                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                        <title_copy
                            cq:styleIds="[1659545825678,1661545829678]"
                            jcr:created="{Date}2023-03-03T16:34:12.950-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2023-05-02T15:21:09.808-04:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Contact for feedback"
                            sling:resourceType="abbvie-com2/components/title/v2/title"
                            type="h3"
                            variant="h"/>
                        <text_1918840030
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2023-05-02T15:22:14.870-04:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2023-05-19T10:23:21.617-04:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>We welcome your feedback on the accessibility of AbbVie.com and AbbVie’s other websites. Please let us know if you encounter any accessibility issues on an AbbVie website or have a suggestion for improving the accessibility or usability of a website by contacting us using one of the methods below. Please make sure to reference the particular website at issue and describe the specific feature you feel is not fully accessible or suggest an improvement:&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>&lt;a href=&quot;/content/abbvie-com2/us/en/contactus.html&quot;>Contact Form&lt;/a>&lt;/li>&#xd;&#xa;&lt;li>E-mail:  &lt;a href=&quot;mailto:webaccessibility@abbvie.com&quot;>webaccessibility@abbvie.com&lt;/a>&lt;/li>&#xd;&#xa;&lt;li>Postal Address: 1 North Waukegan Road, North Chicago, IL, 60064&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                            textIsRich="true"/>
                        <separator_copy
                            cq:styleIds="[1662756423318]"
                            jcr:created="{Date}2023-05-02T15:20:38.160-04:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2023-05-02T15:20:38.160-04:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                        <title_copy_copy
                            cq:styleIds="[1659545825678,1661545829678]"
                            jcr:created="{Date}2023-03-03T16:34:12.950-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2023-05-02T15:25:00.754-04:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Measures to support accessibility"
                            sling:resourceType="abbvie-com2/components/title/v2/title"
                            type="h3"
                            variant="h"/>
                        <text_copy
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2023-03-03T16:36:24.626-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2023-05-02T15:25:25.531-04:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>AbbVie Inc. takes the following measures to ensure accessibility of our websites:&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Include accessibility in our internal policies.&lt;/li>&#xd;&#xa;&lt;li>Appoint an accessibility officer and/or ombudsperson.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                            textIsRich="true"/>
                        <separator_copy_copy
                            cq:styleIds="[1662756423318]"
                            jcr:created="{Date}2023-05-02T15:20:38.160-04:00"
                            jcr:createdBy="chiucx"
