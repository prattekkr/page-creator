                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>This is an accessibility statement from AbbVie Inc.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
