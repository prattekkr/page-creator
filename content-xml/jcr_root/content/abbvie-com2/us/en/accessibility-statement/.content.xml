                            jcr:title="Technical specifications"
                            sling:resourceType="abbvie-com2/components/title/v2/title"
                            type="h3"
                            variant="h"/>
                        <text_copy_copy
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2023-03-03T16:36:24.626-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2023-05-02T15:26:23.663-04:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>Accessibility of our websites rely on the following technologies to work with the particular combination of web browser and any assistive technologies or plugins installed on your computer:&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>HTML&lt;/li>&#xd;&#xa;&lt;li>WAI-ARIA&lt;/li>&#xd;&#xa;&lt;li>CSS&lt;/li>&#xd;&#xa;&lt;li>JavaScript&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>These technologies are relied upon for conformance with the accessibility standards used.&lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
