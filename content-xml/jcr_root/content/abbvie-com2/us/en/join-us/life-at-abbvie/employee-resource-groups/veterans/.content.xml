                                    jcr:lastModified="{Date}2025-08-12T15:01:12.963-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;b>USO – Pathfinder&lt;/b>&lt;/p>&#xd;&#xa;&lt;p>AbbVie supports the USO Pathfinder Transition Program that connects service members with employment opportunities. This program offers support to service members up to 6 months after they have officially left service.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <text_copy_copy_copy__383747574
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2023-01-09T14:28:52.014-05:00"
                                    jcr:createdBy="schafsm"
