                                    jcr:created="{Date}2023-01-07T00:49:42.746-05:00"
                                    jcr:createdBy="schafsm"
                                    jcr:lastModified="{Date}2025-08-12T14:59:58.882-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p style=&quot;text-align: left;&quot;>&lt;b>Employer Support of the Guard (ESGR) program&lt;/b>&lt;br />&#xd;&#xa;&lt;br />&#xd;&#xa;We support the Department of Defense ESGR program which fosters a culture in which all employers support and value the employment and military service of members of the National Guard and Reserve in the United States. ESGR promotes cooperation and understanding between Reserve Component Service members and their civilian employers.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <text_copy_copy_copy_
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2023-01-07T00:49:42.746-05:00"
