                                jcr:primaryType="nt:unstructured"
                                jcr:title="Reach higher ground "
                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                type="h3"
                                variant="h"/>
                            <text
                                cq:styleIds="[1659545825678]"
                                jcr:created="{Date}2022-12-09T17:34:50.014-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2025-02-19T10:23:50.482-05:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>We’re at our best when we push ourselves to grow, try new skills and have the courage to take risks. Aligning your interests with our imperatives as a business, you always have opportunities to step up and reach higher. &amp;nbsp;We don’t just hope everyone at AbbVie will push themselves further, we expect it and support it through a combination of personalized learning opportunities and companywide development programs.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <separator
                                cq:styleIds="[1662756456518]"
                                jcr:created="{Date}2025-02-19T10:29:11.859-05:00"
                                jcr:createdBy="VALENSX5"
                                jcr:lastModified="{Date}2025-02-19T10:29:11.859-05:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                            <title_copy
                                cq:styleIds="[1659545825678,1661545829678]"
                                jcr:created="{Date}2023-01-20T14:26:21.169-05:00"
                                jcr:createdBy="kokajx"
                                jcr:lastModified="{Date}2025-02-19T10:29:26.212-05:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                jcr:title="Your development, your way"
                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                type="h3"
                                variant="h"/>
                            <text_copy
                                cq:styleIds="[1659545825678]"
                                jcr:created="{Date}2022-12-09T17:34:50.014-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2025-02-19T10:29:36.525-05:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>We believe in employees owning their growth and development. Employees define their goals, and AbbVie provides resources to help achieve them. From workshops to global events, our offerings ensure your growth journey is easily accessible, personalized and tailored to your interests.&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>For example, during our award-winning annual Learn.Develop.Perform (LDP) Week, global leaders and experts share their insights on topics like collaboration, business acumen and unconscious bias. Employees curate their learning experience, choosing topics that resonate most with their goals.&lt;/p>&#xd;&#xa;&lt;p>We constantly innovate how learning is delivered. Past events have featured a 24-hour radio station, bite-sized video content through a YouTube channel and TED-style presentations.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </par_13>
