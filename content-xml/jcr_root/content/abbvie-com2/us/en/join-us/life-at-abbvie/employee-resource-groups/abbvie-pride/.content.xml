                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>AbbVie PRIDE’s mission is to foster a safe and inclusive environment for our current and future LGBTQ+ colleagues.&lt;/p>&#xd;&#xa;&lt;p>Our primary objectives are to make a remarkable impact for patients and customers by:&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Encouraging all employees to bring their whole, authentic selves to work, unlocking the exponential potential found in each person.&lt;/li>&#xd;&#xa;&lt;li>Fostering connectivity and internal sense of community.&amp;nbsp;&lt;/li>&#xd;&#xa;&lt;li>Supporting the LGBTQ+ community in visible ways.&lt;/li>&#xd;&#xa;&lt;li>Furthering education around LGBTQ+ issues to raise awareness and heighten sensitivity.&amp;nbsp;&amp;nbsp;&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                            textIsRich="true"/>
                    </container_195460670__1136485499>
