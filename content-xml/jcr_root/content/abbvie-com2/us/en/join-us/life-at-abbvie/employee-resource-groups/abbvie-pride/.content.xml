                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>We strive to cultivate and promote AbbVie’s commitment to LGBTQ+ career development:&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>We offer AbbVie PRIDE members the opportunity to partake in internal and external programs that focus on being an inclusive leader by promoting diversity, inclusion, and belonging in the workplace&lt;/li>&#xd;&#xa;&lt;li>We host workplace events for LGBTQ+ people across the company to “meet and greet” and to establish relationships that could result in future career opportunities&lt;/li>&#xd;&#xa;&lt;li>Our team, along with our partners in HR and Talent Acquisition, collaborate with local colleges and universities to demonstrate our commitment to recruiting and developing a pipeline of LGBTQ+ talent&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                textIsRich="true"/>
