                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;ul>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://www.allergantechalliance.com/Resources/Patient-Savings&quot;>Alphagan® P (brimonidine tartrate) ophthalmic solution&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://www.botoxsavingsprogram.com/&quot;>BOTOX® (onabotulinumtoxinA)&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://www.bystolic.com/&quot;>Bystolic® (nebivolol) tablets&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://www.allergantechalliance.com/Resources/Patient-Savings&quot;>Combigan® (brimonidine tartrate/timolol maleate) opthalmic solution&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://www.creon.com/on-course&quot;>Creon® (pancrelipase) Delayed Release Capsules)&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://www.allergansavingscard.com/crinone/activate&quot;>Crinone® (progesterone) gel&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://www.dalvance.com/reimbursement/patient-savings-program&quot;>Dalvance® (dalbavancin) lyophilisate&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://depakote.com/savings&quot;>Depakote&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>Duopa&lt;br>&#xd;&#xa;Please call 1-(844) DUO-4YOU, which is 1-(844) 386-4968.&amp;nbsp;&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://www.allergantechalliance.com/Resources/Patient-Savings&quot;>Durysta® (bimatoprost) ocular implant&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://www.fetzima.com/depression-resources/savings-card?icid=fetzima_savings_header&quot;>Fetzima® (levomilnacipran) Extended Release Capsules and Titration Pack&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;