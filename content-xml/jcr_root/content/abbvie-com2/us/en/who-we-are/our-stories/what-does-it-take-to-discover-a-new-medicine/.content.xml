                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>Discovery Files: An inside look at why we persevere in the lab every day &lt;/span>&lt;/span>&lt;/p>&#xa;"
