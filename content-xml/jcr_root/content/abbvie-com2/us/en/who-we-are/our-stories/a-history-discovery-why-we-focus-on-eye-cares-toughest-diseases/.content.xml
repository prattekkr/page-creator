                            sling:resourceType="wcm/foundation/components/parsys">
                            <container4
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <text
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-01T03:08:11.212-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2023-05-05T14:53:41.115-04:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>AbbVie eye care leaders Jie Shen, Ph.D., and Mike Robinson, M.D., are driven to elevate the standards of care for challenging eye diseases.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-04-21T11:38:33.370-04:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-04-21T11:38:33.370-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy
                                    cq:styleIds="[1659545825678,1651545825678,1651545825694]"
                                    jcr:created="{Date}2022-11-30T02:11:17.530-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2024-04-15T10:30:50.693-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Continuing a long journey of discovery"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-02T02:54:28.226-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Patrice Keegan has lived with a progressive, hereditary eye disease for 20 years, one that affects millions of people around the globe and is the second-leading cause of blindness.&lt;/p>&#xd;&#xa;&lt;p>Yet, the New York resident finds that many people don’t understand glaucoma and how it affects her daily life.&lt;/p>&#xd;&#xa;&lt;p>A narrow field of vision, balance issues and frequent falls have limited Keegan’s independence and ability to do what she loves, like travel and cook.&lt;/p>&#xd;&#xa;&lt;p>“I don't want my family members, my grandchildren to have to experience the symptoms and the loss of vision that I have,” she says. “That's why raising the standard is important.”&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container4>
                            <video
                                cq:styleIds="[1]"
                                jcr:created="{Date}2022-12-02T02:55:35.432-05:00"
                                jcr:createdBy="kumarvx60"
                                jcr:lastModified="{Date}2023-09-18T02:35:10.355-04:00"
                                jcr:lastModifiedBy="kumarvx60"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/video/v2/video"
                                autoPlay="true"
                                brightcoveAutoPlay="false"
                                btnText="watch 0:22"
                                fileReference="/content/dam/abbvie-com2/images/stories/a-history-of-discovery-why-we-focus-on-challenging-eye-care-diseases/history-of-discovery-yt-screenshot.jpg"
                                loopVideo="false"
                                showBrightcoveControls="false"
                                showPlayerControls="false"
                                showRelatedContent="false"
                                showVideoInfo="false"
                                textIsRich="true"
                                title="Envisioning a better future for glaucoma patients"
                                videoType="youtube"
                                youtubeAutoPlay="false"
                                youtubeUrl="https://www.youtube-nocookie.com/embed/o5_LJ5fqHSA"/>
                            <container
                                cq:styleIds="[1653545825687,1653545847150,1653242825678,1653545835982]"
                                jcr:created="{Date}2022-11-29T14:23:15.605-05:00"
                                jcr:createdBy="sharmrx18"
                                jcr:lastModified="{Date}2022-11-29T14:23:15.605-05:00"
                                jcr:lastModifiedBy="sharmrx18"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <title_copy_copy_copy_1062418293
                                    cq:styleIds="[1659545825678,1651545825678,1651545825694]"
                                    jcr:created="{Date}2022-11-30T02:11:17.530-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2024-04-15T10:29:29.300-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Illuminating a path for better eye care"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_copy_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-05-05T14:55:26.718-04:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>People like Patrice help motivate AbbVie’s eye care scientists to push forward with leading-edge translational research. The company is using innovative approaches to investigate some of the major causes of vision loss and impairment, from various stages of glaucoma to retinal diseases and refractive errors. AbbVie has invested in data convergence, precision medicine, real-world evidence, genetics and genomics and human-based drug discovery to move the needle in translational science.&lt;/p>&#xd;&#xa;&lt;p>With over two decades of experience researching eye diseases, Jie Shen, Ph.D., AbbVie’s vice president of local delivery translational sciences, leads a team of scientists responsible for designing and conducting studies, evaluating drug behavior in the eye, and testing promising drug candidates in early-stage clinical trials.&lt;/p>&#xd;&#xa;&lt;p>Jie and team are driven by a goal to bring medicines with best-in-class outcomes. Pursuing these goals is enabled by an eye care journey that began as Allergan over 75 years ago, bolstered today by AbbVie’s legacy in complex diseases and global scale.&lt;/p>&#xd;&#xa;&lt;p>In this quest to meet patient needs, Jie and team leverage AbbVie’s longstanding expertise in inflammation and neuroscience. Additionally, differentiators like having the same state-of-the-art imaging modalities found in world-class clinical research institutions, digital technologies, statistical modeling and data science accelerate the translation of science to new medicines. According to Jie, AbbVie is also leveraging capabilities at the Genetic Research Center and investing in technology to accelerate and optimize R&amp;amp;D, for example, identifying biomarkers (characteristics of the body that you can measure such as blood pressure) that can help indicate at an early stage whether a drug may be effective.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-04-21T11:38:33.370-04:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-04-21T11:38:33.370-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy_1815371021
                                    cq:styleIds="[1659545825678,1651545825678,1651545825694]"
                                    jcr:created="{Date}2022-11-30T02:11:17.530-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2024-04-15T10:30:59.991-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Putting the spotlight on unmet needs"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_copy_copy_copy_
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-05-05T14:56:34.422-04:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>AbbVie focuses on clinically relevant science to make a meaningful difference for patients and seeks to elevate the standard of care from the front to the back of the eye by addressing areas of unmet needs.&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>For example, retinal diseases present unique challenges because of the barriers to drug delivery to the retina at the back of the eye. Additionally, researchers are limited in their ability to collect a sample for analysis, like you would with a blood or tumor sample for a person taking cancer medication. According to Mike Robinson, M.D., AbbVie’s vice president, clinical development, ophthalmology, the company is investing in gene therapy for retinal diseases.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container>
                            <quote
                                cq:styleIds="[1000000000000]"
                                jcr:created="{Date}2022-12-02T03:00:49.599-05:00"
                                jcr:createdBy="kumarvx60"
                                jcr:lastModified="{Date}2023-01-23T13:02:41.984-05:00"
                                jcr:lastModifiedBy="fusznx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/quote"
                                attributionName="Mike Robinson, M.D."
                                attributionTitle="VP, Clinical Development, Ophthalmology, AbbVie​"
                                quote="These approaches are all potential game changers for patients. While there's no playbook for being a pioneer, we must continue targeting unmet needs."
                                quoteType="regular"
                                textSize="h0"/>
                            <container_copy
                                cq:styleIds="[1653545825687,1653545847150,1653242825678,1653545835982]"
                                jcr:created="{Date}2022-11-29T14:23:15.605-05:00"
                                jcr:createdBy="sharmrx18"
                                jcr:lastModified="{Date}2022-11-29T14:23:15.605-05:00"
                                jcr:lastModifiedBy="sharmrx18"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <title_copy_copy_copy_1062418293
                                    cq:styleIds="[1659545825678,1651545825678,1651545825694]"
                                    jcr:created="{Date}2022-11-30T02:11:17.530-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2024-04-15T10:29:48.187-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Building on a strong foundation to help more patients"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_copy_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-05-05T14:59:01.001-04:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Mike says that strategic collaborations, both inside and out of AbbVie’s walls, are critical to driving new areas of science.&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>With a background in academia and many years as a practicing ophthalmologist, Mike has seen firsthand the great need to elevate the standard of care and continuously improve existing options. While many products exist to treat dry eye, a common condition, there’s still an opportunity to target the inflammation that’s a likely culprit, Mike says.&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>“While there’s no playbook for being a pioneer, we must continue targeting unmet needs and going deep on these diseases,” Mike says.&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>In addition to the company’s genetic research center, Jie also highlights the importance of AbbVie’s biostatistics support, including machine learning, which her team can leverage in the early discovery phase to derive more benefit from available data.&lt;/p>&#xd;&#xa;&lt;p>With glaucoma as the second-leading cause of blindness globally, there continues to be much opportunity and hope for the next breakthrough, Patrice says.&lt;/p>&#xd;&#xa;&lt;p>“I understand there are a lot of failures in science,” she says. “What should keep (scientists) motivated is what keeps me motivated, the fact that you do come upon (ways for people to) have improved quality of life and feel more in control.”&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container_copy>
