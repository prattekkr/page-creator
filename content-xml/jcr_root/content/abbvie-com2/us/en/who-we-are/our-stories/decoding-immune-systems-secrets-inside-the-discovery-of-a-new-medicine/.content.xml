                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2023-04-28T12:10:32.503-04:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/image/v2/image"
                                altValueFromDAM="true"
                                displayPopupTitle="true"
                                fileReference="/content/dam/abbvie-com2/images/stories/Decoding-the-immune-systems-secrets/decoding_immune_systems_secrets_body4_low.jpg"
                                isDecorative="false"
                                titleValueFromDAM="true"/>
                            <container4_copy_copy_1454091355
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <title
                                    cq:styleIds="[1659545825678,1651545825694]"
                                    jcr:created="{Date}2023-04-28T11:57:28.615-04:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-05-08T10:03:57.318-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="The motivator: Sara Murdock, Scientist"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text2
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2023-04-28T12:01:00.620-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;i>Murdock designs, implements and interprets many of the experiments that are part of the immunology drug discovery process.&lt;/i>&lt;/p>&#xd;&#xa;&lt;p>“As a student, I started out as a pharmacy major, which would have led me to a career distributing medicine, but I realized pretty quickly that I wanted to be on the other side of it – developing drugs and coming up with the science behind them – so I switched and graduated with a biology degree.&lt;/p>&#xd;&#xa;&lt;p>Almost everybody knows someone who has rheumatoid arthritis or Crohn's disease and if you know someone that has one of these autoimmune disorders, it really reminds you how despite all the progress, there is still a need for new therapies are needed, and that one new drug can make a huge impact on patients' lives.&lt;/p>&#xd;&#xa;&lt;p>That's what keeps me coming back into the lab and trying to figure it all out: just the possibility of being able to help people. I've been lucky enough to work on projects that have moved into the clinical testing, so that's also incredible motivation for me: seeing what could be possible when our science works.”&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container4_copy_copy_1454091355>
                            <image_copy_copy_copy_466851107
                                cq:styleIds="[1402843082812,1402843082822,1402843082832]"
                                jcr:created="{Date}2023-04-28T11:56:37.425-04:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2023-04-28T12:10:42.704-04:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/image/v2/image"
                                altValueFromDAM="true"
                                displayPopupTitle="true"
                                fileReference="/content/dam/abbvie-com2/images/stories/Decoding-the-immune-systems-secrets/decoding_immune_systems_secrets_body6_low.jpg"
                                isDecorative="false"
                                titleValueFromDAM="true"/>
                            <container4_copy_copy_1181740651
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <title
                                    cq:styleIds="[1659545825678,1651545825694]"
                                    jcr:created="{Date}2023-04-28T11:57:28.615-04:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-05-08T10:04:07.537-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="The inspector: David Duignan, Principal Research Scientist, drug metabolism, pharmacokinetics and bioanalysi"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text2
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2023-04-28T12:01:28.583-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;i>Once a molecule has been identified as having potential to help people, Duignan&amp;nbsp;tests how it gets processed within the body.&lt;/i>&lt;/p>&#xd;&#xa;&lt;p>“The field of pharmacokinetics is all about understanding what the body will do to a medicine once it is taken, because it doesn’t stay there forever, your body eventually eliminates it. To help move that part of the discovery process along, I’ll design experiments to better understand to what degree the medicine is absorbed, metabolized and eliminated and to figure out which molecules might work best for our program. Then, if a molecule or chemical series looks promising, we will also need to conduct experiments to understand what potential molecular interaction risks might exist in patients that will be taking other medications. If there are risks, we will then work to mitigate these risks.&lt;/p>&#xd;&#xa;&lt;p>Right now in immunology, we are working on some relatively novel and non-traditional approaches which makes the work even more exciting. I also really like how our teams work closely together. A lot of informal conversations happen during the day and a lot of decisions can be made outside of meetings. The result is our work can be very fast-paced.”&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container4_copy_copy_1181740651>
