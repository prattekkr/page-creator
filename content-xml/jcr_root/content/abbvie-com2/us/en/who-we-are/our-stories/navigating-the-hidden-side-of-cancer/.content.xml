                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>A cancer diagnosis can upend families’ budgets. Nonprofit Family Reach brings financial relief, and now they’re expanding to help even more families.&lt;/span>&lt;/span>&lt;/p>&#xa;"
                                textIsRich="true"/>
