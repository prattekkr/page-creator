                                fileReference="/content/dam/abbvie-com2/images/stories/abbvie-volunteers-return-to-serving-global-communities-through-week-of-possibilities/volunteers-return_in-body_16x9.jpg"
                                isDecorative="false"
                                titleValueFromDAM="true"/>
                            <container
                                cq:styleIds="[1653545825686]"
                                jcr:created="{Date}2022-12-02T14:21:54.964-05:00"
                                jcr:createdBy="schafsm"
                                jcr:lastModified="{Date}2022-12-02T14:21:54.964-05:00"
                                jcr:lastModifiedBy="schafsm"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <title
                                    cq:styleIds="[1659545825678,1651545825694]"
                                    jcr:created="{Date}2022-12-02T14:22:07.103-05:00"
                                    jcr:createdBy="schafsm"
                                    jcr:lastModified="{Date}2024-04-15T10:23:07.560-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Singapore employees rally to serve their community "
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-02T14:22:35.995-05:00"
                                    jcr:createdBy="schafsm"
                                    jcr:lastModified="{Date}2023-01-09T13:06:31.448-05:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Since Week of Possibilities first began, Judy Low has not only been a volunteer but also acted as a coordinator. Having helped organize events and oversee activities as part of AbbVie public affairs in her earlier role and now, in international communications for Allergan Aesthetics, she knows that things don’t always go right all the time – but has always been impressed by how people have rallied together in a pinch. &lt;/p>&#xd;&#xa;&lt;p>On one occasion volunteers had planned an event to grocery shop with underprivileged children, but health issues caused the event to be cancelled with little notice.&amp;nbsp; &lt;/p>&#xd;&#xa;&lt;p>“This left us with 20 volunteers who were ready but had nowhere to go,” said Low.&lt;br>&#xd;&#xa; &lt;br>&#xd;&#xa;The team quickly adapted. With the help of their nonprofit partner, they pivoted to host an event doing pottery with youth who have special needs.  &lt;/p>&#xd;&#xa;&lt;p>“People were willing to jump in right away. This is the wonderful thing about our volunteers - they come together to make things happen and are flexible and open to serving in whatever way is needed,” she said. “Looking back at how much we were able to achieve together these past years, I’m excited about what more we can do this year.” &lt;/p>&#xd;&#xa;&lt;p>&lt;a href=&quot;https://www.abbvie.com/societal-impact/week-of-possibilities.html&quot; target=&quot;_blank&quot;>Click here to learn more about this event&lt;/a>. &lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <text_221686626
                                    jcr:created="{Date}2022-12-02T14:23:52.958-05:00"
                                    jcr:createdBy="schafsm"
                                    jcr:lastModified="{Date}2023-02-16T11:24:15.457-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
