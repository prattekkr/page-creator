                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>Medical records and insurance claims data help companies, regulators, payers and physicians better understand how medicines perform in the real world.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </container3>
                    </container2>
                    <grid
                        jcr:primaryType="nt:unstructured"
