                        <par_12
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="wcm/foundation/components/parsys">
                            <container4
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <text2
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2026-03-04T13:41:41.527-05:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>In some of Chicago’s most&amp;nbsp;underserved communities, access to health care has gotten easier – thanks to new microsite clinics created by&amp;nbsp;&lt;a href=&quot;https://communityhealth.org/&quot;>CommunityHealth,&lt;/a>&amp;nbsp;in partnership with the AbbVie Foundation. These facilities form a “corridor of care” to address health disparities and access barriers. As of December 2025,&amp;nbsp;CommunityHealth, one of the largest volunteer-based health centers in the nation,&amp;nbsp;operates&amp;nbsp;a total of&amp;nbsp;four&amp;nbsp;microsite clinics in addition to their primary clinic in the Chicagoland area.&lt;/p>&#xd;&#xa;&lt;p>The goal? To create a network of accessible care throughout Chicago’s most vulnerable communities.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container4>
                            <container
                                cq:styleIds="[1653545835982]"
                                jcr:created="{Date}2026-03-04T13:29:44.077-05:00"
                                jcr:createdBy="VALENSX5"
                                jcr:lastModified="{Date}2026-03-04T13:29:44.077-05:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <image_copy
                                    jcr:created="{Date}2026-03-04T13:28:42.464-05:00"
                                    jcr:createdBy="VALENSX5"
                                    jcr:lastModified="{Date}2026-03-04T13:28:51.076-05:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/image/v2/image"
                                    altValueFromDAM="true"
                                    displayPopupTitle="true"
                                    dmPresetType="imagePreset"
                                    fileReference="/content/dam/abbvie-com2/images/stories/communityhealth-microclinic/community-health-map.jpg"
                                    isDecorative="false"
                                    openInNewWindow="false"
                                    titleValueFromDAM="true"/>
                            </container>
                            <quote_copy
                                cq:styleIds="[1000000000000]"
                                jcr:created="{Date}2025-05-07T13:25:02.843-04:00"
                                jcr:createdBy="VALENSX5"
                                jcr:lastModified="{Date}2026-03-04T13:32:39.341-05:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/quote"
                                attributionName="Steph Willding"
                                attributionTitle="CommunityHealth CEO "
                                dmPresetType="imagePreset"
                                quote="With support from the AbbVie Foundation, we’re able to meet patients where they’re at and ensure greater health equity throughout the city."
                                quoteType="regular"
                                textSize="h0"/>
                            <container4_copy_copy
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <separator_copy_copy_
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-10-06T11:00:24.554-04:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-10-06T11:00:24.554-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <text2_copy
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2026-03-04T13:34:18.342-05:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>The AbbVie Foundation has partnered with&amp;nbsp;CommunityHealth&amp;nbsp;for more than two years, serving thousands of uninsured and underserved patients who speak English,&amp;nbsp;Spanish&amp;nbsp;and Polish.&amp;nbsp;CommunityHealth&amp;nbsp;clinician volunteers provide primary and specialty care, medications, lab testing, mental health&amp;nbsp;services&amp;nbsp;and health education at no charge.&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>“We are rethinking space and place for point of care to ensure every Chicago resident is able to access high-quality, culturally competent health care closer to home,” said&amp;nbsp;CommunityHealth&amp;nbsp;CEO Steph&amp;nbsp;Willding. “With support from the AbbVie Foundation, we’re able to meet patients where they’re at and ensure greater health equity throughout the city.”&amp;nbsp;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__1746607130
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-10-06T11:00:24.554-04:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-10-06T11:00:24.554-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title2_copy_copy_cop
                                    cq:styleIds="[1659545825678,1651545824678,1651545825694]"
                                    jcr:lastModified="{Date}2026-03-04T13:34:33.181-05:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Reducing barriers to care  "
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text2_copy_copy
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2026-03-04T13:35:36.738-05:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>In 2025,&amp;nbsp;CommunityHealth,&amp;nbsp;supported by the AbbVie&amp;nbsp;Foundation,&amp;nbsp;opened two microsite clinics in Chicago communities:&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>The first opened in March in the&amp;nbsp;&lt;a href=&quot;https://communityhealth.org/free-health-clinic-opens-in-back-of-the-yards/&quot;>Back of the Yard’s neighborhood.&lt;/a>&amp;nbsp;&lt;/li>&#xd;&#xa;&lt;li>The&amp;nbsp;second opened in December in&amp;nbsp;&lt;a href=&quot;https://communityhealth.org/communityhealth-opens-fourth-microsite-communityhealth-at-rincon-family-services/&quot;>Irving Park&lt;/a>.&amp;nbsp;&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>Both communities have significant uninsured populations, leaving many residents to face economic and cultural barriers to care. Transportation costs and language barriers further complicate access. The clinics offer a variety of essential health care services to uninsured adults.&amp;nbsp;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__1168707482
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-10-06T11:00:24.554-04:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-10-06T11:00:24.554-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title2_copy_copy_cop_262366237
                                    cq:styleIds="[1659545825678,1651545824678,1651545825694]"
                                    jcr:lastModified="{Date}2026-03-04T13:35:17.480-05:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Clinic offerings  "
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text2_copy_copy_copy
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2026-03-04T13:35:52.519-05:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Each microsite clinic uses existing community trust and complements services already available at the location:&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Uninsured and underinsured adults can see a doctor, get laboratory work done, pick up medications and receive referrals to dental and specialty care.&lt;/li>&#xd;&#xa;&lt;li>Virtual appointment options further remove barriers to access, ensuring flexibility for patients with transportation or scheduling challenges.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>“The work&amp;nbsp;CommunityHealth&amp;nbsp;does to improve health outcomes is so meaningful, and it is an honor to partner with them to expand their services and reach through the microsite clinics,” said Keya Miller, president, AbbVie Foundation. “The clinics may be small in size&amp;nbsp;but their impact on the local community is profound.”&amp;nbsp;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__584285229
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-10-06T11:00:24.554-04:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-10-06T11:00:24.554-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title2_copy_copy_cop_1110592234
                                    cq:styleIds="[1659545825678,1651545824678,1651545825694]"
                                    jcr:lastModified="{Date}2026-03-04T13:37:01.247-05:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Bringing health services directly to underserved communities  "
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text2_copy_copy_copy_94789453
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2026-03-04T13:37:09.825-05:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Organizations with deep community roots, like&amp;nbsp;CommunityHealth, help build sustainable healthcare initiatives that create meaningful change. The clinics&amp;nbsp;demonstrate&amp;nbsp;the importance of increasing&amp;nbsp;equitable&amp;nbsp;access to quality health&amp;nbsp;care&amp;nbsp;one community, one clinic&amp;nbsp;and one patient at a time.&amp;nbsp;&amp;nbsp;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__638602702
                                    cq:styleIds="[1662756502570]"
                                    jcr:created="{Date}2023-10-06T11:00:24.554-04:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-10-06T11:00:24.554-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <text2_copy_copy_5593
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2024-10-29T12:22:00.447-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;b>Media inquiries:&lt;/b>&lt;br>&#xd;&#xa;Email:&amp;nbsp;&lt;a href=&quot;mailto:abbviemediarelations@abbvie.com&quot;>abbviemediarelations@abbvie.com&lt;/a>&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container4_copy_copy>
                        </par_12>
