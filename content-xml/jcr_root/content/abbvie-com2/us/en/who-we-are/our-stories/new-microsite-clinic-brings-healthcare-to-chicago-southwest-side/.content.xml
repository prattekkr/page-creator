                                langAttribute="none"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>The AbbVie Foundation and CommunityHealth expand access to essential medical services in local communities.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
