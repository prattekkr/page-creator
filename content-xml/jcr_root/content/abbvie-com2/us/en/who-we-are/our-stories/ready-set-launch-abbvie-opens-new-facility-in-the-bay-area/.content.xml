                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <text2
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2023-01-26T19:02:06.247-05:00"
                                    jcr:lastModifiedBy="schafsm"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>There’s a new addition to the South San Francisco skyline – a brand new research facility equipped with state-of-the-art laboratories and collaborative workspaces.&lt;/p>&#xa;&lt;p>Today marks the grand opening of our new site in the Bay Area. Here our main focus is on researching, developing and commercializing new medicines to treat cancer. This work is a critical piece of our U.S. operations and global R&amp;amp;D footprint, which spans to more than 20 countries with research and manufacturing sites. It also builds on our expertise and legacy of research in oncology.&lt;/p>&#xa;"
                                    textIsRich="true"/>
                            </container4>
