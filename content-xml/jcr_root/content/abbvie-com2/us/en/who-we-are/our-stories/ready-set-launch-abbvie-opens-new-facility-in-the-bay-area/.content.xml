                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;b>Media inquiries:&lt;/b>&lt;br>&#xa;Name: Ilke Limoncu&lt;br>&#xa;Email:&amp;nbsp;&lt;a href=&quot;mailto:ilke.limoncu@abbvie.com&quot;>ilke.limoncu@abbvie.com&lt;/a>&lt;br>&#xa;Call: +1 (650) 540-6145&lt;/p>&#xa;"
                                    textIsRich="true"/>
