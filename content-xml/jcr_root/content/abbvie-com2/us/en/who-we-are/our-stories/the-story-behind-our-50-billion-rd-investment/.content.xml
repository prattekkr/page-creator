                            <text
                                cq:styleIds="[1659545825678,1659545835858]"
                                jcr:lastModified="{Date}2022-12-01T04:52:14.143-05:00"
                                jcr:lastModifiedBy="kumarvx60"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>Discovering and developing new medicines is not easy. But it’s an aspiration that drives our science and is the foundation of this company.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </container3>
                    </container2>
