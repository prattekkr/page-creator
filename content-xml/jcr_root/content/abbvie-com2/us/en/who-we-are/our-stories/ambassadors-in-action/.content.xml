                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>Assembling the pieces of a blockbuster corporate culture.&lt;/span>&lt;/span>&lt;/p>&#xa;"
                                textIsRich="true"/>
                        </container3>
                    </container2>
                    <grid
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="abbvie-com2/components/grid/v2/grid"
                        rowCount="1">
