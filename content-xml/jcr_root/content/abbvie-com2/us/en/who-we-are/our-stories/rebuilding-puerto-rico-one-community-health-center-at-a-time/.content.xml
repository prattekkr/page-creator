                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <separator_copy
                                    cq:styleIds="[1662756456518]"
                                    jcr:created="{Date}2023-01-29T15:53:34.020-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-29T15:53:34.020-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <text
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-05T17:29:01.790-05:00"
                                    jcr:createdBy="schafsm"
                                    jcr:lastModified="{Date}2022-12-05T17:29:22.113-05:00"
                                    jcr:lastModifiedBy="schafsm"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Centro de Salud Familiar clinic serves about 13,000 people annually. It is the only provider of primary and preventive health service for Arroyo, Guayama and the surrounding rural areas.&lt;/p>&#xa;&lt;p>The clinic received an emergency grant from Direct Relief to help bring it back to full strength after Maria caused wind and water damage. The clinic is also a recipient of the AbbVie donation, which funded a custom-built mobile medical unit to reach community members in rural, mountainous areas.&lt;/p>&#xa;&lt;p>Yesenia Ortiz, 27, works at the clinic as a health records clerk. Her family home in Arroyo was so badly damaged that it had to be demolished and rebuilt, a slow process that is not quite complete over a year later.&lt;/p>&#xa;"
                                    textIsRich="true"/>
                            </container_1812379146>
                            <video
