                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>From ensuring backup energy sources to introducing a telemedicine program, Direct Relief anchors Puerto Rico’s resurgence in good health.&lt;/span>&lt;/span>&lt;/p>&#xa;"
                                textIsRich="true"/>
                        </container3>
                    </container2>
