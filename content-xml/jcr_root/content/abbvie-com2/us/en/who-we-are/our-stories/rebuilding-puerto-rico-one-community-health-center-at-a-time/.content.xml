                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;body-unica-8-reg&quot;>&lt;/span>&lt;sup>The emergency room of the Centro de Salud Familiar clinic in Arroyo, Puerto Rico, sustained water and wind damage during Hurricane Maria.&lt;/sup>&lt;/p>&#xa;"
                                textIsRich="true"/>
                            <container_1812379146
                                cq:styleIds="[1653545825687,1653545847150,1653242825678,1653545835982]"
                                jcr:created="{Date}2022-12-05T17:28:30.954-05:00"
