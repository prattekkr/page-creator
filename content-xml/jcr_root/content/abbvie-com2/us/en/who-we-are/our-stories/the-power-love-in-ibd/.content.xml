                                    text="&lt;p>&lt;span class=&quot;body-unica-20-reg&quot;>&lt;b>Media inquiries:&lt;/b>&lt;/span>&lt;br>&#xd;&#xa;Shannelle Fowler&lt;br>&#xd;&#xa;Email:&amp;nbsp;&lt;a href=&quot;mailto:shannelle.fowler@abbvie.com&quot;>shannelle.fowler@abbvie.com&lt;/a>&lt;br>&#xd;&#xa;Call: +1 (773) 520-2106&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
