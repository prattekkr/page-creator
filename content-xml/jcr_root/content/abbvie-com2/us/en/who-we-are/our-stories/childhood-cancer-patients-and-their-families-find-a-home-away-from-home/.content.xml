                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>With AbbVie’s $50 million donation, St. Jude opens a new home-like environment where patient families can relax, recover and connect &lt;/span>&lt;/span>&lt;/p>&#xa;"
                                textIsRich="true"/>
