                            sling:resourceType="wcm/foundation/components/parsys">
                            <container4
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <separator_copy_copy_
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <text_1091121937
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-07T05:33:30.724-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2022-12-08T00:15:44.743-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Howard J. Jacob, Ph.D., vice president and head of genomic research, AbbVie&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <text
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-01T03:08:11.212-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2022-12-08T00:16:04.885-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;i>Howard J. Jacob, Ph.D., was a member of the first team ever to use genome sequencing to diagnose, treat&amp;nbsp;and cure a patient. It was 2009, and the patient was a 6-year-old whose symptoms baffled doctors for years. Working with scientists and physicians, Dr. Jacob’s team sequenced the boy’s DNA and diagnosed his rare disease, which allowed him to undergo a successful bone marrow transplant.&lt;/i>&lt;/p>&#xd;&#xa;&lt;p>&lt;i>Almost a decade later, Dr. Jacob is using the same technology to potentially help millions of patients. As AbbVie’s new vice president and head of genomic research, he brings decades of genomic knowledge from academia and the clinic into the company’s labs. We spoke with Dr. Jacob about the current state of whole genome sequencing, and its potential for both patients and those simply interested in learning more about their “own personal blueprint.”&lt;/i>&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy
                                    cq:styleIds="[1662756409908]"
                                    jcr:created="{Date}2022-12-07T04:23:38.517-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2022-12-07T04:23:38.517-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title
                                    cq:styleIds="[1659545825678,1651545825678,1651545825694]"
                                    jcr:created="{Date}2022-11-30T02:11:17.530-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2024-04-18T10:48:09.920-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="What is whole genome sequencing and how could this technology help scientists discover new treatments?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-08T00:16:36.785-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Jacob: Whole genome sequencing (WGS) is the process of reading a person’s DNA. This is a massive amount of data -- three billion chemical units in the DNA from your mom and another three billion chemical units in your DNA from your dad. The genetic information derived is essentially a personal health blueprint revealing potential disease risks, how you will react to certain treatments and more. When scientists look at these blueprints for millions of people, ultimately we hope to make new and better medicines.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy
                                    cq:styleIds="[1662756409908]"
                                    jcr:created="{Date}2022-12-07T04:23:38.517-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2022-12-07T04:23:38.517-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy
                                    cq:styleIds="[1659545825678,1651545825678,1651545825694]"
                                    jcr:created="{Date}2022-11-30T02:11:17.530-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2024-04-18T10:48:23.710-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="What do you hope to accomplish in your new role at AbbVie?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-08T00:17:20.807-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Jacob: I hope to help more patients, perhaps whole classes of patients. After decades in a clinical setting, I will miss directly working with patients. But in many ways, I bring these patients with me into the research labs here, where I work with a large team to use DNA sequencing to determine what causes some of the world’s most challenging diseases.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container4>
                            <image
                                cq:styleIds="[1402843082832]"
                                jcr:created="{Date}2022-12-07T04:42:37.924-05:00"
                                jcr:createdBy="kumarvx60"
                                jcr:lastModified="{Date}2022-12-08T00:17:43.407-05:00"
                                jcr:lastModifiedBy="kumarvx60"
                                jcr:primaryType="nt:unstructured"
                                jcr:title="Whole genome sequencing (WGS) is the process of reading a person’s DNA (credit: Shutterstock)"
                                sling:resourceType="abbvie-com2/components/image/v2/image"
                                altValueFromDAM="true"
                                displayPopupTitle="false"
                                fileReference="/content/dam/abbvie-com2/images/stories/the-blueprint-of-you/blueprint_of_you_DNA_image.jpg"
                                isDecorative="false"
                                titleValueFromDAM="false"/>
                            <container
                                cq:styleIds="[1653545825687,1653545847150,1653242825678,1653545835982]"
                                jcr:created="{Date}2022-11-29T14:23:15.605-05:00"
                                jcr:createdBy="sharmrx18"
                                jcr:lastModified="{Date}2022-11-29T14:23:15.605-05:00"
                                jcr:lastModifiedBy="sharmrx18"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <separator_copy
                                    cq:styleIds="[1662756456518]"
                                    jcr:created="{Date}2022-12-07T04:23:38.517-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2022-12-07T04:23:38.517-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <separator_copy_copy_
                                    cq:styleIds="[1662756409908]"
                                    jcr:created="{Date}2022-12-07T04:23:38.517-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2022-12-07T04:23:38.517-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy
                                    cq:styleIds="[1659545825678,1651545825678,1651545825694]"
                                    jcr:created="{Date}2022-11-30T02:11:17.530-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2024-04-18T10:48:34.253-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Whole genome sequencing seems useful for patients suspected of having a rare disease. But what about people who are seemingly healthy?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-07T05:36:10.028-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2022-12-08T00:18:24.124-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Jacob: Bridges are inspected using blueprints by structural engineers so they don’t fall down. What if doctors could use our personal blueprints the same way? Completing the mapping of the human genome in 2003 took more than a decade and one&amp;nbsp;billion – and that was&amp;nbsp;to map just one genome. Today, the same process takes a couple of days for a mere fraction of the cost. I would love to see a future where genomes are sequenced the day you are born so you know your risk of getting certain diseases, the best treatments to take and even which foods to eat to stay healthy.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-12-07T05:02:47.289-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2022-12-07T05:02:47.289-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy
                                    cq:styleIds="[1659545825678,1651545825678,1651545825694]"
                                    jcr:created="{Date}2022-11-30T02:11:17.530-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2024-04-18T10:48:43.865-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Have you sequenced your own genome?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-08T00:18:45.691-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Jacob: Of course! I would not let this technology pass me by. I discovered 50 common medicines that won’t work correctly for me based on my genetic makeup. I also modified my diet and reduced my chances of getting diabetes based on my results.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_192593614
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-12-07T05:02:47.289-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2022-12-07T05:02:47.289-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy_1123930835
                                    cq:styleIds="[1659545825678,1651545825678,1651545825694]"
                                    jcr:created="{Date}2022-11-30T02:11:17.530-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2024-04-18T10:48:52.331-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="What does the future hold for genomic sequencing?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-08T00:19:24.216-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Jacob: In 20 years, I hope WGS is like the internet -- a technology that changed everything and is something we can’t imagine life without. Then, maybe we will be talking about curing and preventing diseases along with new treatments that are tailored to fit the makeup of individual patients.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_19259
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-12-07T05:02:47.289-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2022-12-07T05:02:47.289-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy_566828070
                                    cq:styleIds="[1659545825678,1651545825678,1651545825694]"
                                    jcr:created="{Date}2022-11-30T02:11:17.530-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2024-04-18T10:49:02.213-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="If you hadn’t chosen science as a career, what else would you be doing?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_copy_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-08T00:19:58.517-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Jacob: Science, exploration and forging new ground was my world even as a kid. When I was 5&amp;nbsp;years old, Jacques Cousteau was my hero; later in college, I switched my focus from marine biology to pharmacology, which was the focus of my Ph.D.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_19259_946792659
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-12-07T05:02:47.289-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2022-12-07T05:02:47.289-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy_1952730506
                                    cq:styleIds="[1659545825678,1651545825678,1651545825694]"
                                    jcr:created="{Date}2022-11-30T02:11:17.530-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2024-04-18T10:49:11.753-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="What’s written on your office whiteboard?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_copy_copy_copy_
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-08T00:20:32.275-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Jacob: Concepts for how we will use a million genomes to help discover new treatments. I want to use science and the latest cutting-edge technology available to help patients who need answers and new and better treatment options.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_19259_1806308258
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-12-07T05:02:47.289-05:00"
                                    jcr:createdBy="kumarvx60"
