                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>His team’s job is to explore the unknown. Get to know our new head of discovery research and what it takes to explore uncharted territory.&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </container3>
                    </container2>
