                                jcr:title="Magnified Featuring Jonathon Sedgwick"
                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                type="h1"
                                variant="h"/>
                            <text
                                cq:styleIds="[1659545835858,1659545825678]"
