                        enableFetchPriority="false"
                        enableLazyLoading="false"
                        langAttribute="none">
                        <teaser_copy
                            cq:styleIds="[2]"
                            jcr:description="&lt;p>Throughout the 2026 MLB&amp;nbsp;season, AbbVie will donate $20 for every strikeout, a deliberate reflection of the 20% of the population worldwide who will be diagnosed with cancer before age 75.&lt;sup>1&lt;/sup>&lt;/p>&#xd;&#xa;&lt;p>With the league averaging over 40,000 strikeouts annually, AbbVie has pledged up to $1 million per season in donations to support this cause. This initiative creates season-long opportunities to drive awareness and fund critical cancer advocacy and research on a national stage.&lt;/p>&#xd;&#xa;"
                            jcr:lastModified="{Date}2026-03-24T08:17:49.012-04:00"
                            jcr:lastModifiedBy="bryanjx9"
                            jcr:primaryType="nt:unstructured"
                            jcr:title="&lt;p>Every strikeout.&lt;br />&#xd;&#xa;Every game. &lt;br />&#xd;&#xa;&lt;span style=&quot;color: rgb(71,159,248);&quot;>All season long.&lt;/span>&lt;/p>&#xd;&#xa;"
                            sling:resourceType="abbvie-com2/components/teaser/v2/teaser"
                            ctaTarget="_self"
                            textIsRich="[true,true]"/>
                        <text
                            cq:styleIds="[1659545835859]"
                            jcr:created="{Date}2026-03-24T07:37:08.787-04:00"
