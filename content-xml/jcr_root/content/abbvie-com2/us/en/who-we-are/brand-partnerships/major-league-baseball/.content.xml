                            jcr:lastModifiedBy="bryanjx9"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            langAttribute="none"
                            text="&lt;p style=&quot;text-align: right;&quot;>&lt;a href=&quot;https://gco.iarc.who.int/media/globocan/factsheets/populations/900-world-fact-sheet.pdf&quot; target=&quot;_blank&quot;>&lt;span class=&quot;body-unica-16-reg&quot;>1. Global Cancer Observatory, World Health Organization, 2022&lt;/span>&lt;/a>&lt;/p>&#xd;&#xa;"
