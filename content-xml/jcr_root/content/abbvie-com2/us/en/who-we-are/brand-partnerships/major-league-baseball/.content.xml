                                langAttribute="none"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>With every strikeout thrown this Major League Baseball&amp;nbsp;season, AbbVie is donating to charities that help fight cancer and support cancer patients and their families.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </container3>
                    </container2>
                    <container_397828246
