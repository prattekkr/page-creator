                                jcr:title="Our Commitment to Ethical and Responsible Use of Animals in Research"
                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                type="h1"
                                variant="h"/>
                            <text
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2024-06-07T11:13:39.510-04:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>At AbbVie, our mission is to discover and deliver innovative medicines and solutions that address complex health issues and enhance people's lives. In this pursuit, we hold to the highest standards of ethical animal use in research.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <separator_copy_copy_
                                cq:styleIds="[1662756456518]"
                                jcr:created="{Date}2022-12-05T12:22:48.644-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2022-12-05T12:22:48.644-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                            <text_copy_copy
                                cq:styleIds="[1659545825678]"
                                jcr:created="{Date}2022-12-05T18:02:53.586-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2024-06-07T11:37:56.265-04:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Our commitment is reflected in our compliance with global regulatory agencies, including the U.S. Food and Drug Administration (FDA), European Medicines Agency (EMA), and Japan Pharmaceuticals and Medical Devices Agency (PMDA). These agencies require new medicines and medical devices to undergo safety and efficacy evaluation, which may necessitate animal testing.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </container3>
                    </container2>
                    <grid_copy_copy_18801
                        cq:styleIds="[0]"
                        jcr:created="{Date}2022-12-16T16:39:47.272-05:00"
                        jcr:createdBy="chiucx"
                        jcr:lastModified="{Date}2023-02-11T15:06:39.948-05:00"
                        jcr:lastModifiedBy="chiucx"
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="abbvie-com2/components/grid/v2/grid"
                        rowCount="1">
                        <par_12
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="wcm/foundation/components/parsys">
                            <container_568753235
                                cq:styleIds="[1653545825687,1653545847150,1653242825678,1653545835982,1653545835879]"
                                jcr:created="{Date}2022-12-16T18:05:55.966-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2022-12-16T18:05:55.966-05:00"
