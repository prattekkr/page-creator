                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/text/v2/text"
                                        text="&lt;ol>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://www.nature.com/articles/d41573-025-00038-6&quot;>Accelerating adoption of new approach methodologies in regulatory decision making: an industry perspective&amp;nbsp;&lt;/a>&lt;br>&#xd;&#xa;&lt;i>&lt;b>Nature Reviews Drug Discovery&lt;/b> &lt;/i>| https://doi.org/10.1038/d41573-025-00038-6&lt;br>&#xd;&#xa;AbbVie author: Raymond C. Votzmeyer&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://www.nature.com/articles/s41551-023-01154-7&quot;>Towards in vitro models for reducing or replacing the use of animals in drug testing&lt;/a>&lt;br>&#xd;&#xa;&lt;b>&lt;i>Nature Biomedical Engineering&lt;/i>&amp;nbsp;&lt;/b>| https://doi.org/10.1038/s41551-023-01154-7&lt;br>&#xd;&#xa;AbbVie authors: David M. Stresser, Terry R. Van Vleet, Prathap Kumar S. Mahalingaiah, Denice O’Connell, Gary J. Jenkins, Sherry L. Ralston&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://www.sciencedirect.com/science/article/pii/S0378517323002624?via%3Dihub&quot;>In-vitro modeling of intravenous drug precipitation by the optical spatial precipitation analyzer (OSPREY)&lt;/a>&lt;br>&#xd;&#xa;&lt;b>&lt;i>International Journal of Pharmaceutics&lt;/i>&lt;/b>&amp;nbsp;| https://doi.org/10.1016/j.ijpharm.2023.122842&lt;br>&#xd;&#xa;AbbVie authors: Andrew J.&amp;nbsp;Radosevich,&amp;nbsp;Ruth L.&amp;nbsp;Martin,&amp;nbsp;Wayne R.&amp;nbsp;Buck,&amp;nbsp;Lauren&amp;nbsp;Hicks,&amp;nbsp;Amanda&amp;nbsp;Wilsey,&amp;nbsp;Jeffrey Y.&amp;nbsp;Pan&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://www.frontiersin.org/journals/genetics/articles/10.3389/fgene.2022.1078050/full&quot;>Preclinical species gene expression database: Development and meta-analysis&lt;/a>.&lt;br>&#xd;&#xa;&lt;i>&lt;b>Frontiers in Genetics&lt;/b>&lt;/i>&amp;nbsp;| https://doi.org/10.3389/fgene.2022.1078050&lt;br>&#xd;&#xa;AbbVie authors: Caitlin Krause, Kinga Suwada, Eric A. G. Blomme, Kenneth Kowalkowski, Michael J. Liguori, Prathap Kumar Mahalingaiah, Scott Mittelstadt, Richard Peterson, Lauren Rendino, Andy Vo, Terry R. Van Vleet&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://doi.org/10.1039/C9LC01168D&quot; title=&quot;Link to landing page via DOI&quot;>Introduction to a manuscript series on the characterization and use of microphysiological systems (MPS) in pharmaceutical safety and ADME applications&lt;/a>&lt;br>&#xd;&#xa;&lt;b>&lt;i>Lab on a Chip&lt;/i>&lt;/b>&lt;i>&amp;nbsp;&lt;/i>| https://doi.org/10.1039/C9LC01168D&lt;br>&#xd;&#xa;AbbVie authors: Sherry Ralston, Terry R. Van Vleet&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://www.frontiersin.org/journals/big-data/articles/10.3389/fdata.2019.00025/full&quot;>Novel computational approach to predict off-target interactions for small molecules&lt;/a>&lt;br>&#xd;&#xa;&lt;b>&lt;i>Frontiers in Big Data&lt;/i>&lt;/b>&lt;i>&amp;nbsp;&lt;/i>| https://doi.org/10.3389/fdata.2019.00025&lt;br>&#xd;&#xa;AbbVie authors: Mohan S. Rao, Rishi Gupta, Michael J. Liguori, Mufeng Hu, Xin Huang, Srinivasa R. Mantena, Scott W. Mittelstadt, Eric A. G. Blomme, Terry R. Van Vleet&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://currentprotocols.onlinelibrary.wiley.com/doi/abs/10.1002/cptx.45&quot;>An in vitro model of hematotoxicity: differentiation of bone marrow–derived stem/progenitor cells into hematopoietic lineages and evaluation of lineage‐specific hematotoxicity&lt;/a>&lt;br>&#xd;&#xa;&lt;b>&lt;i>Current Protocols in Toxicology&lt;/i>&lt;/b>&lt;i>&amp;nbsp;&lt;/i>| https://doi.org/10.1002/cptx.45&lt;br>&#xd;&#xa;AbbVie authors: Prathap Kumar Mahalingaiah, Tammy Palenski, Terry R. Van Vleet&lt;/li>&#xd;&#xa;&lt;/ol>&#xd;&#xa;&lt;p>&amp;nbsp;&lt;/p>&#xd;&#xa;"
                                        textIsRich="true"/>
                                </accordion_1663597195>
                                <title_116699496_copy_1868904524
                                    cq:styleIds="[1659545825678,1661545829678,1651545825693]"
