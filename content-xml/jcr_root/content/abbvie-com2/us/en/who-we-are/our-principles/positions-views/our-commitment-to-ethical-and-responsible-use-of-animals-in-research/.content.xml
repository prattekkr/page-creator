                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2025-04-17T09:54:20.737-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Allergan Aesthetics, an AbbVie company, develops a portfolio of leading aesthetics brands and products.&amp;nbsp;Allergan Aesthetics does not conduct testing on animals for its cosmetic skin care products.&lt;/p>&#xd;&#xa;"
