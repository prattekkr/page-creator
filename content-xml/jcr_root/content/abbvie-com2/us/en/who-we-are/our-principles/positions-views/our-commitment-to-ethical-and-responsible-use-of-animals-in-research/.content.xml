                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <title_116699496
                                    cq:styleIds="[1659545825678,1661545829678,1651545825693]"
                                    jcr:created="{Date}2022-12-15T11:49:26.700-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-06-25T14:32:40.475-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Policy and approach"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-07T14:53:09.069-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2025-04-07T13:01:23.160-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>We strive to minimize or replace animal use wherever possible in our research and development programs. Animal testing only occurs when no viable alternatives can provide the necessary data to discover and develop safe and effective medicines and devices. To this end, we work closely with regulatory agencies to reduce the need for animal-based testing in our product development and manufacturing processes.&lt;/p>&#xd;&#xa;&lt;p>AbbVie's Global Animal Welfare Policy assures that everyone involved in our operations, from employees and contractors to suppliers and partners, understands and adheres to our high expectations for animal welfare. We will not&amp;nbsp;contract or partner with organizations that do not uphold similar standards.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2024-06-07T14:48:37.428-04:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-06-07T14:48:37.428-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <separator_copy
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2024-06-07T14:48:37.428-04:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-06-07T14:48:37.428-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_116699496_copy_2005055571
                                    cq:styleIds="[1659545825678,1661545829678,1651545825693]"
                                    jcr:created="{Date}2022-12-15T11:49:26.700-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-06-25T14:33:02.241-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Commitment to the 3Rs"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_copy_copy_copy_
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-07T14:53:09.069-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-07-30T14:07:29.142-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>At the core of our scientific efforts are the internationally recognized principles of the “3Rs”:&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>&lt;b>Replacement&lt;/b>: Replace animal studies with non‐animal or insentient alternatives methods.&lt;/li>&#xd;&#xa;&lt;li>&lt;b>Reduction&lt;/b>: Reduce the number of animals to achieve research objectives.&lt;/li>&#xd;&#xa;&lt;li>&lt;b>Refinement&lt;/b>: If animals must be used, modify procedures to minimize potential for pain and/or distress.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>AbbVie scientists continually strive to advance the 3Rs within our programs, integrating technologies such as 3-D printed anatomic models, artificial tissues, microphysiological systems (e.g. organ on a chip), digital biomarkers and other computer modeling techniques, and cell-based assays.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy_1689911009
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2024-06-07T14:48:37.428-04:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-06-07T14:48:37.428-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <accordion
                                    cq:styleIds="[1,8]"
                                    jcr:created="{Date}2024-06-07T15:02:02.081-04:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2025-04-07T13:02:38.308-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/accordion/v2/accordion"
                                    heading="Examples of our SCIENTIFIC EFFORTS "
                                    singleExpansion="false">
                                    <item_1717786996968
                                        cq:panelTitle="Machine Learning and Big Data"
                                        cq:styleIds="[1659545825678]"
                                        jcr:lastModified="{Date}2024-06-25T14:42:06.495-04:00"
                                        jcr:lastModifiedBy="chiucx"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/text/v2/text"
                                        text="&lt;p>AbbVie researchers are leveraging machine learning and big data to improve drug toxicity evaluation, a critical aspect of drug development. They utilize machine learning methods to analyze large toxicology datasets, aiding in the early detection of drug toxicity, potentially reducing development timelines and improving drug safety and efficacy. &lt;a href=&quot;https://pubmed.ncbi.nlm.nih.gov/30040226/&quot; target=&quot;_blank&quot;>Learn more&lt;/a>&lt;/p>&#xd;&#xa;"
                                        textIsRich="true"/>
                                    <item_1717787010304
                                        cq:panelTitle="Organoids"
                                        cq:styleIds="[1659545825678]"
                                        jcr:lastModified="{Date}2024-06-25T14:42:39.239-04:00"
                                        jcr:lastModifiedBy="chiucx"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/text/v2/text"
                                        text="&lt;p>Researchers at AbbVie have developed a method to grow and study cells from the human colon in the lab, modeling the way these cells behave in the human body. These &amp;quot;organoid&amp;quot; cultures could be used to study diseases such as inflammatory bowel disease, and could form the basis for the development of new therapies. &lt;a href=&quot;https://pubmed.ncbi.nlm.nih.gov/33643277/&quot; target=&quot;_blank&quot;>Learn more&lt;/a>&lt;/p>&#xd;&#xa;"
                                        textIsRich="true"/>
                                    <item_1717787020064
                                        cq:panelTitle="Cell-Based Potency Assay "
                                        cq:styleIds="[1659545825678]"
                                        jcr:lastModified="{Date}2025-04-14T10:15:11.009-04:00"
                                        jcr:lastModifiedBy="VALENSX5"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/text/v2/text"
                                        text="&lt;p>In June 2011, we received FDA approval for a non-animal, in vitro, cell-based assay for product release testing of one of AbbVie’s neurotoxins.&lt;sup>1&lt;/sup>&lt;/p>&#xd;&#xa;"
                                        textIsRich="true"/>
                                </accordion>
                                <accordion_1663597195
                                    cq:styleIds="[1]"
                                    jcr:created="{Date}2024-06-25T14:47:51.391-04:00"
                                    jcr:createdBy="chiucx"
