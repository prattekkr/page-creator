                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Animal enrichment and care program"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_copy_copy_copy__2055360426
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-07T14:53:09.069-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-07-30T14:16:17.207-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Our programs are supported by highly trained technical staff and board-certified veterinarians who specialize in research animal care. We also have a robust Global Animal Welfare Program that ensures maintenance of the highest industry welfare standards.&lt;/p>&#xd;&#xa;&lt;p>We have specialists and teams dedicated and committed to advancing animal care and non-animal alternative testing methods. For instance, our Enrichment Committee and dedicated Animal Behavioral Specialist collaborate to develop industry-leading programs for animal care, incorporating innovative enrichment and species-appropriate housing and socialization practices.&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>AbbVie voluntarily maintains accreditation from Association for Assessment and Accreditation of Laboratory Animal Care International (AAALAC) and our programs and facilities consistently exceed regulatory requirements.&amp;nbsp;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
