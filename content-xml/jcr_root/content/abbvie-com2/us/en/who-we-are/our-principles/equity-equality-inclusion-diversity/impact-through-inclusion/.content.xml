                                jcr:lastModified="{Date}2024-08-16T16:33:34.008-04:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                jcr:title="Our actions speak for themselves"
                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                type="h2"
                                variant="h"/>
                            <text
                                cq:styleIds="[1659545825678]"
                                jcr:created="{Date}2022-12-09T17:34:50.014-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2025-07-16T12:17:39.596-04:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>We are constantly striving to raise the bar in our workplace and in the communities where we work and live.&lt;/p>&#xd;&#xa;&lt;p>&lt;b>Building a world-class workforce&lt;/b>&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Through inclusive education programs, we give colleagues around the world the opportunity to learn from one another while we build high performing teams.&lt;/li>&#xd;&#xa;&lt;li>We prioritize leadership development and provide one-on-one mentoring that pairs high performing talent with AbbVie senior executives.&amp;nbsp;&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>&lt;b>&lt;br>&#xd;&#xa;Driving an inclusive culture through awareness and understanding&lt;/b>&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>We believe that having a voice is about more than volume – it is about belonging – feeling empowered to share your unique perspective as part of a collaborative, high-performing team.&lt;/li>&#xd;&#xa;&lt;li>Our &lt;a href=&quot;/content/abbvie-com2/us/en/join-us/life-at-abbvie/employee-resource-groups.html&quot; style=&quot;font-size: 0.8125rem; background-color: rgb(255, 255, 255);&quot;>employee resource groups&lt;/a>&lt;span style=&quot;font-size: 0.8125rem;&quot;> are open to all employees and reflect our belief that inclusion benefits everyone and drives high performance.&lt;/span>&lt;/li>&#xd;&#xa;&lt;li>We are committed to accessibility for all – so our employees can reach their full potential.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>&lt;br>&#xd;&#xa;&lt;b>Creating connections and fostering well-being&lt;/b>&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>We partner with employees on their well-being journey, connecting them to &lt;a href=&quot;/content/abbvie-com2/us/en/join-us/life-at-abbvie/well-being-in-the-workplace.html&quot;>tools and support&lt;/a> at work and at home.&amp;nbsp;&lt;/li>&#xd;&#xa;&lt;li>We’ve made dialogue an everyday way of life at AbbVie, fostering connection to one another and creating space for all to contribute their unique value.&amp;nbsp;&lt;/li>&#xd;&#xa;&lt;li>As part of AbbVie’s commitment to building community, our Employee Resource Groups (ERGs) partner with the AbbVie Foundation to support a variety of nonprofit organizations.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>&amp;nbsp;&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <text_288566735
                                jcr:created="{Date}2025-07-16T12:19:44.461-04:00"
                                jcr:createdBy="VALENSX5"
                                jcr:lastModified="{Date}2025-07-16T12:19:55.705-04:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;b>Our vision is that all our employees can say:&lt;/b>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
