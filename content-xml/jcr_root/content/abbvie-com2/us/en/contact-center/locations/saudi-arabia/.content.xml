                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                type="h5"/>
                            <text
                                jcr:created="{Date}2022-12-23T15:56:40.458-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2024-01-16T09:57:47.866-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Scientific Office – Riyadh&lt;br>&#xd;&#xa;Abraj Attawuneyyah&lt;br>&#xd;&#xa;North Tower, 16th Floor&lt;br>&#xd;&#xa;P.O. Box 9710 Riyadh, 11423&lt;br>&#xd;&#xa;+966 11 299 4200 (OFFICE)&lt;br>&#xd;&#xa;+966 11 299 4288 (FAX)&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <text_597648167
                                cq:styleIds="[1659545825678]"
                                jcr:created="{Date}2022-12-23T16:13:14.081-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2026-03-10T14:23:01.082-04:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                langAttribute="none"
                                text="&lt;p>&lt;b>If you are seeking medical information related to an AbbVie Biopharmaceuticals GmbH product(s), please contact the medical information team at:&lt;/b>&lt;/p>&#xd;&#xa;&lt;p style=&quot;margin-left: 40.0px;&quot;>&lt;a href=&quot;mailto:medinfo_saudi@abbvie.com&quot;>medinfo_saudi@abbvie.com&lt;/a>&lt;br>&#xd;&#xa;or&lt;br>&#xd;&#xa;submit your query via &lt;a href=&quot;https://www.abbviemedinfo.com&quot;>www.abbviemedinfo.com&lt;/a> (Healthcare Professionals only)&lt;/p>&#xd;&#xa;&lt;p>&lt;b>If you would like to report an Adverse Event(s) related to AbbVie product(s) (medication side effects) or Product Quality Complaints (issues with the quality of one of our AbbVie products), you may contact the AbbVie Affiliate Safety Representative/Quality team:&lt;/b>&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;&lt;p style=&quot;margin-left: 40.0px;&quot;>For Adverse Events reporting:&lt;br>&#xd;&#xa;Email:&amp;nbsp;&lt;a href=&quot;mailto:PV.KSA@abbvie.com&quot;>PV.KSA@abbvie.com&lt;/a>&lt;br>&#xd;&#xa;Hotline number: 00966 55 828 2010&lt;/p>&#xd;&#xa;&lt;p style=&quot;margin-left: 40.0px;&quot;>For Quality complaints:&lt;br>&#xd;&#xa;Email:&amp;nbsp;&lt;a href=&quot;mailto:SAPQ@abbvie.com&quot;>SAPQ@abbvie.com&lt;/a>&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>&amp;nbsp;&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <text_112664311
                                cq:styleIds="[1659545825678,,,]"
                                jcr:created="{Date}2024-01-17T09:47:55.962-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2026-03-11T11:26:52.198-04:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                langAttribute="none"
                                text="&lt;p style=&quot;text-align: right;&quot;>إذا كنت تبحث عن معلومات طبية تتعلق بمنتجات شركه أبفي ، فيرجى الاتصال بقسم المعلومات الطبية على&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>&lt;a href=&quot;mailto:medinfo_saudi@abbvie.com&quot;>medinfo_saudi@abbvie.com&lt;/a>&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>أو&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>أرسل استفسارك عبر&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>(للممارسين الصحيين فقط)&amp;nbsp;&lt;a href=&quot;http://www.abbviemedinfo.com/&quot;>www.abbviemedinfo.com&lt;/a>&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>إذا كنت ترغب في الإبلاغ عن أي آثار جانبية لمنتجات شركه أبفي أو شكاوى بشأن جودة المنتج ، مشكلات تتعلق بجودة أحد منتجات أبفي ، فيمكنك الاتصال بممثل السلامة / فريق الجودة التابع لشركة أبفي:&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>الإبلاغ عن الأعراض الجانبية على البريد الإلكتروني:&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>&lt;a href=&quot;mailto:PV.KSA@abbvie.com&quot;>PV.KSA@abbvie.com&lt;/a>&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>رقم الخط الساخن:&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>00966558282010&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>الشكاوي المتعلقة بالجودة على البريد الإلكتروني:&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>&amp;nbsp;&lt;a href=&quot;mailto:SAPQ@abbvie.com&quot;>SAPQ@abbvie.com&lt;/a>&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>موقع المكتب العلمي:&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>أبراج التعاونية – البرج الشمالي الدور السادس عشر&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>الصندوق البريدي: 9170 الرمز البريدي: 11423&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>المملكة العربية السعودية – الرياض&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>هاتف المكتب: 00966112994200&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>فاكس رقم: 00966112994288&lt;/p>&#xd;&#xa;&lt;p style=&quot;text-align: right;&quot;>&lt;b>&amp;nbsp;&lt;/b>&lt;/p>&#xd;&#xa;"
