                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;b>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>The AbbVie Foundation is a catalyst for change—accelerating innovation is essential to our impact.&lt;/span>&lt;/span>&lt;/b>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <separator
                                cq:styleIds="[1662756456518]"
                                jcr:created="{Date}2024-04-22T11:58:18.748-04:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2024-04-22T11:58:18.748-04:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                            <text2_copy
                                cq:styleIds="[1659545825678,1659545835858]"
                                jcr:lastModified="{Date}2024-07-29T11:28:46.827-04:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>We believe that transformative change begins in communities. By embracing bold thinking and working together with our partners to accelerate their new ideas and approaches, we have the greatest potential to drive systemic change and break through critical health inequities that have affected communities for generations.&lt;/p>&#xd;&#xa;&lt;p>We support and empower community-based organizations to develop and scale innovative solutions that disrupt the status quo and address complex issues facing their communities so that everyone can live their healthiest life.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </container3>
