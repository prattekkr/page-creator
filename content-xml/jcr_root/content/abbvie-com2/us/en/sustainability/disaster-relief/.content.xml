                            <text
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2025-01-17T09:30:08.433-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>Our commitment to creating a positive impact on the world is at the heart of everything we do. We aid communities across the globe affected by natural disasters and humanitarian crises by donating essential AbbVie medicines, equipping nonprofit partners with needed resources and providing financial support to impacted employees and their families.&lt;/span>&lt;/span>&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <separator
                                cq:styleIds="[1662756456518]"
                                jcr:created="{Date}2024-04-22T11:58:18.748-04:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2024-04-22T11:58:18.748-04:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                            <text2_copy
                                cq:styleIds="[1659545825678,1659545835858]"
                                jcr:lastModified="{Date}2025-01-17T09:30:25.601-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>The AbbVie Foundation also matches employee donations to select organizations supporting relief efforts in affected areas, empowering our employees to make a difference and advance a healthier world in times of critical need.&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
