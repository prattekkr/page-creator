                                jcr:primaryType="nt:unstructured"
                                jcr:title="I’m sponsored"
                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                type="h5"/>
                            <text
                                cq:styleIds="[1659545825678]"
                                jcr:created="{Date}2023-01-08T16:32:14.327-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2023-02-16T11:30:36.370-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p style=&quot;margin-left: 40px;&quot;>1. An email was sent to you with your login credentials.&lt;/p>&#xd;&#xa;&lt;p style=&quot;margin-left: 80px;&quot;>&lt;u>Example credentials:&lt;/u>&lt;br>&#xd;&#xa;Wi-Fi Name:&amp;nbsp;&lt;i>AbbVie-Guest&lt;/i>&lt;br>&#xd;&#xa;Wi-Fi Username:&lt;b>&amp;nbsp;pbak5&lt;/b>&lt;br>&#xd;&#xa;Wi-Fi Password:&amp;nbsp;&lt;b>2462&lt;/b>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;&lt;p style=&quot;margin-left: 40px;&quot;>2. On your device, go to&amp;nbsp;&lt;b>Wi-Fi settings&lt;/b>.&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p style=&quot;margin-left: 40px;&quot;>3. Select&amp;nbsp;&lt;i>&lt;b>AbbVie-Guest&lt;/b>.&lt;/i>&lt;/p>&#xd;&#xa;&lt;p style=&quot;margin-left: 40px;&quot;>4. On the&amp;nbsp;&lt;b>Guest Wi-Fi Login screen&lt;/b>, enter the&amp;nbsp;&lt;b>login credentials&lt;/b>&amp;nbsp;provided in the email.&lt;/p>&#xd;&#xa;&lt;p style=&quot;margin-left: 40px;&quot;>5. Read AbbVie’s Acceptable Use Policy and click&amp;nbsp;&lt;b>Accept&lt;/b>.&lt;/p>&#xd;&#xa;&lt;p style=&quot;margin-left: 40px;&quot;>6. Click Done to confirm you have access to&amp;nbsp;&lt;b>AbbVie’s Guest Wi-Fi.&lt;/b>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <separator
                                cq:styleIds="[1662756423318]"
                                jcr:created="{Date}2023-01-08T16:33:39.784-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2023-01-08T16:33:39.784-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                            <title_copy_copy
                                cq:styleIds="[1659545825678,1651545829678]"
                                jcr:created="{Date}2023-01-08T15:01:41.504-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2023-01-08T16:34:01.897-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                jcr:title="I’m not sponsored"
                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                type="h5"/>
                            <text_803076704
                                cq:styleIds="[1659545825678]"
                                jcr:created="{Date}2023-01-08T16:33:50.611-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2023-02-16T11:30:53.644-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>This means the AbbVie employee or third-party worker you are visiting has NOT preregistered you for guest Wi-Fi access.&lt;/p>&#xd;&#xa;&lt;p style=&quot;margin-left: 40px;&quot;>1. On your device, go to&amp;nbsp;&lt;b>Wi-Fi settings&lt;/b>.&lt;/p>&#xd;&#xa;&lt;p style=&quot;margin-left: 40px;&quot;>2. Select&amp;nbsp;&lt;i>&lt;b>AbbVie-Guest&lt;/b>.&lt;/i>&lt;/p>&#xd;&#xa;&lt;p style=&quot;margin-left: 40px;&quot;>3. On the Guest Wi-Fi Login screen, select&amp;nbsp;&lt;b>Register for Guest Access&lt;/b>.&lt;/p>&#xd;&#xa;&lt;p style=&quot;margin-left: 40px;&quot;>4. Complete the Registration form and click&amp;nbsp;&lt;b>Register.&lt;/b>&lt;/p>&#xd;&#xa;&lt;p style=&quot;margin-left: 40px;&quot;>&lt;b>5. An email&amp;nbsp;&lt;/b>will be sent to your sponsoring AbbVie employee or third-party worker, who must be onsite or on VPN to approve your access.&lt;/p>&#xd;&#xa;&lt;p style=&quot;margin-left: 40px;&quot;>6. Once your sponsor approves your request, you will receive a&amp;nbsp;&lt;b>confirmation email&lt;/b>&amp;nbsp;with your login credentials.&amp;nbsp;&lt;b>Follow the steps&lt;/b>&amp;nbsp;listed under I’m Sponsored to access AbbVie’s guest Wi-Fi.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </container>
                        <text_1950456619
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2023-01-08T16:39:07.485-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2023-01-08T16:39:39.303-05:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>&lt;b>Need assistance?&lt;/b> Contact your AbbVie sponsoring employee/third-party worker.&lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
                    </container_1402075392>
