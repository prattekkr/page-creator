                            sling:resourceType="abbvie-com2/components/accordion/v2/accordion"
                            heading="Frequently asked questions"
                            headingElement="h5"
                            singleExpansion="false">
                            <item_1671570554123
                                cq:panelTitle="How many devices can I connect to AbbVie-Guest Wi-Fi?"
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2023-01-08T16:37:45.968-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>You can connect up to three separate devices.&amp;nbsp;&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <item_1671570557396
                                cq:panelTitle="How do I know if I’m sponsored?"
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2023-01-08T16:37:51.748-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>If you were sponsored for guest Wi-Fi access ahead of your visit, you should have received an email with your login credentials. If the email didn’t appear in your inbox, it may be in your spam folder.&amp;nbsp;&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <item_1671570603045
                                cq:panelTitle="How long does it take to get guest Wi-Fi access?"
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2023-01-08T16:37:59.473-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Your access time depends on your sponsorship status.&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>If you’re already sponsored, you’ll have guest Wi-Fi access as soon as you enter your login credentials on&amp;nbsp;&lt;i>AbbVie-Guest&lt;/i>. These are found in your sponsorship email.&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>If you’re not sponsored, you’ll need to submit your request to the person you’re visiting. Once they’ve approved your request, you’ll automatically receive your sponsorship email and can log in.&amp;nbsp;&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <item_1671570607019
                                cq:panelTitle="What should I do if I can’t get online?"
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2023-01-08T16:38:07.074-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Contact the person you’re visiting at AbbVie and they will be able to help.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <item_1672933046685
                                cq:panelTitle="Will I have access to protected AbbVie information when I’m connected to AbbVie-Guest?"
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2023-01-08T16:38:13.079-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>No. You will be able to get online, and access websites and content approved by the company.&amp;nbsp;&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <item_1672933056191
                                cq:panelTitle="I am planning on going to another AbbVie building. Will I have AbbVie-Guest Wi-Fi access there, too?"
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2023-01-08T16:38:19.531-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>If you’re still within your approved Wi-Fi access timeframe, which is up to five days, then yes. Once your access expires, you will lose your connection.&amp;nbsp;&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </accordion_copy_copy_>
