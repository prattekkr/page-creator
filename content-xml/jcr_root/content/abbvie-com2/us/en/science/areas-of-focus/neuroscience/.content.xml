                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Brain disorders encompass a broad set of neurological and psychiatric conditions with potentially devastating effects. They can alter the way people think, feel and move, causing identities to slip away and connections – past, present and future – to be lost.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
