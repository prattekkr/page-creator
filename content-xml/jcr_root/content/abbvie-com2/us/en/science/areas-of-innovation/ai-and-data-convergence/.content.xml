                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-07T14:53:09.069-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-11-20T12:27:19.026-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Historically, it takes 10-15 years to bring a medicine from discovery through clinical development – but by unleashing artificial intelligence (AI) and machine learning (ML) throughout our research and development (R&amp;amp;D) process, we could soon deliver life-changing therapies in half the time. &lt;/p>&#xd;&#xa;&lt;p>From early experimental work to understand disease pathways, to in-house discovery of new assets, to advancing late-stage programs, our cutting-edge technologies are helping get transformative medicines to patients sooner. &lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
