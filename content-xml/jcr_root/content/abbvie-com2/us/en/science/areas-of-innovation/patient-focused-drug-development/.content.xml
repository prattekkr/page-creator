                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Going beyond &quot;good enough&quot; to make a difference"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-07T14:53:09.069-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-31T15:10:11.418-05:00"
                                    jcr:lastModifiedBy="mihalsk"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>At the heart of AbbVie's unrelenting drive for innovation are the patients we serve. That's why our investment in R&amp;amp;D is so critical. Our teams of scientists use novel approaches to help deliver therapies and solutions for conditions with the greatest unmet need.&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;Through patient-focused drug development, we empower patient voices to be heard and help guide our decision-making process to advance cutting-edge science.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container_568753235>
                            <container_568753235_
                                cq:styleIds="[1653545847150,1653242825678,1653545835879,1653545835982,1653545825687]"
                                jcr:created="{Date}2022-12-16T18:05:55.966-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2022-12-16T18:05:55.966-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <header
                                    jcr:created="{Date}2022-12-17T13:22:07.773-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-17T13:22:15.549-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/header/v2/header"
                                    eyebrow="KEY AREAS OF FOCUS"/>
                                <title_116699496
                                    cq:styleIds="[1659545825678,1661545829678,1651545825692]"
                                    jcr:created="{Date}2022-12-15T11:49:26.700-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-09-05T12:07:35.499-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="How we innovate for patients:"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <separator_485085862
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-12-17T13:23:00.431-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-17T13:23:00.431-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title
                                    cq:styleIds="[1659545825678,1651545825693]"
                                    jcr:created="{Date}2022-12-17T13:22:39.555-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-09-05T12:07:44.982-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Partnering to advance drug development  "
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h3"
                                    variant="h"/>
                                <text_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-07T14:53:09.069-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-17T13:23:45.146-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>We partner with patients, patient organizations, caregivers and clinicians to ensure that individual experiences, perspectives, needs and priorities are part of the clinical development process. For example, our approach to Patient-Centered Outcomes Research (PCOR) is grounded in collaborations with key stakeholders to understand patients' lived experiences, allowing us to develop strategies and solutions to help patients thrive.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_141616301
                                    cq:styleIds="[1662756486159]"
                                    jcr:created="{Date}2022-12-17T12:18:10.519-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-17T12:18:10.519-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy
                                    cq:styleIds="[1659545825678,1651545825693]"
                                    jcr:created="{Date}2022-12-17T13:22:39.555-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-09-05T12:08:19.422-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Diversifying our clinical trials "
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h3"
                                    variant="h"/>
                                <text_copy_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-07T14:53:09.069-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2025-08-19T16:28:08.830-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>We believe clinical trials should reflect the populations we serve. Led by our dedicated Patient Inclusion team, we work to design inclusive study protocols, enable underrepresented populations to volunteer and continuously evaluate our clinical trial eligibility criteria against real-world datasets — so that all patients can have their voices heard.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_2096421555
                                    cq:styleIds="[1662756486159]"
                                    jcr:created="{Date}2022-12-17T12:18:10.519-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-17T12:18:10.519-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy
                                    cq:styleIds="[1659545825678,1651545825693]"
                                    jcr:created="{Date}2022-12-17T13:22:39.555-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-09-05T12:08:03.516-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Embedding the patient experience "
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h3"
                                    variant="h"/>
                                <text_copy_copy_copy_
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-07T14:53:09.069-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-17T13:31:39.769-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>We work to better understand the experience of people living with a disease or condition, integrating their perspectives throughout our clinical development process to meet their specialized health needs. We develop robust patient journey maps to understand the transactional and emotional journey people experience from diagnosis through treatment and beyond.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy
                                    cq:styleIds="[1662756486159]"
                                    jcr:created="{Date}2022-12-17T12:18:10.519-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-17T12:18:10.519-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy
                                    cq:styleIds="[1659545825678,1651545825693]"
                                    jcr:created="{Date}2022-12-17T13:22:39.555-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-09-05T12:08:14.589-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Advancing digital health technologies "
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h3"
                                    variant="h"/>
                                <text_copy_copy_copy__403879328
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-07T14:53:09.069-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-17T13:32:00.266-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>From wearables to gaming platforms that measure disease symptoms and treatment outcomes, we're deploying digital health technology (DHT) tools that enable unprecedented data gathering and insights that inform our drug development process.&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;For diseases that are challenging to develop new therapies, our new tools help enable the development of objective and sensitive digital biomarkers — which aim to improve our ability to identify treatment responders faster and make clinical assessments more precise.&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;We also measure some outcomes in the real-world setting through connected sensor technology alongside COAs to provide a holistic understanding of patient experience. For example, we measure improvements in physical activity, sleep, and joint range of motion upon treatment in rheumatic conditions. In dermatological indications, images can be captured and assessed in real-time, enabling evidence-based treatment discussions based on disease activity.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator
                                    cq:styleIds="[1662756486159]"
                                    jcr:created="{Date}2022-12-17T12:18:10.519-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-17T12:18:10.519-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy_497179
                                    cq:styleIds="[1659545825678,1651545825693]"
                                    jcr:created="{Date}2022-12-17T13:22:39.555-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-09-05T12:08:36.027-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Unlocking the potential of Real-World Evidence (RWE)"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h3"
                                    variant="h"/>
                                <text_copy_copy_copy__1354420930
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-07T14:53:09.069-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-17T13:32:22.128-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>RWE is clinical data derived from real patients during their real lives, which has the potential to provide a more comprehensive understanding of how a new therapeutic option will work by complementing the findings of traditional randomized clinical trials.&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;RWE helps us understand disease burden, treatment patterns, patient behaviors and unmet needs, and treatment performance — particularly populations with disparities in care and outcomes — that cannot be studied through traditional clinical trials.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container_568753235_>
