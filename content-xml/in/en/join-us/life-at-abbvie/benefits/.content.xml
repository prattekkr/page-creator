                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                            <text_230942827
                                cq:styleIds="[1659545825678]"
                                jcr:created="{Date}2022-12-10T17:10:30.657-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2022-12-10T18:04:21.467-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Our compensation, benefits, and well-being programs support your diverse and evolving needs at every stage of your career and life. We offer differentiated and competitive rewards and benefits. Some programs vary by country.&amp;nbsp;&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
