                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>Support at every stage in your career and life.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
