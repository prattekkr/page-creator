                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/accordion/v2/accordion"
                                    headingElement="h5"
                                    singleExpansion="false">
                                    <item_1670713218905
                                        cq:panelTitle="Compensation"
                                        cq:styleIds="[1659545825678]"
                                        jcr:lastModified="{Date}2022-12-10T18:06:28.723-05:00"
                                        jcr:lastModifiedBy="chiucx"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/text/v2/text"
                                        text="&lt;ul>&#xd;&#xa;&lt;li>Competitive base pay&lt;/li>&#xd;&#xa;&lt;li>Short- and long-term incentives&lt;/li>&#xd;&#xa;&lt;li>Recognition programs&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                        textIsRich="true"/>
                                    <item_1670713221584
                                        cq:panelTitle="Benefits"
                                        cq:styleIds="[1659545825678]"
                                        jcr:lastModified="{Date}2022-12-22T11:37:23.470-05:00"
                                        jcr:lastModifiedBy="chiucx"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/text/v2/text"
                                        text="&lt;ul>&#xd;&#xa;&lt;li>Comprehensive medical, dental, vision, mental health and prescription drug coverage &lt;/li>&#xd;&#xa;&lt;li>Sick pay and medical leave&lt;/li>&#xd;&#xa;&lt;li>Life and disability insurance&lt;/li>&#xd;&#xa;&lt;li>Flexible spending accounts to help pay for health expenses using pre-tax dollars*&lt;/li>&#xd;&#xa;&lt;li>Retirement Savings Plan*&lt;/li>&#xd;&#xa;&lt;li>Employee Stock Purchase Plan, available in most countries outside the U.S.&lt;/li>&#xd;&#xa;&lt;li>Housing and transport allowances, available outside the U.S.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>* Available in the U.S.&lt;/p>&#xd;&#xa;"
                                        textIsRich="true"/>
                                    <item_1670713228568
                                        cq:panelTitle="Flexible work and time off"
                                        cq:styleIds="[1659545825678]"
                                        jcr:lastModified="{Date}2023-02-02T15:14:29.386-05:00"
                                        jcr:lastModifiedBy="kokajx"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/text/v2/text"
                                        text="&lt;ul>&#xd;&#xa;&lt;li>Workplace flexibility that varies based on role, such as flex time, part-time work, job sharing, shift changes, compressed work weeks and remote work&lt;/li>&#xd;&#xa;&lt;li>Hybrid work model for office-based employees that typically consists of 3 days in office and 2 days of remote work&lt;/li>&#xd;&#xa;&lt;li>A phased retirement program*&lt;/li>&#xd;&#xa;&lt;li>Paid vacation and company holidays&lt;/li>&#xd;&#xa;&lt;li>Two paid days off to volunteer, along with a company-wide volunteer week&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>*Available in the U.S.&lt;/p>&#xd;&#xa;"
                                        textIsRich="true"/>
                                    <item_1670713232031
                                        cq:panelTitle="Support for families"
                                        cq:styleIds="[1659545825678]"
                                        jcr:lastModified="{Date}2023-02-02T15:16:27.636-05:00"
                                        jcr:lastModifiedBy="kokajx"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/text/v2/text"
                                        text="&lt;ul>&#xd;&#xa;&lt;li>Paid leave for new parents welcoming a child through birth, adoption, surrogacy or fostering&lt;/li>&#xd;&#xa;&lt;li>Paid leave and support for people caring for sick family members&amp;nbsp;&lt;/li>&#xd;&#xa;&lt;li>Support for family planning, including adoption and surrogacy assistance*&lt;/li>&#xd;&#xa;&lt;li>Discounts at U.S childcare centers, plus access to an on-site daycare center at our headquarters in Lake County, IL*&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>*Available in the U.S.&lt;/p>&#xd;&#xa;"
                                        textIsRich="true"/>
                                    <item_1670713236887
                                        cq:panelTitle="Holistic well-being"
                                        cq:styleIds="[1659545825678]"
                                        jcr:lastModified="{Date}2022-12-22T11:38:07.636-05:00"
                                        jcr:lastModifiedBy="chiucx"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/text/v2/text"
                                        text="&lt;p>We partner with employees on their well-being journey, connecting them to tools, and support to help them be their best selves, at work and at home. Because when you're at your best, you can make the most impact.&lt;/p>&#xd;&#xa;&lt;p>&lt;a href=&quot;/content/abbvie-com2/in/en/join-us/life-at-abbvie/well-being-in-the-workplace.html&quot;>Explore more&lt;/a>&lt;/p>&#xd;&#xa;"
                                        textIsRich="true"/>
                                    <item_1670713240836
                                        cq:panelTitle="Learning &amp; development"
                                        jcr:lastModified="{Date}2022-12-22T11:39:14.793-05:00"
                                        jcr:lastModifiedBy="chiucx"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/text/v2/text"
                                        text="&lt;p>We're at our best when we push ourselves to grow, try new skills and have the courage to take risks. Our commitment to learning and development provides resources that empower employees to step up and reach higher.&lt;/p>&#xd;&#xa;&lt;p>&lt;a href=&quot;/content/abbvie-com2/in/en/join-us/life-at-abbvie/learning-and-development.html&quot;>Explore more&lt;/a>&lt;/p>&#xd;&#xa;"
                                        textIsRich="true"/>
                                </accordion>
