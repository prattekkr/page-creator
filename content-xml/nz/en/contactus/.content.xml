                                jcr:lastModified="{Date}2025-12-15T09:20:15.605-05:00"
                                jcr:lastModifiedBy="singarx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;body-unica-26-reg&quot;>&lt;b>AbbVie Limited&amp;nbsp;&lt;br>&#xd;&#xa;&lt;/b>&lt;/span>&lt;br>&#xd;&#xa;&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-20-reg&quot;>L6, 156-158 Victoria Street&lt;br>&#xd;&#xa; Wellington&lt;br>&#xd;&#xa; PO Box 11437, Manners Street&lt;br>&#xd;&#xa; Wellington&lt;br>&#xd;&#xa; Telephone: 0800 900 030&lt;br>&#xd;&#xa; Fax:&amp;nbsp;+64 9 353 1680&lt;br>&#xd;&#xa; &lt;br>&#xd;&#xa; If you are experiencing a&lt;b>&amp;nbsp;medical emergency&lt;/b>, please call 111. If you require&amp;nbsp;&lt;b>medical advice,&lt;/b> please contact your doctor or other healthcare professional.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <separator_copy
                                jcr:created="{Date}2025-12-15T09:03:43.989-05:00"
                                jcr:createdBy="singarx"
                                jcr:lastModified="{Date}2025-12-15T09:03:43.989-05:00"
                                jcr:lastModifiedBy="singarx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                            <accordion_copy
                                cq:styleIds="[1]"
                                jcr:created="{Date}2025-12-15T09:39:34.234-05:00"
                                jcr:createdBy="singarx"
                                jcr:lastModified="{Date}2025-12-15T09:42:26.361-05:00"
                                jcr:lastModifiedBy="singarx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/accordion/v2/accordion"
                                singleExpansion="false">
                                <item_1765809610130
                                    cq:panelTitle="Patients &amp; Carers"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2025-12-23T11:49:24.617-05:00"
                                    jcr:lastModifiedBy="singarx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Putting patients first.&lt;br>&#xd;&#xa;We’re providing broader support to help ensure patients have the information and support they need.&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>&lt;b>Consumer Medicine Information (CMI)&lt;/b>&amp;nbsp;provides important information about your medicine. Access the&amp;nbsp;&lt;a href=&quot;/content/abbvie-com2/nz/en/patients/products.html&quot;>New Zealand Consumer Medicine Information (CMI) for AbbVie products&lt;/a>&lt;/li>&#xd;&#xa;&lt;li>For&amp;nbsp;&lt;b>enquiries&lt;/b>&amp;nbsp;regarding an AbbVie product, please contact our Medical Information team at&amp;nbsp;&lt;a href=&quot;mailto:medinfoanz@abbvie.com&quot;>medinfoanz@abbvie.com&lt;/a>&amp;nbsp;or call&amp;nbsp;0800 900 030&lt;/li>&#xd;&#xa;&lt;li>For medical advice, please consult your healthcare professional.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1765809612690
                                    cq:panelTitle="Healthcare Professionals"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2026-01-06T02:10:55.039-05:00"
                                    jcr:lastModifiedBy="singarx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Unwavering in our commitment to bring the best science to patients worldwide.&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>For&amp;nbsp;all HCP enquiries&amp;nbsp;including finding your AbbVie representative, please call&lt;br>&#xd;&#xa;0800 900 030&amp;nbsp;or email&amp;nbsp;&lt;a href=&quot;mailto:supportanz@abbvie.com&quot;>supportanz@abbvie.com&lt;/a>&lt;/li>&#xd;&#xa;&lt;li>Access the&amp;nbsp;&lt;a href=&quot;/content/abbvie-com2/nz/en/patients/products.html&quot;>New Zealand Data Sheet for AbbVie products&lt;/a>&lt;/li>&#xd;&#xa;&lt;li>Access a dedicated&amp;nbsp;Healthcare Professional portal,&amp;nbsp;&lt;a href=&quot;https://www.abbviepro.com/nz/en.html&quot;>AbbVie Pro&lt;/a>&amp;nbsp;providing streamlined access to AbbVie product &amp;amp; patient resources, medical education based on expert insights, congress coverage and research publications.&lt;/li>&#xd;&#xa;&lt;li>Clinical trials -&amp;nbsp;&lt;a href=&quot;https://www.abbvie.co.nz/our-science/clinical-trials.html&quot;>explore how we turn our research into reality&lt;/a>&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1765809615496
                                    cq:panelTitle="Wholesalers &amp; Direct Accounts"
                                    jcr:lastModified="{Date}2025-12-15T09:45:42.047-05:00"
                                    jcr:lastModifiedBy="singarx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Creating partnerships that make a difference.&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>For enquiries regarding&amp;nbsp;orders and supply&amp;nbsp;please contact our distribution and warehousing partner Healthcare Logistics&amp;nbsp;&lt;a href=&quot;mailto:orders@healthcarelogistics.co.nz&quot;>orders@healthcarelogistics.co.nz&lt;/a>&amp;nbsp;or call&lt;br>&#xd;&#xa;0800 222 843&lt;/li>&#xd;&#xa;&lt;li>For questions concerning&amp;nbsp;invoice status or payment, please email&amp;nbsp;Accounts Receivable&amp;nbsp;at&amp;nbsp;&lt;a href=&quot;mailto:receivable.go-accounts@abbvie.com&quot;>Receivable.GO-Accounts@abbvie.com&lt;/a>&lt;/li>&#xd;&#xa;&lt;li>For&amp;nbsp;Allergan Aesthetics&amp;nbsp;please call 0800 659 912, email&amp;nbsp;&lt;a href=&quot;mailto:NZenquiries@allergan.com&quot;>NZenquiries@allergan.com&lt;/a>&amp;nbsp;or go to&amp;nbsp;&lt;a href=&quot;http://www.allergan.co.nz/&quot;>http://allerganaesthetics.co.nz&lt;/a>&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1765809618591
                                    cq:panelTitle="Report an adverse event or product complaint"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2026-01-19T05:39:50.757-05:00"
                                    jcr:lastModifiedBy="nandivx5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;ul>&#xd;&#xa;&lt;li>If you are experiencing a&amp;nbsp;medical emergency,&amp;nbsp;please call 111. If you require&amp;nbsp;medical advice, please contact your doctor or other healthcare professional.&lt;/li>&#xd;&#xa;&lt;li>To report an&amp;nbsp;Adverse Event&amp;nbsp;in relation to the use of an AbbVie product please email&amp;nbsp;&lt;a href=&quot;mailto:anzpv@abbvie.com&quot;>anzpv@abbvie.com&lt;/a>&lt;/li>&#xd;&#xa;&lt;li>To report a&amp;nbsp;Product Complaint&amp;nbsp;in relation to the use of an AbbVie product please email&amp;nbsp;&lt;a href=&quot;mailto:productcomplaints-anz@abbvie.com&quot;>productcomplaints-anz@abbvie.com&lt;/a>&lt;/li>&#xd;&#xa;&lt;li>For&amp;nbsp;safety information&amp;nbsp;please refer to the relevant product’s&amp;nbsp;&lt;a href=&quot;/content/abbvie-com2/nz/en/patients/products.html&quot;>Consumer Medicine Information&amp;nbsp;&lt;/a>for patients and&amp;nbsp;&lt;a href=&quot;https://www.abbvie.co.nz/our-science/products.html&quot;>Product Information&lt;/a>&amp;nbsp;for healthcare professionals.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1765809621502
                                    cq:panelTitle="Careers"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2025-12-15T09:46:38.777-05:00"
                                    jcr:lastModifiedBy="singarx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>AbbVie employees work every day to help discover solutions to address many of the world's most pressing health challenges.&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Visit&amp;nbsp;&lt;a href=&quot;https://www.abbvie.co.nz/careers.html&quot;>Explore Careers&lt;/a>&amp;nbsp;to search for current opportunities.&lt;/li>&#xd;&#xa;&lt;li>For career related enquiries email&amp;nbsp;&lt;a href=&quot;mailto:careersanz@abbvie.com&quot;>careersanz@abbvie.com&lt;/a>&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1765809626000
                                    cq:panelTitle="Media"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2025-12-23T11:54:15.767-05:00"
                                    jcr:lastModifiedBy="singarx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;ul>&#xd;&#xa;&lt;li>For media-related enquiries, please contact Corporate Communications Australia an&lt;br>&#xd;&#xa;New Zealand at&amp;nbsp;&lt;a href=&quot;mailto:media_ANZ@abbvie.com&quot;>media_ANZ@abbvie.com&lt;/a>&amp;nbsp;or go to the&amp;nbsp;&lt;a href=&quot;/content/abbvie-com2/nz/en/media.html&quot;>AbbVie Media page&lt;/a>&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </accordion_copy>
