                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>AbbVie collaborates and co-creates with the groups working with and representing patients. The grants we provide patient groups to support their ongoing work can be found here.&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>&lt;a href=&quot;/content/dam/abbvie-com2/nz/documents/abbVie-limited-patient-organisation-report-2023-v1.xlsx&quot;>Reporting Period 1 January 2023 to 31 December 2023 can be viewed by clicking here.&lt;/a>&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>&lt;a href=&quot;/content/dam/abbvie-com2/nz/documents/abbVie-limited-patient-organisation-report-2024-v1.xlsx&quot;>Reporting Period 1 January 2024 to 31 December 2024 can be viewed by clicking here.&lt;/a>&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
