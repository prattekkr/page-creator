                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                        <text_197531824
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2025-12-22T10:55:39.812-05:00"
                            jcr:createdBy="singarx"
                            jcr:lastModified="{Date}2026-01-19T01:50:12.879-05:00"
                            jcr:lastModifiedBy="nandivx5"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>AbbVie supports disclosure and transparency on interactions between the healthcare industry and healthcare professionals to ensure public trust and confidence.&lt;/p>&#xd;&#xa;&lt;p>In alignment with the member companies of Medicines New Zealand, AbbVie has undertaken to be open and transparent when we provide a reportable payment to a healthcare professional or a third party as directed by a healthcare professional. Reportable payments or transfers of value are:&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Payments for the provision of services such as giving a lecture, chairing an educational meeting, providing advice as a member of an Advisory Board or as a Consultant&lt;/li>&#xd;&#xa;&lt;li>Sponsorship to attend a medical education meeting&lt;/li>&#xd;&#xa;&lt;li>Expenses associated with the provision of services or sponsorship such as airfares, accommodation and/or conference registration fees.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>AbbVie has prepared the report for publication in accordance with the Medicines New Zealand Guidelines for Disclosure of Transfers of Value from Pharmaceutical Companies to Healthcare Professionals and New Zealand’s Privacy legislation. The report identifies healthcare professionals by name where their consent has been provided.&lt;br>&#xd;&#xa;The report is provided as a downloadable Excel file.&lt;/p>&#xd;&#xa;&lt;p>To comply with our privacy obligations, the report may be amended from time to time. The report here contains the most up to date information. Any use or disclosure of the data by a third party is the responsibility of that third party, who must comply with the New Zealand Privacy Act 2020.&lt;/p>&#xd;&#xa;&lt;p>For further information about the details in the report, please&amp;nbsp;&lt;a href=&quot;https://www.medicinesnz.co.nz/our-industry/transparency-guidelines&quot;>click here&lt;/a>.&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;This report will be available for at least three years from the date of publication.&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Reporting Period 1 January 2022 to 31 December 2022&lt;ul>&#xd;&#xa;&lt;li>&amp;nbsp;&lt;a href=&quot;/content/dam/abbvie-com2/nz/documents/2022-abbVie-newzealand-report-final.xlsx&quot;>Click here to download an Excel file of the report&lt;/a>.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>Reporting Period 1 January 2023 to 31 December 2023&lt;ul>&#xd;&#xa;&lt;li>&amp;nbsp;&lt;a href=&quot;/content/dam/abbvie-com2/nz/documents/2023-abbVie-newzealand-report-final.xlsx&quot;>Click here to download an Excel file of the report.&lt;/a>&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>Reporting Period 1 January 2024 to 31 December 2024&lt;ul>&#xd;&#xa;&lt;li>&lt;a href=&quot;/content/dam/abbvie-com2/nz/documents/2024-abbVie-newzealand-report-final.xlsx&quot;>Click here to download an Excel file of the report&lt;/a>.&amp;nbsp;&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                            textIsRich="true"/>
