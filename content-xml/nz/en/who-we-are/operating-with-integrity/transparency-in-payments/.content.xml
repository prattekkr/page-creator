                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>AbbVie supports the enhancement of medical knowledge and the quality use of medicines through sponsoring independently organised educational events. These events are primarily offered by societies, colleges, universities or other recognised healthcare professional organisations.&lt;/p>&#xd;&#xa;&lt;p>AbbVie’s sponsorships paid to organisations in support of independently organised educational events can be found here.&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>&lt;a>R&lt;/a>&lt;a href=&quot;/content/dam/abbvie-com2/nz/documents/abbVie-limited-third-party-event-report-v1.xlsx&quot;>eporting Period 1 January 2023 to 31 December 2023 can be viewed by clicking here.&lt;/a>&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>&lt;a href=&quot;/content/dam/abbvie-com2/nz/documents/abbVie-limited-thirdparty-event-report-v1.xlsx&quot;>Reporting Period 1 January 2024 to 31 December 2024 can be viewed by clicking here.&lt;/a>&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                            textIsRich="true"/>
