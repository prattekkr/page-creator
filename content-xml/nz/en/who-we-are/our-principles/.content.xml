                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="abbvie-com2/components/accordion/v2/accordion"
                        heading="Our principles"
                        headingElement="h5"
                        id="accordion"
                        singleExpansion="false">
                        <item_1671570554123
                            cq:panelTitle="Transforming lives"
                            cq:styleIds="[1659545825678]"
                            jcr:lastModified="{Date}2025-10-28T00:06:10.897-04:00"
                            jcr:lastModifiedBy="nandivx5"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>We inspire hope and transform lives every day. We make decisions based on our deep caring and compassion for people, delivering a lasting impact to our patients, their families, our employees and the community. &lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
                        <item_1671570557396
                            cq:panelTitle="Acting with integrity"
                            cq:styleIds="[1659545825678]"
                            jcr:lastModified="{Date}2025-10-28T00:06:38.292-04:00"
                            jcr:lastModifiedBy="nandivx5"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>We strive to always do the right thing. With uncompromising integrity at the heart of everything we do, we pursue the highest standards in quality, compliance, safety and performance.&lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
                        <item_1671570603045
                            cq:panelTitle="Driving innovation"
                            cq:styleIds="[1659545825678]"
                            jcr:lastModified="{Date}2025-10-28T00:07:05.279-04:00"
                            jcr:lastModifiedBy="nandivx5"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>We innovate relentlessly in everything we do to tackle unmet needs. We invest in the discovery and development of new medicines and healthcare approaches for a healthier world.&lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
                        <item_1671570607019
                            cq:panelTitle="Embracing diversity &amp; inclusion"
                            cq:styleIds="[1659545825678]"
                            jcr:lastModified="{Date}2025-10-28T00:07:50.634-04:00"
                            jcr:lastModifiedBy="nandivx5"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>We treat everyone equally, with dignity and respect. Around the world, our employees embrace diverse backgrounds and perspectives which allows us all to achieve our best.&lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
                        <item_1671570609829
                            cq:panelTitle="Serving the community"
                            cq:styleIds="[1659545825678]"
                            jcr:lastModified="{Date}2025-10-28T00:08:16.324-04:00"
                            jcr:lastModifiedBy="nandivx5"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>We are proud to serve and support the community and do our part to protect the environment. We make a remarkable impact that's felt within healthcare and beyond.&lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
                    </accordion>
