                            sling:resourceType="wcm/foundation/components/parsys">
                            <accordion
                                cq:styleIds="[2]"
                                jcr:created="{Date}2022-12-10T16:02:03.886-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2023-01-17T18:02:53.118-05:00"
                                jcr:lastModifiedBy="millicx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/accordion/v2/accordion"
                                heading="the ways we work"
                                headingElement="h5"
                                singleExpansion="false">
                                <item_1670707208042
                                    cq:panelTitle="All For One AbbVie"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2022-12-23T10:36:39.334-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>We weigh all our decisions against the common good for the enterprise. We inspire, share and create as an inclusive team. We solve problems for all rather than serving our immediate team.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1670707211154
                                    cq:panelTitle="Decide, Smart &amp; Sure"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2022-12-23T10:36:52.473-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>We make intelligent decisions, adapting to create the best outcomes. While never compromising patient health or safety, we act quickly, embrace experimentation, accept what doesn’t work and get on to what does.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1670707214308
                                    cq:panelTitle="Agile &amp; Accountable"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2022-12-23T10:37:02.952-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>We seek to streamline and eliminate unnecessary obstacles. We plan ahead and adapt as we go. We delegate and make tough decisions to ensure focus on priorities and results, staying keenly aware of the urgency in all we do.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1670707217700
                                    cq:panelTitle="Clear &amp; Courageous"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2022-12-23T10:37:10.537-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Open, honest and candid dialogue is core to our work and how we act with others. We share information freely and continuously because insights and solutions can come from anywhere and ultimately serve us all. We admit mistakes. Even in disagreement, we grow stronger by putting the courage of our convictions to the test.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1670707220579
                                    cq:panelTitle="Make Possibilities Real"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2022-12-23T10:37:24.434-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>We question relentlessly with endless curiosity. We’re never satisfied with “good enough”—patients depend on us to continually deliver more. We challenge ourselves to find creative, constructive solutions to turn possibilities into reality.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </accordion>
                        </par_13>
