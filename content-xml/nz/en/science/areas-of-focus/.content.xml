                                jcr:lastModifiedBy="nandivx5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Our innovative portfolio and pipeline of new discoveries seek to maintain vision and prevent blindness. We are focused on improving the standards of care across multiple disease areas from the front to the back of the eye, from glaucoma to chronic retinal diseases.&amp;nbsp;&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </par_21>
