                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>We're building on our deep expertise and legacy in immunology research to explore new disease areas, create a more patient-centric discovery and development process and offer solutions for more diverse patient populations.&amp;nbsp;&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </par_11>
                        <par_12
                            jcr:primaryType="nt:unstructured"
