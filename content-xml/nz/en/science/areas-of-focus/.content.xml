                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>We create products and technologies that advance aesthetic medicine. Our aesthetics R&amp;amp;D team seeks to discover and accelerate comprehensive, evidence-based solutions focused on novel indications, improved delivery technologies and enhanced patient outcomes.&amp;nbsp;&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </par_22>
