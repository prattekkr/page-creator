                                jcr:primaryType="nt:unstructured"
                                jcr:title="Additional request types"
                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                type="h2"
                                variant="h"/>
                            <text_1593518832
                                cq:styleIds="[1659545825678]"
                                jcr:created="{Date}2022-12-31T17:04:45.627-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2023-01-27T16:08:35.135-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Other request types include fellowships.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <accordion_copy_copy__365365898
                                cq:styleIds="[2,8]"
                                jcr:created="{Date}2022-12-31T17:09:45.105-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2023-01-27T16:08:17.165-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/accordion/v2/accordion"
                                headingElement="h6"
                                singleExpansion="false">
                                <item_1672525109265
                                    cq:panelTitle="Fellowships"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2026-02-10T16:07:11.543-05:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Fellowships are financial assistance provided to a university, medical school or nonprofit organization for fellowship programs to support educational or research activities of healthcare providers in training. AbbVie may not participate in the selection of the recipient.&lt;/p>&#xd;&#xa;&lt;p>AbbVie is committed to advancing medical knowledge and improving patient care through independent, high-quality education and training. As part of this commitment, the company provides funding to support medical fellowship programs that foster the development of future leaders in medicine and science. These fellowships are intended to enhance clinical expertise, research capability, and scientific understanding in therapeutic areas of unmet need, consistent with the company’s mission to improve health outcomes.&lt;/p>&#xd;&#xa;&lt;p>Each year we post a Call for Fellowship Grants in November for fellowships beginning in July of the following year. Submissions for the 2026-2027 fellowships are currently being accepted through March 20, 2026. Fellows begin the program during the 2026 calendar year for a one-year fellowship.&lt;/p>&#xd;&#xa;&lt;p>&lt;b>Examples&lt;/b>&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Funds to a university or 501(c)(3) to support the ongoing education of a fellow or resident&lt;/li>&#xd;&#xa;&lt;li>May support a large fellowship program or an individual fellow&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>&lt;b>Allowed&lt;/b>&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Support of educational or research activities&lt;/li>&#xd;&#xa;&lt;li>Reasonable stipend/salary&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>&lt;b>Not allowed&lt;/b>&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Expenses for tools and equipment&lt;/li>&#xd;&#xa;&lt;li>Funds for the purpose of purchasing educational items with an independent value (e.g. laptop, smart phone, tablet)&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </accordion_copy_copy__365365898>
                        </par_13>
