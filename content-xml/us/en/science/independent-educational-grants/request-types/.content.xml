                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                jcr:title="Independent Medical Education"
                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                type="h2"
                                variant="h"/>
                            <text
                                cq:styleIds="[1659545825678]"
                                jcr:created="{Date}2022-12-31T16:11:35.983-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2024-03-19T10:50:05.301-04:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Independent Medical Education is funding to an independent third party to support the development or implementation of clearly defined medical or education programs or activities for health care providers that foster increased understanding/knowledge of scientific, clinical or health care issues that contribute to the enhancement of patient care.&lt;/p>&#xd;&#xa;&lt;p>&lt;b>AbbVie has selected providers to be part of the AbbVie Independent Medical Education (IME) Provider Network.&amp;nbsp;&lt;/b>AbbVie will only consider grant requests submitted by providers who are part of the AbbVie IME Provider Network. Submissions from providers who are&amp;nbsp;&lt;i>&lt;b>not&lt;/b>&lt;/i>&amp;nbsp;part of the AbbVie IME Provider Network will no longer be considered for support.&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>&lt;b>Please note:&lt;/b>&amp;nbsp; The AbbVie IME Provider Network does not apply to Independent Patient Education, Fellowships, or Call for Grants.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                textIsRich="true"/>
                            <accordion
                                cq:styleIds="[2,8]"
                                jcr:created="{Date}2022-12-31T17:09:45.105-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2024-06-18T11:57:48.970-04:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/accordion/v2/accordion"
                                headingElement="h6"
                                singleExpansion="false">
                                <item_1672524596713
                                    cq:panelTitle="Examples"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2022-12-31T17:36:57.911-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>May include live presentations (e.g., symposia, regional/local programs, teleconferences, live webcasts) or enduring materials (e.g., printed materials, programmed tests, podcasts, slide kits, monographs, and web-based instructional materials).&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;b>Allowed&lt;/b>&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Expenses for executing medical education programs (e.g., disease presentations, symposia’s, websites)&lt;/li>&#xd;&#xa;&lt;li>Expenses for the development of medical education items (e.g., agendas, program content and development, accreditation fees)&lt;/li>&#xd;&#xa;&lt;li>Equipment rental (e.g. chairs, tables, AV, etc.)&lt;/li>&#xd;&#xa;&lt;li>Modest food buffet allowed&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>&lt;b>Not allowed&lt;/b>&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Registration, travel costs, lodging or any other expenses for non-faculty attendees&lt;/li>&#xd;&#xa;&lt;li>Entertainment and recreation expenses&lt;/li>&#xd;&#xa;&lt;li>Parking for attendees&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </accordion>
                            <separator_785741117
                                cq:styleIds="[1662756486159]"
                                jcr:created="{Date}2022-12-31T17:00:27.321-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2022-12-31T17:00:27.321-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                            <title_copy
                                cq:styleIds="[1659545825678,1651545825692]"
                                jcr:created="{Date}2022-12-31T16:05:26.673-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2024-09-05T16:17:30.264-04:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                jcr:title="Independent Patient Education"
                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                type="h2"
                                variant="h"/>
                            <text_copy
                                cq:styleIds="[1659545825678]"
                                jcr:created="{Date}2022-12-31T16:11:35.983-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2022-12-31T17:13:37.209-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Patient Education is programs designed primarily to advance disease state or treatment education to the patients/consumers and/or care partners.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <accordion_copy
                                cq:styleIds="[2,8]"
                                jcr:created="{Date}2022-12-31T17:09:45.105-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2022-12-31T17:24:05.614-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/accordion/v2/accordion"
                                headingElement="h6"
                                singleExpansion="false">
                                <item_1672524596713
                                    cq:panelTitle="Examples"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2022-12-31T17:36:30.521-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Patient support groups&lt;/li>&#xd;&#xa;&lt;li>Live patient education&lt;/li>&#xd;&#xa;&lt;li>Development, production and distribution of an enduring patient education piece&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>Disease state awareness programs&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>&lt;b>Allowed&lt;/b>&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Expenses for executing patient programs (e.g., disease presentations, symposia, websites)&lt;/li>&#xd;&#xa;&lt;li>Expenses for the development of patient education items (e.g., brochures, patient diaries)&lt;/li>&#xd;&#xa;&lt;li>Written materials that inform patients about adherence to medication regimes, health lifestyle choices&lt;/li>&#xd;&#xa;&lt;li>Patient self-assessment and tracking tools&lt;/li>&#xd;&#xa;&lt;li>Equipment rental (e.g. chairs, tables, AV, etc.)&lt;/li>&#xd;&#xa;&lt;li>Modest food buffet allowed&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>&lt;br>&#xd;&#xa;&lt;b>Not allowed&lt;/b>&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Entertainment and recreation expenses&lt;/li>&#xd;&#xa;&lt;li>Parking for attendees&lt;/li>&#xd;&#xa;&lt;li>Equipment purchases&lt;/li>&#xd;&#xa;&lt;li>Salary for employees or agents of an HCP&lt;/li>&#xd;&#xa;&lt;li>Travel costs, lodging or other expenses for non-faculty attendees including guests, spouses or family members of faculty&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </accordion_copy>
                            <separator_785741117__300484432
