                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                        <accordion
                            cq:styleIds="[1,8]"
                            jcr:created="{Date}2023-01-22T16:54:15.475-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2023-02-17T14:07:41.713-05:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/accordion/v2/accordion"
                            heading="Frequently asked questions"
                            headingElement="h5"
                            singleExpansion="false">
                            <item_1674424493787
                                cq:panelTitle="What is the purpose of the AbbVie Research Collaborative?"
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2023-05-03T14:37:57.230-04:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>AbbVie’s mission is to discover and develop new medicines for patients like you. We’re here to connect everyday people with more research opportunities and chances to influence future treatments.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <item_1674424499871
                                cq:panelTitle="Do I need to be diagnosed with migraine to participate in the Collaborative?"
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2023-02-17T14:09:50.825-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>No, you do not need to have an official diagnosis of migraine to join the Collaborative and contribute to this research. If you choose to enroll in a migraine clinical research study offered by AbbVie, a diagnosis from your physician may be required for participation in the study.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <item_1674424502611
                                cq:panelTitle="Are there any requirements to join the AbbVie Research Collaborative?"
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2023-02-17T14:10:04.490-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>You must be 18 years old and living in the US.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <item_1674424517045
                                cq:panelTitle="Will I be paid to participate in the AbbVie Research Collaborative?"
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2023-02-17T14:10:17.061-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>There is no compensation for joining the Collaborative. However, we will notify you as clinical research studies become available, and if you are eligible to participate, you may receive related compensation for participation in the study.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <item_1674424573736
                                cq:panelTitle="Who can I contact to learn more information about the AbbVie Research Collaborative?"
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2023-02-17T14:10:29.953-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>We're here to help. If you have any questions or concerns regarding participating in the AbbVie Research Collaborative, please email us at &lt;a href=&quot;mailto:research_collaborative@abbvie.com&quot;>research_collaborative@abbvie.com&lt;/a>.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </accordion>
