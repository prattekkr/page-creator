                                jcr:lastModified="{Date}2024-09-05T16:03:44.086-04:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                jcr:title="The partnerships team"
                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                type="h2"
                                variant="h"/>
                            <text_1185168660_copy
                                cq:styleIds="[1659545825678]"
                                jcr:created="{Date}2023-01-04T13:14:02.289-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2023-01-04T13:59:00.677-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Our team is ready to meet with you to share our capabilities and discuss your business opportunities. We are always looking for innovation and new partnership opportunities that align with our focus areas. With offices in the Northern California, Chicago and Boston areas, as well as other locations around the world, we look forward to hearing from you.&lt;/p>&#xd;&#xa;&lt;p>&lt;a href=&quot;https://abbvie.partneringplace.com/SubmissionUI/abbvie/submission&quot;>Contact us&lt;/a>&amp;nbsp;to submit your idea.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
