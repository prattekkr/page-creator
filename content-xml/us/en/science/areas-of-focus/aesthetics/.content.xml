                        <title2
                            cq:styleIds="[1659545825678,1651545824678,1651545825693]"
                            jcr:lastModified="{Date}2024-09-05T12:02:38.524-04:00"
                            jcr:lastModifiedBy="VALENSX5"
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Research interests"
