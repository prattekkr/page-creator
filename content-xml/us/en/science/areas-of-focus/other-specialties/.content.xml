                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Unified in a vision for progress"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text2
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2024-08-14T09:35:43.892-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Our teams are advancing the research and development for diseases that share one commonality — we believe that innovation will lead to new discoveries. Areas of interest include Hepatitis C, HIV, pulmonology, endocrinology, gastrointestinal diseases, and therapeutic neurotoxins.&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;Our scientific talent and experience are as diverse as the diseases we study. Together, we work around the globe to incubate and advance strategies to help bring medicines and solutions to adults and children in need.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container4>
