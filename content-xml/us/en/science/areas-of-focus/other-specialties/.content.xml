                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>Beyond our core therapeutic areas, our researchers study a diverse set of diseases with high unmet needs where we believe great progress for patients is possible.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
