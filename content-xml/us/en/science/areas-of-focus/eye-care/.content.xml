                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>A group of eye diseases (many different types) that cause damage to the optic nerve; usually involves high eye pressure; can lead to blindness.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <item_1671312481387
                                cq:panelTitle="Age-Related Retinal Diseases"
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2022-12-18T10:01:08.510-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Damage to the macula near the center of the retina affects a person's central vision and the ability to see fine details. Age-related macular degeneration is the most common cause of severe loss of eyesight among people 60 and older.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <item_1671372277563
                                cq:panelTitle="Refractive Disorders"
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2022-12-18T10:01:21.959-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Vision problems that make it hard to see clearly due to the shape of the eye not allowing light to focus on the retina. Some common refractive disorders may make it hard for middle-aged and older adults to see things up close.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </accordion_copy_copy>
