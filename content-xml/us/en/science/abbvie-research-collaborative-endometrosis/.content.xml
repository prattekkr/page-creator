                                jcr:lastModified="{Date}2023-02-17T14:13:51.662-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>The journey to&amp;nbsp;improve endometriosis care starts with research. And everyone deserves a voice in that process.&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;b>That’s where you come in.&amp;nbsp;&lt;/b>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <text_copy
                                cq:styleIds="[1659545825678]"
                                jcr:created="{Date}2022-12-10T17:16:00.094-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2023-02-17T14:14:25.923-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Our scientists are on a mission to improve lives. Join the AbbVie Research Collaborative to help uncover new insights and get updates on the latest research opportunities.&amp;nbsp;&lt;b style=&quot;font-size: 0.8125rem;&quot;>Joining is easy and free.&lt;/b>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <button_copy
                                jcr:created="{Date}2023-01-22T16:47:05.421-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2023-02-21T13:12:12.808-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                jcr:title="Join now"
                                sling:resourceType="abbvie-com2/components/button/v2/button"
                                accessibilityLabel="joining is easy"
                                linkTarget="_self"
                                linkURL="#join"/>
                        </par_13>
