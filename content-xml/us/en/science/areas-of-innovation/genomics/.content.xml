                        <par_12
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="wcm/foundation/components/parsys">
                            <container_568753235
                                cq:styleIds="[1653545825687,1653545847150,1653242825678,1653545835982]"
                                jcr:created="{Date}2022-12-16T18:05:55.966-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2022-12-16T18:05:55.966-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <title_116699496
                                    cq:styleIds="[1659545825678,1661545829678,1651545825692]"
                                    jcr:created="{Date}2022-12-15T11:49:26.700-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-09-05T12:06:38.965-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Unlocking the power of genomic data"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-07T14:53:09.069-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-11-22T13:44:03.741-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Genomics is swiftly moving to the forefront of medicine and helping transform health care by making it more personalized and proactive.&lt;/p>&#xd;&#xa;&lt;p>With access to more than 1 million genomes, AbbVie scientists are leading one of the world’s largest genomics research efforts, using real-world data, single-cell transcriptomics, epigenetics and other cutting-edge technologies to make revolutionary advancements that wouldn't have been possible only a few years ago.&lt;/p>&#xd;&#xa;&lt;p>Through building a greater understanding of disease biology and how medicine works at the individual level, we’re working to develop and deliver new and more tailored medicines for the right patient at the right time.&lt;/p>&#xd;&#xa;&lt;p>In 2016, AbbVie centralized all genetic and genomic work within the company and formed&amp;nbsp;&lt;a href=&quot;/content/abbvie-com2/us/en/who-we-are/our-stories/can-unlocking-one-million-genomes.html&quot;>AbbVie’s Genomics Research Center&lt;/a>. The center includes six specialized teams:&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-12-17T11:19:50.354-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-17T11:19:50.354-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <accordion
                                    cq:styleIds="[1,7]"
                                    jcr:created="{Date}2024-11-14T15:54:52.161-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-11-14T16:07:48.621-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/accordion/v2/accordion"
                                    heading="explore teams"
                                    singleExpansion="false">
                                    <item_1731617712950
                                        cq:panelTitle="Functional Genomics"
                                        cq:styleIds="[1659545825678]"
                                        jcr:lastModified="{Date}2024-11-14T15:56:42.917-05:00"
                                        jcr:lastModifiedBy="chiucx"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/text/v2/text"
                                        text="&lt;p>Uses advanced science to understand the function of the genome to identify, validate and progress therapeutic targets.&lt;/p>&#xd;&#xa;"
                                        textIsRich="true"/>
                                    <item_1731617717507
                                        cq:panelTitle="Genome Biology"
                                        cq:styleIds="[1659545825678]"
                                        jcr:lastModified="{Date}2024-11-14T15:57:01.597-05:00"
                                        jcr:lastModifiedBy="chiucx"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/text/v2/text"
                                        text="&lt;p>Uncovers the complex biology of the genome to understand how genes function and interact with diverse cellular models of human disease.&lt;/p>&#xd;&#xa;"
                                        textIsRich="true"/>
                                    <item_1731617723561
                                        cq:panelTitle="Bioinformatics"
                                        cq:styleIds="[1659545825678]"
                                        jcr:lastModified="{Date}2024-11-14T15:57:10.287-05:00"
                                        jcr:lastModifiedBy="chiucx"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/text/v2/text"
                                        text="&lt;p>Develops and applies computational methods for understanding the genomics of disease biology and treatment – from a single cell to entire populations.&lt;/p>&#xd;&#xa;"
                                        textIsRich="true"/>
                                    <item_1731617737596
                                        cq:panelTitle="Genomic Medicine"
                                        cq:styleIds="[1659545825678]"
                                        jcr:lastModified="{Date}2024-11-14T15:57:21.031-05:00"
                                        jcr:lastModifiedBy="chiucx"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/text/v2/text"
                                        text="&lt;p>Discovers genetic and genomic variations that may contribute to how a patient responds to therapy.&lt;/p>&#xd;&#xa;"
                                        textIsRich="true"/>
                                    <item_1731617747254
                                        cq:panelTitle="Human Genetics"
                                        cq:styleIds="[1659545825678]"
                                        jcr:lastModified="{Date}2024-11-14T15:57:35.719-05:00"
                                        jcr:lastModifiedBy="chiucx"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/text/v2/text"
                                        text="&lt;p>Analyzes and interprets data from large, human genetics databases to determine genotype-phenotype relationships, and to inform novel drug target discovery.&lt;/p>&#xd;&#xa;"
                                        textIsRich="true"/>
                                    <item_1731617863248
                                        cq:panelTitle="Genomic Technologies"
                                        cq:styleIds="[1659545825678]"
                                        jcr:lastModified="{Date}2024-11-14T15:58:10.560-05:00"
                                        jcr:lastModifiedBy="chiucx"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/text/v2/text"
                                        text="&lt;p>Advances preclinical and clinical research by deploying and developing novel high-throughput technologies to address important biological questions.&lt;/p>&#xd;&#xa;"
                                        textIsRich="true"/>
                                </accordion>
                                <title_116699496_copy
                                    cq:styleIds="[1659545825678,1661545829678,1651545825692]"
                                    jcr:created="{Date}2022-12-15T11:49:26.700-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-11-14T16:04:24.108-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Accelerating drug discovery and development"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_copy_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-07T14:53:09.069-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-11-22T13:45:14.095-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Genomics is the study of our DNA, which acts as a personal health blueprint for all of us.&amp;nbsp;&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>Today, the experts at AbbVie’s Genomics Research Center are analyzing and interpreting millions of ‘blueprints’ to determine what causes some of the world’s most challenging diseases and learn why people have unique risk factors, respond differently to certain treatments and more.&lt;/p>&#xd;&#xa;&lt;p>Breaking down massive amounts of human data to unearth solutions that work on the individual level, we’re working to improve disease prediction and produce precision medicines, more efficiently, to deliver them to patients faster.&lt;/p>&#xd;&#xa;&lt;p>&lt;a href=&quot;/content/abbvie-com2/us/en/who-we-are/our-stories/the-blueprint-of-you-unlocking-potential-whole-genome-sequencing.html&quot;>Meet one of AbbVie’s genetic pioneers&lt;/a>&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container_568753235>
