                        sling:resourceType="abbvie-com2/components/container/v2/container">
                        <title_116699496
                            cq:styleIds="[1659545825678,1661545829678,1651545825692]"
                            jcr:created="{Date}2022-12-15T11:49:26.700-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2024-11-14T16:11:54.593-05:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Pioneering scientific breakthroughs with human data"
                            sling:resourceType="abbvie-com2/components/title/v2/title"
                            type="h2"
                            variant="h"/>
                        <text_copy_copy
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2022-12-07T14:53:09.069-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2024-11-22T13:45:43.147-05:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>We’re focused on finding connections between our genes and health to better understand and treat disease. Our interests include:&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Utilizing innovative gene editing systems as a bridge between genomics and biology&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>Leveraging computational biology enabling multi-omics data integration, machine learning and human biology characterization to drive innovation&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>Leveraging rare diseases to discover and/or validate targets ultimately to help us design more individualized medicines for patients&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>Providing genetic evidence to repurpose some of our existing medicines into new indications&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>Implementing induced pluripotent stem cells (iPSCs) with gene editing and genomics&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>Applying cutting-edge platforms integrated with automated wetlab and standardized analysis pipeline for high-throughput multi-omic data generation&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>Using&amp;nbsp;artificial intelligence (AI)/machine learning (ML)  and predictive modeling for a variety of analyses for target prioritization, extracting knowledge from multi-omics data, imaging and others&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>Using human genetic data to accelerate R&amp;amp;D and reduce failure rates&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                            textIsRich="true"/>
                    </container_568753235_>
                    <copy_of_container_co
                        cq:styleIds="[1653545825683,1653545847149,1653545835879]"
                        jcr:created="{Date}2022-12-05T12:55:26.609-05:00"
