                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>We’re leading one of the largest genomics research efforts in the world to discover and deliver the right medicines for the right patient at the right time.&lt;/span>&lt;/span> &lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
