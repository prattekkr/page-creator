                                jcr:primaryType="nt:unstructured"
                                jcr:title="AbbVie's response to the Ukraine crisis"
                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                type="h1"/>
                            <text
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2022-12-21T13:21:44.096-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>Our thoughts are with the people of Ukraine and those affected across the region. As a global biopharmaceutical company, we have a responsibility to patients who depend on our medicines. We are committed to ensuring our patients in Ukraine, Russia, and throughout the region continue to have access to our essential and life-saving medicines.&amp;nbsp;&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </container3>
                    </container2>
                    <container_1947196865
                        cq:styleIds="[1653545825688]"
                        jcr:created="{Date}2022-12-21T13:22:19.204-05:00"
                        jcr:createdBy="chiucx"
                        jcr:lastModified="{Date}2022-12-21T13:22:19.204-05:00"
                        jcr:lastModifiedBy="chiucx"
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="abbvie-com2/components/container/v2/container">
                        <title
                            cq:styleIds="[1659545825678,1661545829678]"
                            jcr:created="{Date}2022-12-21T13:22:42.069-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2022-12-21T13:23:02.491-05:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            jcr:title="AbbVie will donate profits from Russia to humanitarian relief"
                            sling:resourceType="abbvie-com2/components/title/v2/title"
                            type="h5"/>
                        <text
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2022-12-21T13:23:10.733-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2022-12-21T13:23:16.294-05:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>As a company dedicated to the health of patients, we will continue to supply our essential life-saving medicines in Russia. All profits from sales of AbbVie’s essential medicines in Russia will be donated to support direct humanitarian relief efforts in Ukraine.&lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
                        <separator
                            cq:styleIds="[1662756456518]"
                            jcr:created="{Date}2022-12-21T13:23:30.349-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2022-12-21T13:23:30.349-05:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                        <title_copy
                            cq:styleIds="[1659545825678,1661545829678]"
                            jcr:created="{Date}2022-12-21T13:22:42.069-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2022-12-21T13:25:02.614-05:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            jcr:title="AbbVie's presence in Ukraine and throughout the region"
                            sling:resourceType="abbvie-com2/components/title/v2/title"
                            type="h5"/>
                        <text_copy
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2022-12-21T13:23:10.733-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2022-12-21T13:25:10.090-05:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>As the tragic events continue to unfold in Ukraine, we previously announced the suspension of operations of our aesthetics products in Russia.&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>We do not have any manufacturing plants in the region and will continue to monitor the safety of our employees in the region&lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
                        <separator_copy
                            cq:styleIds="[1662756456518]"
                            jcr:created="{Date}2022-12-21T13:23:30.349-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2022-12-21T13:23:30.349-05:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                        <title_copy_copy
                            cq:styleIds="[1659545825678,1661545829678]"
                            jcr:created="{Date}2022-12-21T13:22:42.069-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2022-12-21T13:25:17.374-05:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Status of clinical trials"
                            sling:resourceType="abbvie-com2/components/title/v2/title"
                            type="h5"/>
                        <text_copy_copy
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2022-12-21T13:23:10.733-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2022-12-21T13:25:23.239-05:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>AbbVie is doing everything possible to minimize disruption to the treatment and care of our patients and clinical trial participants. We have halted new clinical studies and ceased enrollment of ongoing studies in Ukraine and Russia. We are committed to ensuring our clinical trial participants have access to the investigational medicines they need.&lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
                        <separator_copy_copy
                            cq:styleIds="[1662756456518]"
                            jcr:created="{Date}2022-12-21T13:23:30.349-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2022-12-21T13:23:30.349-05:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                        <title_copy_copy_copy
                            cq:styleIds="[1659545825678,1661545829678]"
                            jcr:created="{Date}2022-12-21T13:22:42.069-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2022-12-21T13:25:31.445-05:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Humanitarian / Philanthropic response"
                            sling:resourceType="abbvie-com2/components/title/v2/title"
                            type="h5"/>
                        <text_copy_copy_1113584035
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2022-12-21T13:23:10.733-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2022-12-21T13:25:40.767-05:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>Our philanthropic focus is on humanitarian, employee, and donation support.&lt;/p>&#xd;&#xa;&lt;p>AbbVie is:&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Donating a total of&amp;nbsp;$1 million to nonprofit partners for medical care and supplies for Ukraine and Ukrainian refugees.&lt;/li>&#xd;&#xa;&lt;li>Donating essential medicines to the Ukrainian government and our disaster relief partners.&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>Providing relief and additional financial support as needed to Ukrainian employees and their immediate families.&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;li>Doubling the AbbVie Foundation's employee donation match for select disaster relief partners with active humanitarian relief efforts in Ukraine and surrounding countries.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>As this situation evolves, we will continue working with our nonprofit partners and employees to support relief efforts as we hope for a peaceful resolution.&lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
                    </container_1947196865>
