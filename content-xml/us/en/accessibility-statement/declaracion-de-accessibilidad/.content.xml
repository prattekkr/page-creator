                        <title_copy_copy_copy
                            cq:styleIds="[1659545825678,1661545829678]"
                            jcr:created="{Date}2023-03-03T16:34:12.950-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2023-09-05T15:12:56.237-04:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Especificaciones técnicas"
                            sling:resourceType="abbvie-com2/components/title/v2/title"
                            type="h3"
                            variant="h"/>
                        <text_copy_copy
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2023-03-03T16:36:24.626-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2023-09-05T15:13:19.637-04:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>La accesibilidad de nuestros sitios web depende de las siguientes tecnologías para trabajar con la combinación particular de navegadores web y cualquier tecnología asistencial o complementos (plugins) instalados en su computadora:&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>HTML&amp;nbsp;&lt;/li>&#xd;&#xa;&lt;li>WAI-ARIA&amp;nbsp;&lt;/li>&#xd;&#xa;&lt;li>CSS&amp;nbsp;&lt;/li>&#xd;&#xa;&lt;li>JavaScript&amp;nbsp;&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>Estas tecnologías se utilizan para cumplir con las normas de accesibilidad usadas.&lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
