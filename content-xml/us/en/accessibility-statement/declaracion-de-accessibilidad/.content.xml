                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>Esta es una declaración de accesibilidad de AbbVie Inc.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
