                            jcr:primaryType="nt:unstructured"
                            jcr:title="Medidas para apoyar la accesibilidad"
                            sling:resourceType="abbvie-com2/components/title/v2/title"
                            type="h3"
                            variant="h"/>
                        <text_copy
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2023-03-03T16:36:24.626-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2023-09-05T15:12:48.306-04:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>AbbVie Inc. toma las siguientes medidas para asegurar la accesibilidad a nuestros sitios web:&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Incluye accesibilidad en nuestras políticas internas.&amp;nbsp;&lt;/li>&#xd;&#xa;&lt;li>Asigna un oficial y/o mediador de accesibilidad&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                            textIsRich="true"/>
                        <separator_copy_copy
                            cq:styleIds="[1662756423318]"
                            jcr:created="{Date}2023-05-02T15:20:38.160-04:00"
                            jcr:createdBy="chiucx"
