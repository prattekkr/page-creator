                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>The AbbVie Foundation envisions a world where all people live their healthiest lives—we strive to remove the barriers that stand in the way.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <text_1286916811
                                cq:styleIds="[1659545825678]"
                                jcr:created="{Date}2025-12-11T12:14:01.519-05:00"
                                jcr:createdBy="VALENSX5"
                                jcr:lastModified="{Date}2025-12-12T14:56:12.140-05:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>A person’s health is influenced by more than clinical care alone. Education, access, social and environmental conditions, and financial resources all shape health outcomes — especially in underserved communities.&lt;/p>&#xd;&#xa;&lt;p>We work with organizations to address the root causes of systemic barriers impacting the health of their communities. By empowering our partners to accelerate and expand their innovative, community-led solutions, we’re tackling the most pressing needs and driving transformative change so everyone can thrive.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </container3>
                    </container2>
