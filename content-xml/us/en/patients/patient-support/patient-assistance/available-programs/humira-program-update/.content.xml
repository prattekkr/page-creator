                                jcr:primaryType="nt:unstructured"
                                jcr:title="Important Program Updates to myAbbVie Assist Patient Assistance program (PAP) for HUMIRA® (adalimumab) "
                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                langAttribute="none"
                                type="h1"
                                variant="h"/>
                            <text
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2026-04-30T16:28:49.715-04:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                langAttribute="none"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>We’ve recently updated our Patient Assistance Program, please see below for more information.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <container
                                jcr:created="{Date}2026-04-30T17:06:12.366-04:00"
                                jcr:createdBy="VALENSX5"
                                jcr:lastModified="{Date}2026-04-30T17:06:12.366-04:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <text_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2026-04-30T16:28:57.016-04:00"
                                    jcr:createdBy="VALENSX5"
                                    jcr:lastModified="{Date}2026-04-30T17:07:52.495-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    langAttribute="none"
                                    text="&lt;p>&lt;b>HUMIRA Program Updates:&lt;/b>&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>After carefully reviewing the growing number of treatment options available to patients today, including FDA‑approved adalimumab biosimilars that may be available through insurance or other support programs, we have decided to begin phasing out HUMIRA from the myAbbVie Assist Patient Assistance Program.&lt;/li>&#xd;&#xa;&lt;li>&lt;b>Effective July 1, 2026, myAbbVie Assist PAP will no longer accept &lt;u>new patients&lt;/u> for HUMIRA into the program.&lt;/b>&lt;/li>&#xd;&#xa;&lt;li>&lt;b>We will continue to support currently enrolled patients in the program through the end of their current eligibility term.&lt;/b>&lt;/li>&#xd;&#xa;&lt;li>When a patient’s current eligibility ends, they will not be able to renew their enrollment for HUMIRA through the myAbbVie Assist program.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>&lt;b>What Current HUMIRA PAP Patients Should Do Next:&lt;/b>&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Call your healthcare provider to discuss treatment options and to plan next steps.&lt;/li>&#xd;&#xa;&lt;li> If you have insurance, contact your insurance provider to learn which treatment options are covered by your insurance.&lt;/li>&#xd;&#xa;&lt;li>We encourage patients to start planning now with your healthcare provider, as changing treatment can take time. &lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <container
                                    jcr:created="{Date}2026-04-30T17:06:34.453-04:00"
                                    jcr:createdBy="VALENSX5"
                                    jcr:lastModified="{Date}2026-04-30T17:06:34.453-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/container/v2/container">
                                    <accordion_copy
                                        cq:styleIds="[1]"
                                        jcr:created="{Date}2026-04-30T16:30:22.722-04:00"
                                        jcr:createdBy="VALENSX5"
                                        jcr:lastModified="{Date}2026-04-30T17:10:30.014-04:00"
                                        jcr:lastModifiedBy="VALENSX5"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/accordion/v2/accordion"
                                        heading="Frequently Asked Questions:"
                                        singleExpansion="false">
                                        <item_1777581045595
                                            cq:panelTitle="What is a biosimilar"
                                            cq:styleIds="[1659545825678]"
                                            jcr:lastModified="{Date}2026-04-30T17:11:16.514-04:00"
                                            jcr:lastModifiedBy="VALENSX5"
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="abbvie-com2/components/text/v2/text"
                                            langAttribute="none"
                                            text="&lt;ul>&#xd;&#xa;&lt;li>A biosimilar is defined as a medicine that is different from the original but has no clinically meaningful differences in terms of safety, purity, or potency. Over the past few years, several biosimilar options for HUMIRA have gained FDA approval and have been released for patient use. Since biosimilars are often lower cost, many insurance plans now prefer biosimilars instead of HUMIRA.&lt;/li>&#xd;&#xa;&lt;li>Click &lt;a href=&quot;/content/dam/abbvie-com2/pdfs/biosimilar-pap.pdf&quot;>here&lt;/a>&amp;nbsp;for a listing of FDA-approved biosimilars and website information.&amp;nbsp; Visit the&amp;nbsp;biosimilar’s&amp;nbsp;official website or reach out to their support&amp;nbsp;team for details about their product and available benefits.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                            textIsRich="true"/>
                                        <item_1777581141922
                                            cq:panelTitle="Are there any immediate changes for patients who are currently enrolled? "
                                            cq:styleIds="[1659545825678]"
                                            jcr:lastModified="{Date}2026-04-30T16:41:34.053-04:00"
                                            jcr:lastModifiedBy="VALENSX5"
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="abbvie-com2/components/text/v2/text"
                                            langAttribute="none"
                                            text="&lt;p>No, there are no immediate impacts to a patient’s current enrollment or ability to receive their medication. Patients currently enrolled may remain in the program until their enrollment end date. &lt;/p>&#xd;&#xa;"
                                            textIsRich="true"/>
                                        <item_1777581160373
                                            cq:panelTitle="Will AbbVie help to find alternative treatments for patients or provide any further guidance?   "
                                            cq:styleIds="[1659545825678]"
                                            jcr:lastModified="{Date}2026-04-30T17:32:20.298-04:00"
                                            jcr:lastModifiedBy="VALENSX5"
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="abbvie-com2/components/text/v2/text"
                                            langAttribute="none"
                                            text="&lt;p>AbbVie understands that treatment decisions are made between a patient and their provider. Accordingly, AbbVie does not help identify or provide alternative treatment options for patients.&lt;/p>&#xd;&#xa;"
                                            textIsRich="true"/>
                                        <item_1777581169340
                                            cq:panelTitle="How do I know what other treatment options are available?"
                                            cq:styleIds="[1659545825678]"
                                            jcr:lastModified="{Date}2026-04-30T16:56:02.126-04:00"
                                            jcr:lastModifiedBy="VALENSX5"
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="abbvie-com2/components/text/v2/text"
                                            langAttribute="none"
                                            text="&lt;ul>&#xd;&#xa;&lt;li>If you have insurance, check with your insurance provider to understand what other treatment options are covered through your plan.&lt;/li>&#xd;&#xa;&lt;li>Contact your healthcare provider to discuss what treatment options are right for you and begin next steps towards an alternate treatment plan.&lt;/li>&#xd;&#xa;&lt;li>For a list of FDA-approved biosimilars and website information, please click &lt;a href=&quot;/content/dam/abbvie-com2/pdfs/biosimilar-pap.pdf&quot;>here&lt;/a>.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                            textIsRich="true"/>
                                        <item_1777581182090
                                            cq:panelTitle="My insurance only covers an adalimumab biosimilar, but I would like to continue taking HUMIRA. What options do I have? "
                                            cq:styleIds="[1659545825678]"
                                            jcr:lastModified="{Date}2026-04-30T16:56:29.789-04:00"
                                            jcr:lastModifiedBy="VALENSX5"
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="abbvie-com2/components/text/v2/text"
                                            langAttribute="none"
                                            text="&lt;ul>&#xd;&#xa;&lt;li>Humira will be phased out of the myAbbVie Assist PAP and no longer available for new patients. Existing patients will be unable to renew their enrollment.&lt;/li>&#xd;&#xa;&lt;li>If you are doing well on HUMIRA, an adalimumab biosimilar may be an option to support continued therapy. Many biosimilars have a patient assistance program for patients with affordability concerns. Please review the product information for approved indications and dosing, as well as PAP program availability. For your information, please click &lt;a href=&quot;/content/dam/abbvie-com2/pdfs/biosimilar-pap.pdf&quot;>here&lt;/a> for a listing of FDA-approved biosimilars and website information.&lt;/li>&#xd;&#xa;&lt;li>If a new therapeutic plan would better meet your goals, other AbbVie treatment options offered through myAbbVie Assist such as SKYRIZI® (risankizumab-rzaa) and RINVOQ® (upadacitinib) may be available. Please see the product labeling for approved indication and dosing.&lt;/li>&#xd;&#xa;&lt;li>Discuss with your healthcare provider about what option is best for you.&lt;br>&#xd;&#xa;&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                            textIsRich="true"/>
                                        <item_1777581191475
                                            cq:panelTitle="Do biosimilars have patient assistance programs? "
                                            cq:styleIds="[1659545825678]"
                                            jcr:lastModified="{Date}2026-04-30T17:05:59.298-04:00"
                                            jcr:lastModifiedBy="VALENSX5"
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="abbvie-com2/components/text/v2/text"
                                            langAttribute="none"
                                            text="&lt;ul>&#xd;&#xa;&lt;li>Biosimilars&amp;nbsp;may&amp;nbsp;have their own patient&amp;nbsp;assistance&amp;nbsp;programs.&amp;nbsp;For your information, please click &lt;a href=&quot;/content/dam/abbvie-com2/pdfs/biosimilar-pap.pdf&quot;>here&lt;/a> for a listing of FDA-approved biosimilars and website information.&amp;nbsp;To&amp;nbsp;see&amp;nbsp;details about&amp;nbsp;their eligibility requirements and benefits, please visit the&amp;nbsp;biosimilar’s&amp;nbsp;official website or reach out to their support&amp;nbsp;team.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                            textIsRich="true"/>
                                        <item_1777581199975
                                            cq:panelTitle="What is AbbVie’s position on adalimumab biosimilars?"
                                            cq:styleIds="[1659545825678]"
                                            jcr:lastModified="{Date}2026-04-30T16:47:50.279-04:00"
                                            jcr:lastModifiedBy="VALENSX5"
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="abbvie-com2/components/text/v2/text"
                                            langAttribute="none"
                                            text="&lt;p>AbbVie supports the entry of biosimilars that have been shown, with robust evidence, including clinical trials, to be as safe and efficacious as originator biologic medicines. Please see our position through the following link: &lt;a href=&quot;https://mcas-proxyweb.mcas.ms/certificate-checker?login=false&amp;amp;originalUrl=https%3A%2F%2Fnews.abbvie.com.mcas.ms%2F2015-17-20-Committed-to-Biologic-Innovation%3FMcasTsid%3D20892&amp;amp;McasCSRF=6bad08f8dda5d9a7213ce99ba90732fd7afaf0a1c00d24eb7f4884ac11a0e392&quot;>https://news.abbvie.com/2015-17-20-Committed-to-Biologic-Innovation&lt;/a>  &lt;/p>&#xd;&#xa;"
                                            textIsRich="true"/>
                                        <item_1777581211509
                                            cq:panelTitle="Who do I contact if I have more questions about myAbbVie Assist?"
                                            cq:styleIds="[1659545825678]"
                                            jcr:lastModified="{Date}2026-04-30T16:48:13.589-04:00"
                                            jcr:lastModifiedBy="VALENSX5"
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="abbvie-com2/components/text/v2/text"
                                            langAttribute="none"
                                            text="&lt;p>For further information, please call 1-800-222-6885, available Monday through Friday from 7am-7pm CST, to speak with a Patient Assistance Counselor.&lt;/p>&#xd;&#xa;"
                                            textIsRich="true"/>
                                    </accordion_copy>
                                </container>
