                                jcr:lastModifiedBy="stromkx1"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>AbbVie’s summer internship program offers current undergraduate and graduate college students the opportunity to gain impactful industry experience across a wide range of business and scientific areas, from R&amp;amp;D and commercial to HR, finance, operations and more.&lt;/p>&#xd;&#xa;"
