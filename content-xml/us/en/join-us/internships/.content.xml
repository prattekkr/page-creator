                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>This summer start your career with AbbVie&amp;nbsp;&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
