                                <item_1759341157007
                                    cq:panelTitle="How long are internship programs at AbbVie?"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2025-12-19T12:24:30.806-05:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Our internships typically run for ten to twelve weeks over the summer, from May to August, and are full-time, paid experiences.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1759341166926
                                    cq:panelTitle="What business areas can interns explore at AbbVie?"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2025-12-19T12:24:49.991-05:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>We have internship opportunities available in:&lt;br />&#xd;&#xa;&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Commercial&lt;/li>&#xd;&#xa;&lt;li>Corporate &lt;/li>&#xd;&#xa;&lt;li>Operations&lt;/li>&#xd;&#xa;&lt;li>Research &amp;amp; Development&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1759341172358
                                    cq:panelTitle="What is the internship experience like at AbbVie?"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2025-12-19T12:25:11.285-05:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;ul>&#xd;&#xa;&lt;li>Real, impactful project work&lt;/li>&#xd;&#xa;&lt;li>Exposure to leaders throughout the organization&lt;/li>&#xd;&#xa;&lt;li>Skill-building sessions&lt;/li>&#xd;&#xa;&lt;li>Social events to build your professional network&lt;/li>&#xd;&#xa;&lt;li>Immersed in a purpose-driven, inclusive culture that fosters curiosity, collaboration, and connection&lt;/li>&#xd;&#xa;&lt;li>Access to wellness tools and philanthropic initiatives&lt;/li>&#xd;&#xa;&lt;li>Opportunity to present projects to functional peers and leaders&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1759341180543
                                    cq:panelTitle="Where are AbbVie internships located?"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2025-12-02T12:03:14.079-05:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>We offer internships across ten+ U.S. sites, including:&lt;br>&#xd;&#xa;Irvine, CA; Pleasanton, CA; South San Francisco, CA; Lake County, IL; Cambridge, MA; Waltham, MA; Worcester, MA; Wyandotte, MI; Branchburg, NJ; Florham Park, NJ; Madison, NJ; Waco, TX; Sales field-based locations.&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;Specific locations may vary depending on your role and function, so please check the individual listing on our career site for more details.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1764694792684
                                    cq:panelTitle="Who is eligible to apply for an AbbVie internship?"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2025-12-02T12:03:52.456-05:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>If you’re a currently enrolled third-year undergraduate college student, or a graduate college student pursuing a master’s, MBA, PhD, or PharmD degree, then you should consider applying!&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;Eligibility may vary by program, so refer to individual listings on our career site for specific degree requirements.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1764694797392
                                    cq:panelTitle="Is relocation support available for AbbVie interns?"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2025-12-02T12:04:17.658-05:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>If eligible, you’ll receive relocation support to help with travel and housing expenses through our relocation vendor.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </accordion_copy_copy_>
                        </container_1590644019_96479118>
