                                        jcr:lastModifiedBy="VALENSX5"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/text/v2/text"
                                        text="&lt;p>You may go through phone or video interviews, with a mix of behavioral, technical, or case-style questions based on the role.&lt;/p>&#xd;&#xa;"
                                        textIsRich="true"/>
                                    <item_1759341166926
                                        cq:panelTitle="What are the internship start and end dates?"
                                        cq:styleIds="[1659545825678]"
                                        jcr:lastModified="{Date}2025-12-02T12:32:27.699-05:00"
                                        jcr:lastModifiedBy="VALENSX5"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/text/v2/text"
                                        text="&lt;p>Internships typically begin in May and end in August, running for approximately 10-12 weeks.&lt;/p>&#xd;&#xa;"
                                        textIsRich="true"/>
                                    <item_1759341172358
                                        cq:panelTitle="What areas of the business offer internships?"
                                        cq:styleIds="[1659545825678]"
                                        jcr:lastModified="{Date}2025-12-02T12:32:49.281-05:00"
                                        jcr:lastModifiedBy="VALENSX5"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/text/v2/text"
                                        text="&lt;p>Internships are available across a range of functions, including:&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Commercial&lt;/li>&#xd;&#xa;&lt;li>Corporate&lt;/li>&#xd;&#xa;&lt;li>Operations&lt;/li>&#xd;&#xa;&lt;li>Research &amp;amp; Development&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                        textIsRich="true"/>
                                    <item_1759341180543
                                        cq:panelTitle="Is the AbbVie internship paid?"
                                        cq:styleIds="[1659545825678]"
                                        jcr:lastModified="{Date}2025-12-02T12:33:09.635-05:00"
                                        jcr:lastModifiedBy="VALENSX5"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="abbvie-com2/components/text/v2/text"
                                        text="&lt;p>Yes, all internships are paid, full-time positions.&lt;/p>&#xd;&#xa;"
