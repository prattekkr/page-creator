                            jcr:created="{Date}2023-01-10T00:09:56.155-05:00"
                            jcr:createdBy="schafsm"
                            jcr:lastModified="{Date}2024-09-12T10:30:06.777-04:00"
                            jcr:lastModifiedBy="VALENSX5"
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Making an impact"
                            sling:resourceType="abbvie-com2/components/title/v2/title"
                            type="h2"
                            variant="h"/>
                        <text_797704670
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2023-01-10T00:10:01.618-05:00"
                            jcr:createdBy="schafsm"
                            jcr:lastModified="{Date}2025-07-24T09:13:59.260-04:00"
                            jcr:lastModifiedBy="VALENSX5"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>Community outreach is part of AHORA’s fabric. True to our vision of building a stronger workforce, we are committed to supporting the communities in our own backyard.&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>We’ve embedded with a high school in our hometown community of Waukegan, IL and support their students with mentoring along with career exploration, including encouraging their students to apply to our internships&amp;nbsp;&lt;/li>&#xd;&#xa;&lt;li>We engage in various volunteer efforts, including mentorship for students from diverse backgrounds&amp;nbsp;&lt;/li>&#xd;&#xa;&lt;li>We partner with other organizations to find ways to collaborate and benchmark on Latino ERG initiatives and activities and provide networking and mentorship workshops&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>AHORA is proud to support community organizations in partnership with the AbbVie Foundation.&amp;nbsp;&lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
