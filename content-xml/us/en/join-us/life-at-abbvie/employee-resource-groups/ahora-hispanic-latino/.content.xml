                            jcr:lastModified="{Date}2025-08-08T09:33:12.558-04:00"
                            jcr:lastModifiedBy="VALENSX5"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>True to our vision of helping employees reach their full potential, AHORA emphasizes mentorship and networking opportunities.&lt;/p>&#xd;&#xa;&lt;p>Our efforts include:&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Hosting “Café con Leche” talks with AbbVie leadership&lt;/li>&#xd;&#xa;&lt;li>Offering seminars led by university partners&amp;nbsp;&lt;/li>&#xd;&#xa;&lt;li>Collaborating with external organizations&lt;/li>&#xd;&#xa;&lt;li>Supporting employees new to AbbVie with orientation activities&amp;nbsp;&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                            textIsRich="true"/>
                        <separator
                            cq:styleIds="[1662756456518]"
                            jcr:created="{Date}2023-01-11T11:44:55.671-05:00"
                            jcr:createdBy="chiucx"
