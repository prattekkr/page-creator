                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Skill development is one of our strategic priorities. We do this through activities such as:&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Seminars to empower our members to activate their career development.&lt;/li>&#xd;&#xa;&lt;li>Informal networking and mentorship opportunities, which help improve retention and employee satisfaction.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                textIsRich="true"/>
