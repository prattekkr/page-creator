                                jcr:created="{Date}2023-01-06T22:21:03.834-05:00"
                                jcr:createdBy="schafsm"
                                jcr:lastModified="{Date}2025-07-24T09:46:59.208-04:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>We are committed to helping employees achieve their full potential and support community organizations where we work and live. We focus on engaging with our local communities, amplifying our impact beyond bringing effective medicines to market. This includes volunteering for events that teach the importance of STEM-based curriculum with school-age children in underserved schools.&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>WLA is proud to support community organizations in partnership with the AbbVie Foundation.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
