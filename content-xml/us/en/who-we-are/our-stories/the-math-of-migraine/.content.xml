                                jcr:created="{Date}2022-12-02T18:56:04.777-05:00"
                                jcr:createdBy="schafsm"
                                jcr:lastModified="{Date}2022-12-02T18:56:29.692-05:00"
                                jcr:lastModifiedBy="schafsm"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/image/v2/image"
                                altValueFromDAM="true"
                                displayPopupTitle="true"
                                fileReference="/content/dam/abbvie-com2/images/stories/the-math-of-migraine/math-of-migraine_stats_860x484.png"
                                isDecorative="false"
                                titleValueFromDAM="true"/>
                            <container_598586051
                                cq:styleIds="[1653545825687,1653545847150,1653242825678]"
                                jcr:created="{Date}2022-12-02T18:56:48.253-05:00"
                                jcr:createdBy="schafsm"
                                jcr:lastModified="{Date}2022-12-02T18:56:48.253-05:00"
                                jcr:lastModifiedBy="schafsm"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <text
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-02T18:57:07.891-05:00"
                                    jcr:createdBy="schafsm"
                                    jcr:lastModified="{Date}2022-12-02T18:57:23.041-05:00"
                                    jcr:lastModifiedBy="schafsm"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Above all, Ruiz de la Torre says awareness about how migraine impacts people – not just at work but everywhere – can help combat its stigma and bring hope to those who live with it.&lt;/p>&#xd;&#xa;&lt;p>“We don’t have to be shamed for it,” Ruiz de la Torre says about migraine. “I want [people with migraine] to live a future life in a much easier way than the one I have had to live because there was no understanding.”&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container_598586051>
