                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>Why is it important for people to see a rheumatologist sooner rather than later?&lt;/span>&lt;/span>&lt;/p>&#xa;"
                                textIsRich="true"/>
