                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                jcr:title="With the acquisition of Allergan, we expanded our therapeutic areas, adding aesthetics, eye care and neuroscience to AbbVie's already established immunology and hematologic oncology franchises."
