                            <container_1023517219
                                cq:styleIds="[1653545825687,1653545847150,1653242825678,1653545835982]"
                                jcr:created="{Date}2022-12-01T22:50:06.015-05:00"
                                jcr:createdBy="schafsm"
                                jcr:lastModified="{Date}2022-12-01T22:50:06.015-05:00"
                                jcr:lastModifiedBy="schafsm"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <text
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-01T22:50:53.781-05:00"
                                    jcr:createdBy="schafsm"
                                    jcr:lastModified="{Date}2022-12-01T22:51:14.367-05:00"
                                    jcr:lastModifiedBy="schafsm"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>“For so long, it hurt to move. Nobody knew what was wrong with me, that I had an autoimmune skin disease. I went seven years from when the symptoms started to when I actually found out what it was: hidradenitis suppurativa. What kept me going and kept me positive through the years was hope for a better, more comfortable life where I wouldn’t have to deal with pain and discomfort.&lt;/p>&#xd;&#xa;&lt;p>Challenges or failures happen, and it is not a reason to stop.”&lt;/p>&#xd;&#xa;&lt;p>–&amp;nbsp;&lt;i>Will, lives with hidradenitis suppurativa&lt;/i>&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container_1023517219>
