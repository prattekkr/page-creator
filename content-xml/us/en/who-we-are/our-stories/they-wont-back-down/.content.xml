                                quoteType="regular"
                                textSize="h0"/>
                            <container_525522024
                                cq:styleIds="[1653545825687,1653545847150,1653242825678,1653545835982]"
                                jcr:created="{Date}2022-12-01T22:47:31.777-05:00"
                                jcr:createdBy="schafsm"
                                jcr:lastModified="{Date}2022-12-01T22:47:31.777-05:00"
                                jcr:lastModifiedBy="schafsm"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <text
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-01T22:48:30.264-05:00"
                                    jcr:createdBy="schafsm"
                                    jcr:lastModified="{Date}2022-12-01T22:48:40.431-05:00"
                                    jcr:lastModifiedBy="schafsm"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>“I have spent a lot of time as an epidemiologist trying to understand the burden of disease. So much of science is quantifying the world around us and finding answers to unanswered questions. The investment in the future is critical because, in the work we do, things don’t happen overnight. You have to think today about what the questions are tomorrow.&lt;/p>&#xa;&lt;p>Innovation requires a vision and the way to innovate is to take small steps each day. It’s that willingness to learn and ask the next question. Tenacity is the anchor of solving any real challenge. It’s what keeps you there, keeps you trying, keeps you driven to find that answer.”&lt;/p>&#xa;&lt;p>–&lt;i>&amp;nbsp;Aubrey Adams, Ph.D., Area Lead TNT &amp;amp; Migraine, U.S. Medical Affairs, AbbVie&lt;/i>&lt;/p>&#xa;"
                                    textIsRich="true"/>
                            </container_525522024>
