                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>Learn about the program’s continued support for community-led solutions to advance health equity.&amp;nbsp;&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
