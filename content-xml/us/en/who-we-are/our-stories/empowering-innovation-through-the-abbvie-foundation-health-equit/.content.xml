                                    jcr:title="What the program provides:"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    langAttribute="none"
                                    type="h2"
                                    variant="h"/>
                                <image_copy_copy_copy
                                    jcr:created="{Date}2026-01-26T16:15:33.772-05:00"
                                    jcr:createdBy="VALENSX5"
                                    jcr:lastModified="{Date}2026-01-26T16:15:39.824-05:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/image/v2/image"
                                    altValueFromDAM="true"
                                    displayPopupTitle="true"
                                    dmPresetType="imagePreset"
                                    fileReference="/content/dam/abbvie-com2/images/stories/accelerator/accelerator-story-infographic.jpg"
                                    isDecorative="false"
                                    openInNewWindow="false"
                                    titleValueFromDAM="true"/>
                                <separator_copy_15795
                                    cq:styleIds="[1662756486159]"
                                    jcr:created="{Date}2026-01-28T14:44:28.919-05:00"
                                    jcr:createdBy="VALENSX5"
                                    jcr:lastModified="{Date}2026-01-28T14:44:28.919-05:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_533958857
                                    cq:styleIds="[1659545825678,1651545825694]"
                                    jcr:created="{Date}2026-01-26T16:09:22.841-05:00"
                                    jcr:createdBy="VALENSX5"
                                    jcr:lastModified="{Date}2026-01-26T16:11:47.768-05:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Innovating Together: The Power of Collaboration "
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text2_copy_757537449
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2026-01-28T14:43:43.647-05:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>By bringing together community-based organizations, offering expert mentorship and resources, along with structured opportunities for strategy building, the accelerator is catalyzing a new era of innovation in health equity.&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>For Banco de Alimentos de Puerto Rico, participation in the AbbVie Foundation Health Equity Accelerator was vital in strengthening the nonprofit’s strategy and impact.&amp;nbsp;At the conclusion of the program, the organization received a $50,000 grant for their innovative solution to advance health equity.&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>“Being a participant in the program and the support we’ve gotten, I feel like I’ve just left with a bachelor’s degree in Medicare, health care management 101,” said Laborde.&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>Through the accelerator, the organization has been able to enhance the impact of their “Food as Medicine” initiative. The program provides monthly food prescriptions, in-home health check-ins, nutrition&amp;nbsp;education&amp;nbsp;and exercise activities to older adults in underserved Puerto Rican communities.&amp;nbsp;&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>Catalyzed by the mentorship and support received through the accelerator, Banco de Alimentos de Puerto Rico recently secured a public grant to scale its impact. The organization will soon open the first three ‘food pharmacies’ within community health clinics across the island, addressing not only hunger, but other key factors in shaping long-term health outcomes.&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>By investing in innovative solutions, the accelerator is empowering nonprofits across the U.S. with the support and resources needed to forge new pathways to better health outcomes – driving transformative change and strengthening communities along the way.&lt;/p>&#xd;&#xa;&lt;p>Learn more about the&amp;nbsp;&lt;a href=&quot;https://www.abbvie.com/sustainability/abbvie-foundation/innovative-impact.html&quot;>AbbVie Foundation’s approach to driving innovative impact&lt;/a>.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container4>
                        </par_12>
