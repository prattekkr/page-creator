                                jcr:primaryType="nt:unstructured"
                                jcr:title="Working Parent Sofie Berg and her two sons Hugo and Victor connect through a love of soccer, cooking and travel."
                                sling:resourceType="abbvie-com2/components/image/v2/image"
                                altValueFromDAM="true"
                                displayPopupTitle="false"
                                dmPresetType="imagePreset"
                                fileReference="/content/dam/abbvie-com2/images/stories/working-parent-2023/sofie-berg-family.jpg"
                                isDecorative="false"
                                titleValueFromDAM="false"/>
                            <container4_copy_1970_26452752
