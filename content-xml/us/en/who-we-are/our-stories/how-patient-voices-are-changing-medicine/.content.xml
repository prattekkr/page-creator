                            <container4
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <title2
                                    cq:styleIds="[1659545825678,1651545824678,1651545825694]"
                                    jcr:lastModified="{Date}2024-04-15T10:25:57.378-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Understanding the value of patient centricity"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text2
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2022-12-05T11:16:06.476-05:00"
                                    jcr:lastModifiedBy="schafsm"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>How well are you able to carry out your usual social activities? How does your sleep issue affect your ability to do things with your family? Do you&lt;i>&amp;nbsp;feel&lt;/i>&amp;nbsp;like you’re getting better?&lt;br>&#xd;&#xa;&amp;nbsp;&lt;br>&#xd;&#xa;These questions may seem unusual, but the answers are critical in understanding a patient’s disease burden, specifically, the health-related quality of life impact of a treatment, according to one of AbbVie’s leaders in patient-centered outcomes research.&lt;br>&#xd;&#xa;&amp;nbsp;&lt;br>&#xd;&#xa;This leader may be new to AbbVie, but her focus in patient experience isn’t. Katy Benjamin, Ph.D., director, health economics and outcomes research, leverages her expertise in developing tools to measure treatment outcomes from the patients’ perspective. She digs into what patients think and feel, combining this valuable information with more traditional clinical data to understand the burden of disease and how our molecules and medicines may reduce that burden – ultimately, to help create better treatments for patients.&amp;nbsp;&lt;br>&#xd;&#xa;&amp;nbsp;&lt;br>&#xd;&#xa;We sat down with Katy to understand the role of the patient-centered research (PCR) group within AbbVie and how some critical insights are discovered outside of the lab.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-06-08T15:47:16.240-04:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-06-08T15:47:16.240-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title
                                    cq:styleIds="[1659545825678,1651545825694]"
                                    jcr:created="{Date}2022-12-05T11:18:05.321-05:00"
                                    jcr:createdBy="schafsm"
                                    jcr:lastModified="{Date}2024-04-15T10:26:08.591-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Understanding the value of patient centricity"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-05T11:19:28.341-05:00"
                                    jcr:createdBy="schafsm"
                                    jcr:lastModified="{Date}2022-12-05T11:19:39.338-05:00"
                                    jcr:lastModifiedBy="schafsm"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>How well are you able to carry out your usual social activities? How does your sleep issue affect your ability to do things with your family? Do you&lt;i>&amp;nbsp;feel&lt;/i>&amp;nbsp;like you’re getting better?&lt;br>&#xd;&#xa;&amp;nbsp;&lt;br>&#xd;&#xa;These questions may seem unusual, but the answers are critical in understanding a patient’s disease burden, specifically, the health-related quality of life impact of a treatment, according to one of AbbVie’s leaders in patient-centered outcomes research.&lt;br>&#xd;&#xa;&amp;nbsp;&lt;br>&#xd;&#xa;This leader may be new to AbbVie, but her focus in patient experience isn’t. Katy Benjamin, Ph.D., director, health economics and outcomes research, leverages her expertise in developing tools to measure treatment outcomes from the patients’ perspective. She digs into what patients think and feel, combining this valuable information with more traditional clinical data to understand the burden of disease and how our molecules and medicines may reduce that burden – ultimately, to help create better treatments for patients.&amp;nbsp;&lt;br>&#xd;&#xa;&amp;nbsp;&lt;br>&#xd;&#xa;We sat down with Katy to understand the role of the patient-centered research (PCR) group within AbbVie and how some critical insights are discovered outside of the lab.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-06-08T15:47:16.240-04:00"
                                    jcr:createdBy="chiucx"
