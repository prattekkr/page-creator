                        <par_12
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="wcm/foundation/components/parsys">
                            <container4
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <text2
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2022-12-09T14:17:26.124-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;i>In the “Magnified” series, we take a closer look at the life experiences &amp;amp; career journeys that have shaped AbbVie’s leaders. Meet Shuhong Zhang, our vice president of development sciences, a China native who blooms where she’s planted and brings a growth mindset to everything she does.&lt;/i>&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy_
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy
                                    cq:styleIds="[1651545825668,1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-09T14:18:37.416-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: You’re head of development sciences within our R&amp;D organization. What is your team’s role and goal?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"/>
                                <text_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-27T12:11:40.432-05:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>My team is the bridge that transforms molecules to medicine. Development sciences collaborates with many groups, including discovery research and operations. We work with discovery research teams to evaluate, select and formulate new candidate molecules. We also support manufacturing processes to produce clinical supplies of the candidates that meet the quality and distribution needs for our clinical trial sites globally. In partnership with the operations organization, we develop manufacturing processes and medication dosage forms to support the registration, approval and launch of new medicines to patients.&lt;/p>&#xd;&#xa;&lt;p>It’s an exciting time in my organization. We’re doing a lot of fine-tuning and collaboration as we invent new processes and technologies to achieve our goals and advance the pipeline.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__613734442
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy
                                    cq:styleIds="[1651545825668,1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-09T14:19:18.216-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: When did you know you were interested in a career in science?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"/>
                                <text_copy_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-09T14:19:29.708-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>It wasn’t obvious that I’d end up in science. As a teenager I was very interested in journalism because I enjoyed interacting with people and understanding their stories. I wanted to pursue that career until my high school literature teacher and mentor talked with me about the challenges I may face in China with career limitations. He suggested that I find a new field that would leverage my love of math, physics and puzzles. I thought to myself, what job has limitless potential and can tackle the big puzzles of the world – a scientist!&lt;/p>&#xd;&#xa;&lt;p>My five siblings and I were influenced by our parents. They built their careers around service to others, with my dad working for the government in China where I was raised and my mom as a medical doctor. They instilled in us that helping people is the right thing to do and that we needed to contribute to a broader society.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container4>
                            <quote_copy_copy
                                cq:styleIds="[1000000000000]"
                                jcr:created="{Date}2022-11-16T17:03:32.882-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2023-01-27T12:12:13.509-05:00"
                                jcr:lastModifiedBy="fusznx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/quote"
                                attributionName="Shuhong Zhang"
                                attributionTitle=" VP, Development Sciences, AbbVie"
                                quote="&quot;Resilience is being able to see success in failure.&quot;"
                                quoteType="regular"
                                textSize="h0"/>
                            <container4_copy
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <title_copy_copy
                                    cq:styleIds="[1651545825668,1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-09T14:21:29.919-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: You grew up in China. How did that experience shape the leader you are today?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"/>
                                <text_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-09T14:21:40.825-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>I grew up in the eastern part of China, in a small province north of Shanghai near the Yellow Sea. My parents were what you’d consider very traditional Chinese, emphasizing the need for a good education and to work really hard.&lt;/p>&#xd;&#xa;&lt;p>I have fond memories of how my mom would stay up late with me, holding a fan to keep the mosquitoes away so I could study. Her support and dedication helped me get into college. I moved to the U.S. after college with only 18 months of English language classes. From these experiences, I learned to be adaptable and resilient and that’s carried through to my career today.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__613734442
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy
                                    cq:styleIds="[1651545825668,1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-09T14:21:54.789-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: You mentioned resilience: What does that word mean to you and how you approach your work at AbbVie?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"/>
                                <text_copy_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-09T14:22:06.102-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Resilience is being able to see success in failure. Every time we test a hypothesis, we may not succeed. However, by nature, scientists have a curiosity and a desire to find out the “why.” We may learn and discover something new that will help us advance our understanding and our science. It’s our resilience that propels us forward and I am continually inspired by my colleagues, who share this same resolve.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy_
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy_968431554
                                    cq:styleIds="[1651545825668,1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-09T14:22:45.296-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: How does resilience impact your research and your areas of passion outside the office?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"/>
                                <text_copy_copy_copy_
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-09T14:23:06.936-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>I’m passionate about nature. My family and I visit many national parks to hike and explore. When I can’t get to a park, I still have a lot to keep me busy at home. I raise different types of trees, ones you can’t find in the nurseries and that aren’t native to where I live in Illinois.&lt;/p>&#xd;&#xa;&lt;p>I look at raising trees the same way I look at science: I do a lot of research and I bring a lot of optimism. I hope they all grow into big trees, but sometimes you fail and sometimes you succeed. It’s about rising to the challenge.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__1193155509
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy_1473594847
                                    cq:styleIds="[1651545825668,1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-09T14:23:37.666-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: How would you describe your leadership style?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"/>
                                <text_copy_copy_copy__2073827771
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-28T15:06:16.113-05:00"
                                    jcr:lastModifiedBy="schafsm"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>I'm a collaborative leader. My team works with so many other groups and our decisions can be big ones with an impact felt by many. It’s an inclusive approach. You have to always consider what’s best for the specific program, not just what’s best for your individual team.&lt;/p>&#xa;&lt;p>I also describe myself as a relationship-oriented leader. It’s imperative that I create and maintain ongoing relationships not just within R&amp;amp;D and my team but also with my fellow AbbVie leaders. When you build trusting relationships, it allows you to be open and incorporate diversity of thought during challenging situations.&lt;br>&#xa;&lt;br>&#xa;&amp;nbsp;&lt;/p>&#xa;&lt;p>&lt;a href=&quot;https://www.abbvie.com/our-science/our-rd-leaders/shuhong-zhang.html&quot; target=&quot;_blank&quot; title=&quot;Learn more about Shuhong&quot;>Learn more about Shuhong&lt;/a>&lt;/p>&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__585472023
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <text_copy_759260103_
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-23T16:46:55.248-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-27T12:13:20.140-05:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;span class=&quot;body-unica-20-reg&quot;>&lt;b>Media inquiries:&lt;/b>&lt;/span>&lt;br>&#xd;&#xa;&lt;a href=&quot;mailto:abbviemediarelations@abbvie.com&quot;>abbviemediarelations@abbvie.com&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container4_copy>
                        </par_12>
