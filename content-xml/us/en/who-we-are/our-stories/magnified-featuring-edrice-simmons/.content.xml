                        <par_12
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="wcm/foundation/components/parsys">
                            <container4
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <text2_copy
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2023-10-27T15:40:27.096-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;i>In the “Magnified” series, we take a closer look at the life experiences &amp;amp; career journeys that have shaped AbbVie’s leaders. In this episode, we drop in on Edrice Simmons, AbbVie’s vice president of U.S. commercial oncology. Explore how her inclusive leadership style and appreciation for what makes each us different drove her to the helm of one of AbbVie’s largest commercial teams.&lt;/i>&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy_
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-10-27T15:49:11.262-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: Tell us about your upbringing."
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-10-27T15:50:47.021-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>I grew up on a farm in a rural town in Indiana called Noblesville. My mom was trained as a chemist but worked in finance for the Army, and my dad was an engineer. We were one of the first brown families to live in our town, and because we looked different, we weren’t always accepted. But we never let that deter us. We remained close as a family and traveled a lot because of my mom’s work and that gave us opportunities to see and experience different cultures and people. I see that as one of the real strengths of how I grew up: though we lived in a place where we weren’t always accepted, we grew up appreciating difference.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container4>
                            <quote_copy_copy
                                cq:styleIds="[1000000000000]"
                                jcr:created="{Date}2022-11-16T17:03:32.882-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2023-10-27T15:58:40.212-04:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/quote"
                                attributionName="Edrice Simmons"
                                attributionTitle="VP U.S. Commercial Oncology, AbbVie"
                                quote="I know what it feels like to feel left out or like you don’t belong, and I work to create a space where no one ever feels that way."
                                quoteType="regular"
                                textSize="h0"/>
                            <container4_copy_copy
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <separator_copy
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-10-27T15:51:24.659-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: What led you to a career in pharma?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-11-08T17:29:06.515-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>For me it all started when I was seven years old. I was on the way to school in Indianapolis and passed by a building with these big bold red letters that spelled &amp;quot;Lilly.&amp;quot; I asked my mom what the building was and she said that’s where she used to work as a chemist, and that it was a place where they make medicine to help people feel better. At that point I made up it in my mind - I was going to work there. Though I was just a child and didn’t really understand what it meant to develop medicines or really drive a business, this idea of being able to help people just resonated with me. So from seven years old until I finally joined the company in my twenties, that was my goal.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-10-27T15:51:43.425-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: How did your career journey progress and eventually lead you to AbbVie?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text_563117609
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:02:32.555-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-10-27T15:51:56.200-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>I went to college to study medical social work, which focused on helping people who were in hospitals transition home. After that, I went on to get a business degree, then started working in sales at Eli Lilly. After 16 years there, working a range of different roles, I found an opportunity to make even a greater impact on patients here at AbbVie and that opportunity brought me here.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy_
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-10-27T15:52:09.244-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: At AbbVie, you’ve worked across immunology, oncology, aesthetics and other therapeutic areas. How did you navigate these different career opportunities?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text_563117609_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:02:32.555-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-11-08T17:29:31.135-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>At different stages in my career, I either took a leap, broadened my view or charted the course. When I’ve taken leaps, those were moments that felt like jumping into cold water, diving into something totally new and trusting myself to figure out how to swim once I landed. Moving to California during COVID was one of those moments when fear set in but rising to the challenge and joining the Aesthetics Family was a memorable experience I will cherish.&lt;/p>&#xd;&#xa;&lt;p>When I’ve taken the scenic route to broaden my view, it’s been about pursuing a non-linear path to gain experiences and knowledge that would help me accelerate elsewhere faster. And charting the course for me really means progressing along the traditional career path.&lt;/p>&#xd;&#xa;&lt;p>At each stage, I’ve gained new knowledge, skills or perspectives that have helped me be a better leader. The key thing is to know where you are and where you want to be. From there, you can figure out what you need to do to close the gap, whether that means continuing to chart the course or deciding it’s time to take a detour or make a leap.&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container4_copy_copy>
                            <quote_copy_copy_copy
                                cq:styleIds="[1000000000000]"
                                jcr:created="{Date}2022-11-16T17:03:32.882-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2023-10-27T15:53:13.740-04:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/quote"
                                quote="My personal vision for my life is to help people reach their full potential."
                                quoteType="regular"
                                textSize="h0"/>
                            <container4_copy_copy_1865269900
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <separator_copy
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-10-27T15:53:35.558-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: Today you lead U.S. commercial oncology. As a commercial leader, how would you describe your team’s impact on patients?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-10-27T15:54:00.676-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Our mission in commercial is to accelerate demand for our life changing-medicines. My team is responsible for ensuring that our hematology portfolio realizes its full value for patients and AbbVIe. It is also critical to uncover what is next, where we are is promising; however, we must be relentless to pursue the next generations of treatments because the lives of patients depend on it.&lt;/p>&#xd;&#xa;&lt;p>We all want every patient who's living with cancer to have as much time off treatment while extending their quality of life to look forward to their next birthday, vacation or graduation.&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-10-27T15:54:18.551-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: How would you describe the way you lead?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text_563117609
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:02:32.555-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-10-27T15:54:28.931-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>I think what my teams would say is that I’m a purpose-driven leader. I focused on getting teams to really connect to a greater purpose. Here, we’re reaching patients who are very sick and often very isolated, and our purpose is to make sure that we can transform their lives for the better. Keeping that at the forefront of my teams' minds is what I strive to do.&lt;/p>&#xd;&#xa;&lt;p>I would also say that I strive to be inclusive in how I lead. Because of my childhood experience, I know what it feels like to feel left out or like you don’t belong, and I work to create a space where no one ever feels that way.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy_
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-10-27T15:54:40.485-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: What keeps you motivated in your work?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text_563117609_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:02:32.555-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-10-27T15:54:49.599-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>My personal vision for my life is to help people reach their full potential. Working to understand what motivates each person I work with—and help them reach their potential based on those drivers—motivates me.&lt;/p>&#xd;&#xa;&lt;p>I'm also driven by the purpose-driven impact that we make with our medicines. At end of my life, I want to be able to look back and say that I made a meaningful impact on someone's life or extended the quality of their life, helped them reach their potential or gave them a voice. Those are things that really motivate me.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__2080598940
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <text_copy_759260103
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-23T16:46:55.248-05:00"
