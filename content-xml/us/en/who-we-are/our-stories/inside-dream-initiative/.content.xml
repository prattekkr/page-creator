                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>Why we’re reimagining beauty standards in the aesthetics industry.&lt;/span>&lt;/span>&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
