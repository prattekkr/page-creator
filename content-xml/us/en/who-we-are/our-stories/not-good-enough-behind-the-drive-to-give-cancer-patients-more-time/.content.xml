                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                jcr:title="SEER Cancer Data Base; ONCrg. &lt;sup>3&lt;/sup> *All survival rates are 1L metastatic. "
