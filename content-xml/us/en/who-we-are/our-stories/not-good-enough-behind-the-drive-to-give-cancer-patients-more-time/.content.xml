                            <container4_copy_copy
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <separator
                                    cq:styleIds="1662756423318"
                                    jcr:created="{Date}2023-12-20T16:04:22.471-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-12-20T16:04:22.471-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <text
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:created="{Date}2023-12-20T16:04:24.956-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-01-03T13:40:53.288-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;b>Daejin:&lt;/b>&lt;br>&#xd;&#xa;We’re evaluating this target using ADCs, which is a specialized targeted cancer treatment designed to deliver a cancer killing drug directly into cancer cells. ADCs combine the specificity of a monoclonal antibody, which targets cancer cells by recognizing and binding to unique markers on their surface, linked to a cytotoxic drug payload. Once bound to the cancer cell, the ADC is internalized and broken down, releasing the drug and killing the cancer cell from within.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_1218674558
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-12-20T12:17:22.737-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-12-20T12:17:22.737-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title2_copy_copy_cop
                                    cq:styleIds="[1659545825678,1651545824678,1651545825668]"
                                    jcr:lastModified="{Date}2023-12-20T12:20:25.821-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: What’s AbbVie’s approach to immunotherapy?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text2_copy_copy_copy_2109424958
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2024-01-03T13:41:23.893-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;b>Daejin:&lt;/b>&lt;br>&#xd;&#xa;Our aim in immunotherapy is to target the tumor microenvironment and improve the effect of the immune system on cancer cells. In an ideal world, your immune system is designed not only to fight against infectious diseases, but also to manage and treat cancer. Cancer finds ways to hijack those natural mechanisms so that it can survive beyond the immune system. Immunotherapy targets the pathways that the cancer takes, mobilizing your own immune system to recognize and  destroy the cancer where it is.&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_12186
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-12-20T12:17:22.737-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-12-20T12:17:22.737-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title2_copy_copy_cop_793603127
                                    cq:styleIds="[1659545825678,1651545824678,1651545825668]"
                                    jcr:lastModified="{Date}2023-12-20T12:20:55.362-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: How do you navigate the challenges of developing effective cancer medicines, especially considering the slow pace of progress across the industry?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text2_copy_copy_copy_2039407815
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2024-01-03T13:43:18.654-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;b>Pedro:&lt;/b>&lt;br>&#xd;&#xa;Beyond having incredible science, we also have to take a unique approach to how we do our work. We’re focused on four principles. One is speed. We need to go fast for patients. Two, we’re also driving agility. We must pivot as soon as we get data since the technology is moving rapidly. Three, we need to be bold and make sure we are creating novel ideas. And last, but not least, we are focused. We need to think night and day about delivering value to patients.&lt;br>&#xd;&#xa;&lt;b>&lt;br>&#xd;&#xa; Daejin:&lt;/b>&lt;br>&#xd;&#xa;What drives me every day to do what I do are the people we serve, which are patients. This extends beyond my background as a physician. We all have either had a family member, a friend, or know of someone who has been affected by cancer. And what drives me is recognizing that the work we do can bring benefit and change the lives of people who are affected by cancer. We want to not only find new treatment options but ultimately our goal is to find a cure.&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;b>Pedro:&lt;/b>&lt;br>&#xd;&#xa;On my office wall is a picture that reminds me of my dad. He passed away from cancer. I cannot wait to find a way to give hope for cancer patients like my father and extend survival for them. That’s why we’re here. &lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_12186_749711391
                                    cq:styleIds="[1662756502570]"
                                    jcr:created="{Date}2023-12-20T12:17:22.737-05:00"
                                    jcr:createdBy="chiucx"
