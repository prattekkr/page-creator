                                textIsRich="true"/>
                            <container4_copy
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <separator_copy_19127
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-12-20T12:17:22.737-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-12-20T12:17:22.737-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <text2
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2023-12-20T12:15:19.560-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>In addition to low survival rates, the treatment itself can often feel worse than the disease. Chemotherapy, radiation, surgery, and the accompanying side effects are still hallmarks of cancer treatment – impacting patients, their families and the quality of time that may already be limited.&lt;br>&#xd;&#xa; &lt;br>&#xd;&#xa;AbbVie’s solid tumor oncology team is looking to change the narrative, with their sights set on transforming outcomes for patients, including the goal of finding a cure. Two leaders of the team sat down to share more about their approach, their progress, and their passion for giving patients more time. &lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_1912747915
