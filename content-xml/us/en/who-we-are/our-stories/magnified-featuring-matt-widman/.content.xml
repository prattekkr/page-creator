                        <par_12
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="wcm/foundation/components/parsys">
                            <container4
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <text2_copy
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2022-11-30T21:09:32.719-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;i>With a passion for problem solving and a background in analytical chemistry, Matt Widman, vice president, patient services, now leads a team that serves as the touchpoint to the patient at AbbVie. Widman carries a unique empathy for the patient and their families because of his own personal loss, and that fuels him to ensure patients diagnosed with some of the most challenging conditions feel empowered and can reach their full treatment potential. &lt;/i>&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy_
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy
                                    cq:styleIds="[1651545825668,1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-30T21:12:43.645-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: You started your professional career as a bench scientist – a very different area than where you are today. Why did you want to be a chemist? "
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"/>
                                <text_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-27T11:04:25.546-05:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>I love solving problems, and it all resonated with me during my first high school chemistry class. I am analytical. I like math. I like science. I like numbers. Chemistry to me was having  the ability to solve very large, complex issues and synthesizing them down to a way you can understand. Once I went down that road, I never looked back. &lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__671170804
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-27T11:00:23.866-05:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: Did  you have any  role models in science or medicine to lean on as you pursued a chemistry degree and career?  "
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text_copy_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-30T21:14:17.538-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>It was a path I paved for myself. I was the first in my family to go to college. It was uncharted territory because there was a lot of responsibility for me to achieve success. While my friends and family couldn’t guide me specifically on this career path, what I’ve always taken away from them is how to treat others. I think when you work hard and do what’s right for others and for yourself, you’ll find a recipe for success&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__1702681535
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy_1612011726
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-27T11:00:53.501-05:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: Your career headed into a new direction when you left R&amp;D  as a chemist  and pursued your MBA.  What was that transition like?  "
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text_copy_copy_copy_
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-30T21:15:11.430-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>When I went from an analytical chemist to a research chemist, I really enjoyed being more involved in the strategy, innovation and design of new experiments compared to repetitive sequence experiments on the bench. I made a choice to go to business school so that I could expand my knowledge and skills. After getting my MBA, I took on new roles in the area of strategic marketing, commercial development, program management and operations. I also spent time in a global marketing role which gave me a better understanding of how we work around the world to bring our innovative medicines to patients.  Here, I experienced working with many different cultures, operating models, health systems, and strategies. The one thing that was similar was the commitment to our patients and making a remarkable impact on their lives.  &lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container4>
                            <quote_copy_copy
                                cq:styleIds="[1000000000000]"
                                jcr:created="{Date}2022-11-16T17:03:32.882-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2023-01-27T11:11:04.994-05:00"
                                jcr:lastModifiedBy="fusznx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/quote"
                                attributionName="Matt Widman"
                                attributionTitle="Vice President, Patient Services, AbbVie"
                                quote="We take time to understand what patients are going through. We listen to them, and we learn from them."
                                quoteType="regular"
                                textSize="h0"/>
                            <container4_copy_copy
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <separator_copy
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-27T11:01:23.850-05:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: Your career took another turn to create a group that supports patients who are prescribed AbbVie medicines.  What does this work look like for you each day? "
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-27T11:05:18.445-05:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Everything we do at AbbVie is for the patient. They are our North Star, no matter where you sit in the company, and about 10  years ago, I was tapped  to  establish what is now our Patient Services organization.  We have come a long way in that time to build what we view as a best-in-class organization that supports patients on AbbVie medications  while on their prescribed treatment journey.  We take the time to understand what patients are going through. We listen to them, and we learn from them. We provide education and resources that help patients navigate their prescribed treatment journey, which can often be complex and frustrating, and we do it in an empathetic and caring way.&lt;/p>&#xd;&#xa;&lt;p>Imagine being diagnosed with cancer and the shock you feel and the questions you might have, along with the work that might need to be done to figure out how your insurance covers the medication. In Patient Services, we develop a series of strategies and tactics to help patients navigate their prescribed treatment journey and help them achieve the best possible treatment outcome. A lot of the approach and thought process is very similar to being in a lab and solving a complex experiment.  &lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-27T11:01:44.573-05:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: You personally understand the emotional roller coaster patients and their families experience. Does that  give you a different perspective of how to support patients?  "
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text_563117609
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:02:32.555-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-27T11:02:23.838-05:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>I’ve experienced what caregivers go through when a loved one is diagnosed, and my wife and I have felt that pain in one of the worst ways when our 3-year-old son was diagnosed with neuroblastoma. He fought it for 15  months but  passed away. At the time I was very angry  and  broken. Over the years, I reflected on all the health care and support that we received along the way and have gained so much respect and gratitude for health care providers and  the pharmaceutical industry who work to provide patients and their families hope and a chance to live life to the fullest. At AbbVie, we describe our work as purposeful and it’s that mindset that fuels our passion to be here for patients every single day.   &lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy_
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-27T11:06:06.982-05:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: How do you describe your leadership style with a team that carries so much responsibility  for what they do for patients? "
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text_563117609_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:02:32.555-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-27T11:06:34.702-05:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>I am so lucky to lead a group of people who are just as passionate and committed to supporting our patients as I am. They come from different backgrounds, have different skill sets, and have different perspectives. As someone who is inclusive and who tries to be authentic with my team, I want to hear their ideas and I want them to know where I stand because at the end of the day, we want what’s best for patients. What patients needed last year could be different from this year and even five years from now. We’re always listening and we’re always problem solving. &lt;br />&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__2080598940
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <text_copy_759260103
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-23T16:46:55.248-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-27T11:07:12.126-05:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;span class=&quot;body-unica-20-reg&quot;>&lt;b>Media inquiries:&lt;/b>&lt;/span>&lt;br>&#xd;&#xa;&lt;a href=&quot;mailto:abbviemediarelations@abbvie.com&quot;>abbviemediarelations@abbvie.com&lt;/a>&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container4_copy_copy>
                        </par_12>
