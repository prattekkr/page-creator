                                jcr:title="The Power of Partnership: An Innovative Approach to Improve Maternal Health"
                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                type="h1"
                                variant="h"/>
                            <text
                                cq:styleIds="[1659545825678,1659545835858,,]"
                                jcr:lastModified="{Date}2025-12-09T17:17:39.469-05:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>A collaborative pilot creates an ecosystem of support advancing health equity in underserved communities.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </container3>
                    </container2>
                    <grid
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="abbvie-com2/components/grid/v2/grid"
                        rowCount="1">
