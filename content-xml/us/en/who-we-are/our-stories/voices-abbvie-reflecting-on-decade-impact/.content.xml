                            sling:resourceType="wcm/foundation/components/parsys">
                            <container4
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <title2
                                    cq:styleIds="[1659545825678,1651545824678,1651545825692]"
                                    jcr:lastModified="{Date}2024-05-08T09:37:27.742-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Looking toward a bright future"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text2
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2023-01-06T18:37:13.128-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Since our inception in 2013, we’ve focused on taking on tough health challenges to make a real difference in people’s lives. In the past 10 years, we’ve invested over $50 billion to research, develop and discover new medicines and solutions. We’ve also expanded to over 50,000 employees who are focused every day on making a remarkable impact that lasts.&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;While we have made great progress, it’s only the beginning. As we recognize a decade of impact, we turned to our employees around the globe to reflect on what motivates their work, how culture plays a part and what they see for the future of our company.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container4>
                            <video
                                cq:styleIds="[1]"
                                jcr:created="{Date}2023-01-06T18:37:28.508-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2023-09-08T13:00:39.865-04:00"
                                jcr:lastModifiedBy="singarx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/video/v2/video"
                                autoPlay="true"
                                brightcoveAutoPlay="false"
                                btnText="Watch 1:46"
                                descriptiveIframeTitle="Voices of AbbVie: Reflecting on a Decade of Impact"
                                fileReference="/content/dam/abbvie-com2/images/stories/voices-abbvie-reflecting-on-decade-impact/voices-of-abbvie-video-thumbnail.jpg"
                                loopVideo="false"
                                showBrightcoveControls="false"
