                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Throw yourself into every opportunity and experience that’s offered to you. Make sure you’re having fun along the way, and that you love what you're doing. The rest will fall into place.&lt;/p>&#xd;&#xa;"
