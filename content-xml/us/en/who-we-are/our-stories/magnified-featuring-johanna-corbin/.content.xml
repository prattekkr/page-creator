                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>From practicing science to practicing law, follow the unique career journey of Johanna Corbin, senior vice president, chief patent and innovation counsel.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
