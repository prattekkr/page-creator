                        <par_12
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="wcm/foundation/components/parsys">
                            <container4
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <text2_copy
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2022-11-30T22:05:36.776-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;i>Linda Scarazzini, vice president, pharmacovigilance &amp;amp; patient safety, has had two drivers throughout her scientific career and her life: curiosity and kindness. Today, that same enthusiasm is foundational to how she develops new leaders and creates an inclusive culture where everyone can thrive.&lt;/i>&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy_
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy
                                    cq:styleIds="[1651545825668,1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-30T22:06:20.515-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: Your career has spanned all areas of science, from pharmacist to clinical researcher to FDA leader. When did your interest in science start?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"/>
                                <text_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-30T22:07:19.890-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>I don’t know if I was born with an interest in science, but I was born with a curiosity of how things work. My parents nurtured this in me in different ways. My father was a builder and would spend hours working with me on my erector sets, building different structures with the precise support. My mother constantly encouraged me to keep reading, exploring, and expanding my world. She would sit with me for hours, helping with my biology homework and encouraging me to pursue my passion: science.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__1979954844
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy
                                    cq:styleIds="[1651545825668,1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-30T22:07:05.459-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: You went to the Philadelphia College of Pharmacy and eventually the Lewis Katz School of Medicine at Temple University. Why did you go that route?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"/>
                                <text_copy_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-30T22:07:38.633-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>I chose pharmacy school for a few reasons: first, I spent a lot of time at my friend’s parents’ pharmacy and saw how a local pharmacy was an important point of interaction in the community. Second, pharmacy school appealed to my natural intuition for order and accuracy. Lastly, it was a way for me to exercise my scientific curiosity. It was in pharmacy school that I began to deeply understand how medications work and how to explain benefits and risks to patients. It was a practical, meaningful stepping stone toward medical school.&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__381220425
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy_1142776816
                                    cq:styleIds="[1651545825668,1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-30T22:08:09.360-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: At what point did you move in the specific direction of pharmaceutical safety?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"/>
                                <text_copy_copy_copy_
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-30T22:08:49.035-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>My internal medicine residency was at Graduate Hospital of the University of Pennsylvania during the height of the HIV-AIDS epidemic. I had the privilege of working with clinicians and researchers in this area, helping treat patients who were waiting for life-altering therapies. I experienced first-hand the impact of drug development on patients’ lives. So, when I was approached to transfer my skills as a practicing physician to that of a pharmacovigilance team in the pharmaceutical industry, I was intrigued. Even though I wasn’t completely sure what pharmacovigilance was, my soon-to-be-boss assured me that my knowledge of clinical research, medical training, and curiosity were the elements she was looking for. She gave me a chance, and 20 years later – here I am. Even today, when I’m hiring new team members, I bring that same mindset. If you have curiosity, varied experiences, and an open mind, you will be a strong asset to my diverse team.&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__1497650312
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy_722318736
                                    cq:styleIds="[1651545825668,1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-30T22:09:20.740-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: How do you explain what you do in pharmacovigilance to friends and family?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"/>
                                <text_copy_copy_copy__1414259895
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-30T22:09:37.864-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>I tell them that I collect, analyze, interpret, and communicate information about the safety of medicines. Basically, we&amp;nbsp;&lt;i>do safety, so you don’t have to&lt;/i>. I think COVID-19 has made it that much easier to explain the importance of my work. Family and friends have been asking how to discern facts from fiction. They look to me to clearly explain what publications and clinical research findings really mean, so they have the knowledge and confidence to make informed decisions about treatments and vaccines. I try to tailor my advice so that they can make their own choices based on their individual risk profile and real-time data.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__1077831014
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy_1987623609
                                    cq:styleIds="[1651545825668,1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-30T22:10:10.351-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: You’ve been getting useful information into patients’ hands for decades. Where did that start?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"/>
                                <text_copy_copy_copy__557072852
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-30T22:10:25.135-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>During my undergraduate program at the Philadelphia College of Pharmacy, I joined a community-based project called Brown Bag Saturdays. Residents from the surrounding neighborhood would bring their medication to a park across the street from my school. My peers and I would review their different prescriptions and talk to them about their medications. We listened to their concerns without judgment and answered their questions about the benefits and risks. It was at that time that I realized the importance of social determinants of health, including health literacy, as important factors that affect medication adherence.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__432335246
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy_2086561883
                                    cq:styleIds="[1651545825668,1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-30T22:10:49.614-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: The FDA was quite the pivot, as they’re responsible for protecting people by ensuring the safety, efficacy, and security of therapies. What was that experience like?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"/>
                                <text_copy_copy_copy__2028649661
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-30T22:11:09.512-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>I like to say that I’ve looked at drugs from all sides now: from patient, to pharmacist, to physician, to industry, to regulatory agency and back to industry. My FDA experience was pivotal in my career. There, I learned about public health from my colleagues, who had dedicated their careers to public service. I also learned about the responsibility that leaders have to communicate simply, transparently, and effectively.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container4>
                            <image
                                jcr:created="{Date}2022-11-30T22:12:10.890-05:00"
                                jcr:createdBy="sharmrx18"
                                jcr:lastModified="{Date}2022-11-30T22:20:55.030-05:00"
                                jcr:lastModifiedBy="sharmrx18"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/image/v2/image"
                                altValueFromDAM="true"
                                displayPopupTitle="true"
                                fileReference="/content/dam/abbvie-com2/images/stories/body_Magnified_Linda_Scarazzinie_1750x1400_low.jpg"
                                isDecorative="true"
                                titleValueFromDAM="true"/>
                            <text_copy_copy_copy_
                                cq:styleIds="[1659545825678]"
                                jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2022-11-30T22:19:24.751-05:00"
                                jcr:lastModifiedBy="sharmrx18"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>A subtle reminder that each person, each patient matters.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <container
                                cq:styleIds="[1653545825687,1653545847150,1653545835982,1653242825678]"
                                jcr:created="{Date}2022-12-21T14:09:34.790-05:00"
                                jcr:createdBy="schafsm"
                                jcr:lastModified="{Date}2022-12-21T14:09:34.790-05:00"
                                jcr:lastModifiedBy="schafsm"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <separator_copy_copy_
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy_1402002637
                                    cq:styleIds="[1651545825668,1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-30T22:21:40.375-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: You have a lot of items on your desk. Is each one special to you?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"/>
                                <text_copy_copy_copy__137914307
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-30T22:22:40.826-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>There is a small rock on my desk that has the number 22 written on it. A military veteran who worked on my team at AbbVie gave it to me to let me know he was not going to be one of the 22 veterans estimated to take their own life each day. He said that his career at AbbVie gave him a sense of purpose and belonging. I look at that rock every time I sit at my desk and reflect on my own sense of purpose and belonging. Not only here at AbbVie, but in the world.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <title_copy_copy_copy
                                    cq:styleIds="[1651545825668,1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-30T22:22:35.695-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: How do you describe your leadership style today?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"/>
                                <text_copy_copy_copy_
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-30T22:24:20.077-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
