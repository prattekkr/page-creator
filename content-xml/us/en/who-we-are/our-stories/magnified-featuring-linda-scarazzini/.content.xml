                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>A closer look at the life experiences &amp;amp; career journeys that have shaped AbbVie’s leaders – like our head of pharmacovigilance &amp;amp; patient safety.&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
