                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>Learn how AbbVie is working to reimagine the standards of care for patients with autoimmune diseases &lt;/span>&lt;/span>&lt;/p>&#xa;"
                                textIsRich="true"/>
