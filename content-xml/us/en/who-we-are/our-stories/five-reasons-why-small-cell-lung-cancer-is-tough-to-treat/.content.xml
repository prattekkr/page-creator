                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2023-05-04T21:35:42.808-04:00"
                                    jcr:createdBy="SCHAFSM"
                                    jcr:lastModified="{Date}2023-06-09T12:22:27.972-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="3. Stage of diagnosis"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text2_copy_copy
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2023-06-09T12:22:37.146-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Small cell lung cancer grows quickly and symptoms may seem run of the mill until they worsen. By the time of diagnosis, the majority of people with SCLC may have an advanced stage of the disease, which has a very low survival rate.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_892772230
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-06-09T12:22:11.793-04:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-06-09T12:22:11.793-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2023-05-04T21:35:42.808-04:00"
                                    jcr:createdBy="SCHAFSM"
                                    jcr:lastModified="{Date}2023-05-13T01:03:27.218-04:00"
                                    jcr:lastModifiedBy="SCHAFSM"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="4. Resistance to treatments"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text2_copy
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2023-05-04T21:43:04.777-04:00"
                                    jcr:lastModifiedBy="SCHAFSM"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Small cell lung cancer initially responds well to radiation and chemotherapy, improving symptoms and shrinking tumors. What remains a mystery is that SCLC develops resistance to these treatments and comes back quickly.&lt;sup>4&lt;/sup>&lt;/p>&#xa;"
                                    textIsRich="true"/>
                            </container4_copy>
                            <quote
                                cq:styleIds="[1000000000000]"
                                jcr:created="{Date}2023-05-04T21:42:26.170-04:00"
                                jcr:createdBy="SCHAFSM"
                                jcr:lastModified="{Date}2023-05-04T21:43:56.231-04:00"
                                jcr:lastModifiedBy="SCHAFSM"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/quote"
                                attributionName="Phillip Komarnitsky, M.D."
                                attributionTitle="senior medical director, AbbVie"
                                quote="Most patients respond very well to initial treatment. It seems like it’s good news and it is good news, but it is good news for a very short period of time. By six months from the start of treatment, it’s back to square one for the majority of patients."
                                quoteType="regular"
                                textSize="h0"/>
                            <container4_copy_copy
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <separator
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-05-04T21:36:06.400-04:00"
                                    jcr:createdBy="SCHAFSM"
                                    jcr:lastModified="{Date}2023-05-04T21:36:06.400-04:00"
                                    jcr:lastModifiedBy="SCHAFSM"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2023-05-04T21:35:42.808-04:00"
                                    jcr:createdBy="SCHAFSM"
                                    jcr:lastModified="{Date}2023-05-13T01:02:46.082-04:00"
                                    jcr:lastModifiedBy="SCHAFSM"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="5. New treatments for the toolbox needed"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text2_copy
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2024-07-11T11:21:40.900-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Nearly all SCLC patients relapse after their first-line treatment, chemotherapy, and have only one U.S. Food and Drug Administration-approved option for second-line treatment, with no approved options for third-line treatment of the disease.&lt;/p>&#xd;&#xa;&lt;p>Researchers continue to add to the understanding of how SCLC grows and the new ways doctors might be able to treat it. One example is immunotherapies, which work in other types of cancer like non-small cell lung cancer by reactivating the immune system’s response so that it will find and destroy cancer cells. Studies are examining the effectiveness of immunotherapies in SCLC, particularly in combination with other treatments.&lt;/p>&#xd;&#xa;&lt;p>While SCLC is tough to treat today, researchers are forging ahead with more than 700&amp;nbsp;&lt;a href=&quot;https://clinicaltrials.gov/ct2/home&quot; target=&quot;_blank&quot; title=&quot;Clinical studies&quot;>clinical studies&lt;/a>&amp;nbsp;seeking new ways to treat this devastating disease and break the slow news cycle for good.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-05-04T21:36:06.400-04:00"
                                    jcr:createdBy="SCHAFSM"
                                    jcr:lastModified="{Date}2023-05-04T21:36:06.400-04:00"
                                    jcr:lastModifiedBy="SCHAFSM"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
