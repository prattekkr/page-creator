                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>Researchers continue to bring into focus the reasons why small cell lung cancer is tough to treat and what can be done about it.&lt;/span>&lt;/span>&lt;/p>&#xa;"
                                textIsRich="true"/>
                        </container3>
                    </container2>
