                                jcr:title="Noah Tu, M.S., senior scientist, discovery chemistry and technologies, AbbVie, holds up a jar of ChemBeads. In this jar alone, there are approximately 500,000 ChemBeads."
                                sling:resourceType="abbvie-com2/components/image/v2/image"
                                alt="Noah Tu, M.S., senior scientist"
                                altValueFromDAM="false"
                                displayPopupTitle="false"
