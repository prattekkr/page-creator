                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>Discovering a new medicine isn’t easy. When robots couldn’t help, three scientists found a way.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
