                        <par_12
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="wcm/foundation/components/parsys">
                            <container4
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <text2
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2023-04-25T12:10:35.153-04:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;i>In the “Magnified” series, we take a closer look at the life experiences and career journeys that have shaped AbbVie’s leaders. Meet Nicholas Donoghoe, our R&amp;amp;D chief operating officer. Nicholas knew he wanted to be a doctor for as long as he can remember, but never imagined he’d end up helping change medicine for the better on a global scale. See how his journey put this father of two on the path to becoming our R&amp;amp;D chief operating officer.&lt;/i>&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-02-27T12:43:31.343-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-04-18T17:57:30.239-04:00"
                                    jcr:lastModifiedBy="SCHAFSM"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-04-24T17:25:33.380-04:00"
                                    jcr:lastModifiedBy="SCHAFSM"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: You knew at a young age you wanted to be a physician. What sparked your interest in the field? "
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text2_copy
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2023-04-24T16:52:00.361-04:00"
                                    jcr:lastModifiedBy="SCHAFSM"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>I knew for as long as I can remember that I wanted to be a physician and one of the people I was inspired by was a pioneering, early obstetrician-gynecologist in our family in Louisville, Kentucky. I grew up hearing stories about him, and the impact he had on the entire region where my mom and dad were both born. That ability to apply emerging science to change the lives of generations fascinated me, even at a young age.&lt;/p>&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy_1979729123
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-02-27T12:43:31.343-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-02-27T12:43:31.343-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-04-25T11:45:09.456-04:00"
                                    jcr:lastModifiedBy="SCHAFSM"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: You attended John Hopkins Medical School in Baltimore but then transitioned to a career with McKinsey. What prompted that change?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text2_copy_copy
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2023-04-25T11:57:22.875-04:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>While in medical school, I was lucky enough to work with mentors on developing new surgical techniques and devices. That experience got me really interested in how to go from a challenge in the operating room, to an idea for a product, to actually making a new device and changing clinical practice, which was a total mystery to me. So, I joined McKinsey to figure out how to do that. &amp;nbsp; &amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>At McKinsey I got to work with impressive teammates from many different backgrounds, from Ph.D.s to lawyers to physicists, to solve complex business challenges. The art of problem solving with clients to advance healthcare really captured my imagination. So, after I graduated medical school, I chose to stay with McKinsey and one year turned into two, which eventually turned into 10 more. This experience let me work across five continents on countless different challenges and really see what it took to innovate in medicine from many perspectives. &amp;nbsp;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container4>
                            <quote
                                cq:styleIds="[1000000000000]"
                                jcr:created="{Date}2023-04-24T16:26:53.191-04:00"
                                jcr:createdBy="SCHAFSM"
                                jcr:lastModified="{Date}2023-04-25T11:40:04.957-04:00"
                                jcr:lastModifiedBy="fusznx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/quote"
                                attributionName="Nicholas Donoghoe, M.D. "
                                attributionTitle="SVP, R&amp;D Chief Operating Officer"
                                quote="The opportunity to work across the R&amp;D continuum – from early clinical, to launch and life cycle management – is an incredible privilege and what excites me every morning to go to work."
                                quoteType="regular"
                                textSize="h0"/>
                            <container4_copy
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <separator_copy_copy
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-02-27T12:43:31.343-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-02-27T12:43:31.343-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-04-24T16:29:00.784-04:00"
                                    jcr:lastModifiedBy="SCHAFSM"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: How did you transition to working at AbbVie and how has your career evolved since? "
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text2_copy
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2023-04-25T11:48:28.105-04:00"
                                    jcr:lastModifiedBy="SCHAFSM"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>While at McKinsey, I had a chance to work with Abbott in the early days of preparing to launch AbbVie and set its own course as a new company. I saw leadership’s commitment to patients and its investment to continue raising standards of care. I was very impressed by AbbVie's ability to bring innovative therapies in immunology, oncology and infectious disease to patients across the globe. That ability to touch millions of lives each year, on a truly global scale, across so many therapeutic areas is something I could never have done practicing medicine.&lt;/p>&#xa;&lt;p>Ultimately though, what led me to join AbbVie was my wife. On the flight home from our honeymoon, she asked what would become a life-changing question, “why aren’t you working at AbbVie? It's obvious how much you love them.” She was absolutely right and as soon as we landed, I began discussing the opportunity to join and create a new group called the Innovation team. &amp;nbsp;&lt;/p>&#xa;&lt;p>Since then, I've had a chance to work in several different roles across our commercial and R&amp;amp;D organizations and in our aesthetics and therapeutics businesses. Each of these experiences helped me to see new connections across the business and to continually ask how we can find new ways of working together to accomplish amazing things.&lt;/p>&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy_1328488393
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-02-27T12:43:31.343-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-02-27T12:43:31.343-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-04-24T16:29:22.402-04:00"
                                    jcr:lastModifiedBy="SCHAFSM"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: Within our R&amp;D organization, what are your teams focused on? "
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text2_copy_copy
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2023-04-24T16:56:19.218-04:00"
                                    jcr:lastModifiedBy="SCHAFSM"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>I have a chance to work with many groups across R&amp;amp;D to build, deliver and launch our pipeline. As a company we realize that great ideas can occur anywhere so our search and evaluation, business development and alliance management teams work together to bring in transformative medicines.&lt;/p>&#xa;&lt;p>Whether a medicine is discovered in our labs or brought in through external innovation, we are uniquely positioned to develop these medicines with our in-house clinical development operations (CDO) and innovation teams. &amp;nbsp;Every day they are finding new ways of enrolling people in our trials and generating the evidence we need to gain approvals and access across the globe. &amp;nbsp;&lt;/p>&#xa;&lt;p>At this point our global and U.S medical affairs organizations, as well as health economics and outcomes research (HEOR), transformation and corporate strategy teams play an enormous role. They help to demonstrate the value of our medicines, and the meaningful impact our work has on our patients. The opportunity to work across the R&amp;amp;D continuum – from early clinical, to launch and life cycle management – is an incredible privilege and what excites me every morning to go to work.&lt;/p>&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy_
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-02-27T12:43:31.343-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-02-27T12:43:31.343-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                            </container4_copy>
                            <quote_18408992
                                cq:styleIds="[1000000000000]"
                                jcr:created="{Date}2023-04-24T16:31:39.883-04:00"
                                jcr:createdBy="SCHAFSM"
                                jcr:lastModified="{Date}2023-04-24T16:32:30.281-04:00"
                                jcr:lastModifiedBy="SCHAFSM"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/quote"
                                quote="Becoming a father to two little girls has helped me think about the meaning of our work for the next generation and become even more focused as a leader."
                                quoteType="regular"
                                textSize="h0"/>
                            <container4_copy_copy
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <separator_copy_copy
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-02-27T12:43:31.343-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-02-27T12:43:31.343-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy_1172842007
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-04-24T16:29:45.989-04:00"
                                    jcr:lastModifiedBy="SCHAFSM"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: How would you describe your leadership style? "
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text2_copy_copy_1715987992
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2023-04-24T16:56:55.837-04:00"
                                    jcr:lastModifiedBy="SCHAFSM"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>My role is to build an inclusive culture, where good ideas can come from everyone and we’re always looking to raise the bar on our own performance. I focus on asking questions and ensuring we are using data-driven decision making. I support teams in helping see the bigger picture and breakdown roadblocks to getting things done. Becoming a father to two little girls has also helped me think about the meaning of our work for the next generation and become even more focused as a leader.&lt;/p>&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy_670461390
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-02-27T12:43:31.343-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-02-27T12:43:31.343-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy_93918702
                                    cq:styleIds="[1659545825678,1651545825668]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-04-24T16:30:04.084-04:00"
                                    jcr:lastModifiedBy="SCHAFSM"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: What’s your purpose? "
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"
                                    variant="h"/>
                                <text2_copy_copy_1715
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2023-04-25T18:17:13.026-04:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Going back to my dream as a young boy – I am driven by the ability to work all day on therapies that can change peoples’ lives – give them back their function and time with their families, as well as their ability to live life on their terms. And to be able to do that on a global scale across so many areas of medicine is incredibly rewarding and in many ways is an even bigger dream than I could have ever imagined.&lt;/p>&#xd;&#xa;&lt;p>&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>&lt;a href=&quot;/content/abbvie-com2/us/en/who-we-are/our-leaders/nicholas-donoghoe.html&quot;>Learn more about Nicholas Donoghoe&lt;/a>&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy_1297565079
                                    cq:styleIds="[1662756502570]"
                                    jcr:created="{Date}2023-02-27T12:43:31.343-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-02-27T12:43:31.343-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <text_45036242_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2023-04-18T15:48:24.042-04:00"
                                    jcr:createdBy="SCHAFSM"
                                    jcr:lastModified="{Date}2023-04-18T15:48:37.461-04:00"
                                    jcr:lastModifiedBy="SCHAFSM"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;span class=&quot;body-unica-20-reg&quot;>&lt;b>Media inquiries:&lt;/b>&lt;/span>&lt;br>&#xa;&lt;a href=&quot;mailto:abbviemediarelations@abbvie.com&quot;>abbviemediarelations@abbvie.com&lt;/a>&lt;/p>&#xa;"
                                    textIsRich="true"/>
                            </container4_copy_copy>
