                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>From studying medicine to leading teams building and launching AbbVie’s pipeline, see the path that our R&amp;amp;D chief operating officer took to support patients all over the globe.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </container3>
