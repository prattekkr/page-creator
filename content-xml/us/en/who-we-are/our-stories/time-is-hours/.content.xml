                                jcr:title="AbbVie Teams Up With Latin America Migraine Community on Policy Solutions "
                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                type="h1"
                                variant="h"/>
                            <text
                                cq:styleIds="[1659545825678,1659545835858]"
                                jcr:lastModified="{Date}2025-09-03T09:29:25.822-04:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>The true cost of migraine can go far beyond individual burden, and inaction is something we can’t afford.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </container3>
                    </container2>
