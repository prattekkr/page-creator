                                jcr:lastModified="{Date}2023-02-14T14:19:01.959-05:00"
                                jcr:lastModifiedBy="sharmrx18"
                                jcr:primaryType="nt:unstructured"
                                jcr:title="Whole genome sequencing (WGS) is the process of reading a person’s DNA (credit: Shutterstock)"
                                sling:resourceType="abbvie-com2/components/image/v2/image"
                                alt="alzheimer-socialbrain"
                                altValueFromDAM="false"
                                displayPopupTitle="true"
                                fileReference="/content/dam/abbvie-com2/images/stories/living-with-the-unknowns-of-alzheimer-disease/alzheimer-socialbrain.gif"
                                isDecorative="false"
                                titleValueFromDAM="true"/>
                            <container
                                cq:styleIds="[1653545825687,1653545847150,1653242825678,1653545835982]"
                                jcr:created="{Date}2022-11-29T14:23:15.605-05:00"
                                jcr:createdBy="sharmrx18"
                                jcr:lastModified="{Date}2022-11-29T14:23:15.605-05:00"
                                jcr:lastModifiedBy="sharmrx18"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <separator_copy
                                    cq:styleIds="[1662756456518]"
                                    jcr:created="{Date}2022-12-07T04:23:38.517-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2022-12-07T04:23:38.517-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <separator_copy_copy_
                                    cq:styleIds="[1662756409908]"
                                    jcr:created="{Date}2022-12-07T04:23:38.517-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2022-12-07T04:23:38.517-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <text
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-07T05:36:10.028-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2022-12-08T05:23:28.401-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Since his diagnosis, Jim says he has found peace and learned to live with the “hiccups,” or the dozens of memory lapses he experiences daily. He smiles at them and focuses on the positives – headlined by his family. “I have a lot to cherish about my life and a lot to enjoy in my life,” Jim says. “There’s nothing in my life more important than family and friends.”&lt;/p>&#xd;&#xa;&lt;p>Lisa, a central figure in Jim’s familial support system, bolsters Jim daily by ensuring he has opportunities to be active and engaged in his retirement from a decades-long career in drug rehabilitation services – despite she herself working full time six days a week. Every morning, she wakes up thinking of suggestions to keep him occupied so he doesn’t dwell on his diagnosis, a strategy that has been complicated by COVID-19 lockdowns. “I just try and help him if I see him kind of bored,” Lisa says. “A lot of this time, he has been bored because there’s only so much you can do.”&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container>
                            <image_copy
                                cq:styleIds="[1402843082832,1402843082812]"
                                jcr:created="{Date}2022-12-07T04:42:37.924-05:00"
                                jcr:createdBy="kumarvx60"
                                jcr:lastModified="{Date}2022-12-08T05:24:46.736-05:00"
                                jcr:lastModifiedBy="kumarvx60"
                                jcr:primaryType="nt:unstructured"
                                jcr:title="Jim leans on his family for support as he navigates his Alzheimer’s disease."
                                sling:resourceType="abbvie-com2/components/image/v2/image"
                                altValueFromDAM="true"
                                displayPopupTitle="false"
                                fileReference="/content/dam/abbvie-com2/images/stories/living-with-the-unknowns-of-alzheimer-disease/JimButler_low.jpg"
                                isDecorative="false"
                                titleValueFromDAM="false"/>
                            <container4_copy
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <separator_copy_copy_
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <text_1091121937
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-07T05:33:30.724-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2022-12-08T05:25:05.094-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Jim also finds support in other immediate and extended family members. He smiles over memories he hopes to always recall, of flying in the two-seater plane he and his son built and spending so much time with his sister.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__377739499
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_207325939
                                    cq:styleIds="[1659545825678,1651545825678,1651545825694]"
                                    jcr:created="{Date}2022-11-30T02:11:17.530-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2024-04-18T10:51:52.342-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Resilience is key to research"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_1091121937_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-07T05:33:30.724-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2022-12-08T05:26:11.792-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Despite hurdles in Alzheimer’s research, scientists continue to examine potential paths toward disease modification. “Alzheimer’s is a complex disease riddled with unknowns,” says Dr. Olga Sánchez-Soliño, global neuroscience therapeutic area head, global medical affairs, AbbVie. “We need to keep on trying. We must be resilient and have hope. Such a big impact in Alzheimer’s is yet to come.”&lt;/p>&#xd;&#xa;&lt;p>Dr. Sánchez-Soliño also points to the critical role patients play in the search for potential treatments. “We need to work together with investigators and count on the incredible generosity of patients who are willing to participate in clinical trials,” Dr. Sánchez-Soliño says. “We are very grateful to these patients who contribute their time and energy to advance research.”&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container4_copy>
                            <image_copy_copy
                                cq:styleIds="[1402843082812,1402843082832]"
                                jcr:created="{Date}2022-12-07T04:42:37.924-05:00"
                                jcr:createdBy="kumarvx60"
                                jcr:lastModified="{Date}2023-02-15T15:43:09.024-05:00"
                                jcr:lastModifiedBy="SCHAFSM"
                                jcr:primaryType="nt:unstructured"
                                jcr:title="Jim has acclimated to living with daily “hiccups” by smiling at and dismissing them. “I try not to get mad at them,” he says."
                                sling:resourceType="abbvie-com2/components/image/v2/image"
                                altValueFromDAM="true"
                                displayPopupTitle="false"
                                fileReference="/content/dam/abbvie-com2/images/stories/living-with-the-unknowns-of-alzheimer-disease/jim-hiccups.png"
                                isDecorative="false"
                                titleValueFromDAM="false"/>
                            <container4_copy_copy_1362013193
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <separator_copy_copy_
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <separator_copy_copy__1788246815
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <text_1091121937
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-07T05:33:30.724-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2022-12-08T05:27:04.435-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>For Jim, participating in clinical trials is the least he can do to help researchers in the fight for treatments. “I really appreciate their efforts to try to find a cure,” Jim says. “If my simple job is to just go on in there and take some cognitive tests and get infusions every month, [I] want to contribute.”&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__377739499
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_207325939
                                    cq:styleIds="[1659545825678,1651545825678,1651545825694]"
                                    jcr:created="{Date}2022-11-30T02:11:17.530-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2024-04-18T10:52:01.903-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Living now, every day"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_1091121937_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-12-07T05:33:30.724-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2022-12-08T05:27:26.985-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>In addition to leaning on family, Jim invests in each day as much as he can – at home with chores and in society with politics – as a way to cope with his diagnosis. Participating in Alzheimer’s advocacy through patient groups and clinical trials also gives Jim a sense of purpose and pride. “It’s like being part of the team,” Jim says. “If I can put a helpful face to someone who’s covering this ground, that’s making a big contribution.”&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__58757743
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
