                                <title_copy
                                    cq:styleIds="[1659545825678,1651545825678,1651545825694]"
                                    jcr:created="{Date}2022-11-30T02:11:17.530-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2024-03-20T11:02:04.901-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Helping the most vulnerable"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-02-10T21:38:38.037-05:00"
                                    jcr:lastModifiedBy="SCHAFSM"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>There’s even more work being done to reach people around the world.&lt;br>&#xa;AbbVie also partners with &lt;a href=&quot;https://www.sightsavers.org/&quot; target=&quot;_blank&quot;>Sightsavers&lt;/a>, and the&amp;nbsp;&lt;a href=&quot;https://www.iapb.org/&quot;>International Agency for the Prevention of Blindness&lt;/a>, a non-profit whose goal is to prevent avoidable blindness and save the sight of some of the world’s most vulnerable people.&lt;/p>&#xa;"
                                    textIsRich="true"/>
                            </container4>
