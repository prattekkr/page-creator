                                jcr:lastModifiedBy="sharmrx18"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <separator_copy_copy_
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <text_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-27T13:35:27.156-05:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>The program is called Keep Sight where AbbVie helps to provide training for eyecare professionals in Nigeria and India to screen high risk populations, ensure early and accurate diagnosis and provide appropriate care to make a positive impact on people at risk or living with glaucoma.&lt;/p>&#xd;&#xa;&lt;p>In just one year, ophthalmologists conducted more than more than 12,000 eye screenings and referred more than 1,000 glaucoma-related cases.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__848341076
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy
                                    cq:styleIds="[1659545825678,1651545825678,1651545825694]"
                                    jcr:created="{Date}2022-11-30T02:11:17.530-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2024-03-20T11:02:19.007-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Seeing the science"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-27T13:41:03.357-05:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>On top of making more people aware of the difficulties that glaucoma can cause, AbbVie is dedicated to researching and developing innovative solutions to preserve people’s vision. Leading the charge since 2005 is Mike Robinson, MD, vice president, clinical development, ophthalmology. Prior to joining the company, Robinson was a clinical staff fellow at the National Institutes of Health, but it’s the emotional moments of patient care that drive him to continue looking for new ways to restore people’s vision.&lt;/p>&#xd;&#xa;&lt;p>“There is such great satisfaction after removing a blinding cataract in a patient and seeing them cry tears of joy the next day when they realize their vision has returned,” says Robinson.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container_copy>
                            <quote
                                cq:styleIds="[1000000000040,1000000000010,1000000000032,1000000000051,1000000000000]"
                                jcr:created="{Date}2023-01-27T13:42:05.946-05:00"
                                jcr:createdBy="fusznx"
                                jcr:lastModified="{Date}2023-02-20T17:24:59.879-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/quote"
                                attributionName="Mike Robinson, M.D."
                                attributionTitle="Vice President, Clinical Development, Ophthalmology, AbbVie"
                                quote="Ophthalmology is even in the forefront of stem cell research and regenerative medicine, which is exciting for the future of eye care."
                                quoteType="regular"
                                textSize="h0"/>
                            <container_copy_copy_1366099597
                                cq:styleIds="[1653545825687,1653545847150,1653242825678,1653545835982]"
                                jcr:created="{Date}2022-11-29T14:23:15.605-05:00"
                                jcr:createdBy="sharmrx18"
                                jcr:lastModified="{Date}2022-11-29T14:23:15.605-05:00"
                                jcr:lastModifiedBy="sharmrx18"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <separator_copy_copy__848341076
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <text_copy_1709081072
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-01T02:42:56.202-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>He combines his years of caring for patients with his passion for science. Robinson believes ophthalmology is the perfect fit. “I was drawn to eye health and vision restoration because of the rich history of innovation this area of medicine holds,” says Robinson. “Ophthalmology is even in the forefront of stem cell research and regenerative medicine, which is exciting for the future of eye care.”&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_copy__1903963848
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-11-16T10:43:45.922-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_1444531967
                                    cq:styleIds="[1659545825678,1651545825678,1651545825694]"
                                    jcr:created="{Date}2022-11-30T02:11:17.530-05:00"
                                    jcr:createdBy="kumarvx60"
                                    jcr:lastModified="{Date}2024-03-20T11:02:32.269-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Focused on eye innovation"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text_copy_copy_256774788
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-01T02:45:05.649-05:00"
                                    jcr:lastModifiedBy="kumarvx60"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>While eye care may seem simple, with many vision issues being solved by people wearing glasses contact lenses, or even using eye drops, the reality is what works for some does not work for others. One of the areas Robinson has been focused on in his research has been addressing the challenge of glaucoma patients not managing their eye health correctly and losing their vision.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container_copy_copy_1366099597>
