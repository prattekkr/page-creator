                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>Prompt action is key to combat post-stroke spasticity. Researchers are trying to raise visibility of the condition to help people recognize it early.&lt;/span>&lt;/span>&lt;/p>&#xa;"
