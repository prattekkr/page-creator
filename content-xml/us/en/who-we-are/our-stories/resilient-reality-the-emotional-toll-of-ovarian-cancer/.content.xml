                                dmPresetType="imagePreset"
                                fileReference="/content/dam/abbvie-com2/images/stories/ovarian-global-feature/global-ovarian-cancer-infographic-v2.jpg"
                                isDecorative="false"
                                openInNewWindow="false"
                                titleValueFromDAM="true"/>
                        </par_12>
                        <par_13
