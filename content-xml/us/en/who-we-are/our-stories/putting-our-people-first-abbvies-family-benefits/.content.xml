                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>Explore what makes AbbVie a family-friendly workplace.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
