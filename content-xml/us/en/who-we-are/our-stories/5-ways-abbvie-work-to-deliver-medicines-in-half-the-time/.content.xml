                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>When it comes to creating more time for patients with debilitating diseases, AbbVie’s goals are ambitious—and they need to be.&lt;/span>&lt;/span>&lt;br />&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </container>
                    </container2>
                    <grid
                        jcr:primaryType="nt:unstructured"
