                                jcr:primaryType="nt:unstructured"
                                jcr:title="Behind Every Product: How AbbVie's Integrated Operations Help Prevent Drug Shortages"
                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                type="h1"
                                variant="h"/>
                            <text
                                cq:styleIds="[1659545825678,1659545835858]"
                                jcr:lastModified="{Date}2025-08-27T14:28:30.897-04:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>Advanced planning systems, robust manufacturing capabilities and strategic redundancies help ensure patients worldwide receive life-changing medications.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </container3>
                    </container2>
                    <grid
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="abbvie-com2/components/grid/v2/grid"
                        rowCount="1">
                        <columns jcr:primaryType="nt:unstructured">
