                                jcr:lastModifiedBy="sharmrx18"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>What do a genetics pioneer, medicinal chemist and IT manager have in common? Find out how they’re teaming up to lead one of the largest data initiatives in the industry.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </container3>
