                        <par_12
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="wcm/foundation/components/parsys">
                            <container4
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <text_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-11T12:00:30.890-05:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>The average person generates 1.7 megabytes of data every second. That’s enough to fill a laptop hard drive every week. In science and medicine, the amount of data we have access to is also growing — in fact, it’s doubling every 18 months. But with so much data being generated, how can scientists best collect, analyze, and apply it to help improve patients’ lives and revolutionize the healthcare industry?&lt;/p>&#xd;&#xa;&lt;p>At AbbVie, diverse teams of life scientists, data scientists and engineers are creating new ways of doing just that. We call this field data convergence, and it’s evolving as quickly as we generate data.&lt;/p>&#xd;&#xa;&lt;p>Three leaders share their insights on how to harness data and what they’ve learned building a team of experts with unique skillsets.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container4>
                            <video
                                cq:styleIds="[0]"
                                jcr:created="{Date}2022-12-02T14:49:08.810-05:00"
                                jcr:createdBy="sharmrx18"
                                jcr:lastModified="{Date}2023-09-08T05:56:07.531-04:00"
                                jcr:lastModifiedBy="KANCHRX3"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/video/v2/video"
                                brightcoveAutoPlay="false"
                                btnText="Watch 0:31"
                                description="&lt;p>Here’s how AbbVie approaches it.&lt;/p>&#xd;&#xa;"
                                descriptiveIframeTitle="Everyone’s talking about data science and analytics. Here’s how AbbVie approaches it."
                                fileReference="/content/dam/abbvie-com2/images/stories/everyones-talking-about-data-science-and-analytics-heres-how-abbvie-approaches-i/Everyone's talking about data science and analytics thumbnail.png"
                                loopVideo="false"
                                showBrightcoveControls="false"
                                showPlayerControls="true"
                                showRelatedContent="false"
                                showVideoInfo="true"
                                textIsRich="true"
                                title="Everyone’s talking about data science and analytics. "
                                videoId="bMKSaF6sflc"
                                videoType="youtube"
                                youtubeAutoPlay="false"
                                youtubeUrl="https://www.youtube-nocookie.com/embed/bMKSaF6sflc"/>
                            <container
                                cq:styleIds="[1653545825687,1653545847150,1653242825678,1653545835982]"
                                jcr:created="{Date}2022-12-26T21:51:45.804-05:00"
                                jcr:createdBy="schafsm"
                                jcr:lastModified="{Date}2022-12-26T21:51:45.804-05:00"
                                jcr:lastModifiedBy="schafsm"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <title_copy_copy
                                    cq:styleIds="[1651545825668,1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-02T14:54:54.463-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: What is data integration, or data convergence as it’s called at AbbVie?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"/>
                                <text_copy_copy_copy
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-02T15:00:24.628-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;b>Howard Jacob, Ph.D., vice president of genomics research and head of data convergence&lt;/b>: Convergence is&amp;nbsp;in some sense&amp;nbsp;exactly what it sounds like — it’s bringing together different types of data to create knowledge. We have access to so much data here at AbbVie: preclinical and clinical trial data, public databases, data from scientific publications, and a million genomes — that’s a lot of data!&lt;/p>&#xd;&#xa;&lt;p>So, data convergence was born out of the question “how do we take all of that information and put it together so that we can drive new knowledge much faster?&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-01-28T16:38:57.508-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-28T16:38:57.508-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy
                                    cq:styleIds="[1651545825668,1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-02T14:56:31.452-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: What are the data science skills needed to unlock new knowledge?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"/>
                                <text_copy_copy_copy_
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-02T15:00:14.142-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;b>Jennifer Van Camp, Ph.D., senior director and research fellow, R&amp;amp;D, information research:&lt;/b> There are a lot of disciplines that are represented on data science teams at AbbVie that one doesn't necessarily think of as typical for the pharmaceutical industry. We have electrical engineers with experience in signal and image processing, computational linguists, data engineers, and life scientists like me on our data science teams. It’s the mix of different core strengths and experiences that make progress possible.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-01-28T16:38:57.508-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-28T16:38:57.508-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy_575667514
                                    cq:styleIds="[1651545825668,1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-02T14:57:30.137-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: What are some data science tools AbbVie is building to bridge the gap from data to knowledge and insights?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"/>
                                <text_copy_copy_copy__1655255110
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2024-03-12T10:57:08.753-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;b>Jacob&lt;/b>: We’ve built a central knowledge platform called the ARCH, which stands for AbbVie R&amp;amp;D Convergence Hub. It pulls together all these different data sets into one place. It incorporates different types of information tools that allow us to ask new questions and gain additional insights. With ARCH, we’re able to learn new things about disease definitions, discover new indications, and take a deeper look into understanding the molecular underprint of a disease. In a sense, it democratizes the data.&lt;/p>&#xd;&#xa;&lt;p>&lt;b>Brian Martin, head of artificial intelligence &amp;amp; research fellow, R&amp;amp;D, information research&lt;/b>: The powerful thing about the ARCH is that it’s a knowledge platform versus a data platform. What makes it that way is our scientists and having them explain what makes a specific piece of data information&amp;nbsp;meaningful.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_842658748
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-01-28T16:38:57.508-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-28T16:38:57.508-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy_33529268
                                    cq:styleIds="[1651545825668,1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-02T14:58:37.242-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: Can data convergence help us identify potential new treatments for unmet patient needs?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"/>
                                <text_copy_copy_copy__1969556938
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-02T14:59:28.056-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;b>Martin&lt;/b>: The real-world data we have access to provides us with the opportunity to ask ourselves questions regarding patients’ experiences to quantify their unmet needs from various perspectives. For example, we can now look at preclinical data alongside clinical data and data from insurance claims. This can help us connect the various impacts that a certain compound might have on patients. That ability to bridge the gap from the real-world data back to preclinical data in the lab, that's the power of integration to affect the way we bring assets into our pipeline.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_1896951584
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-01-28T16:38:57.508-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-28T16:38:57.508-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <title_copy_copy_copy_882767733
                                    cq:styleIds="[1651545825668,1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:00:58.796-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2022-12-02T15:01:07.624-05:00"
                                    jcr:lastModifiedBy="sharmrx18"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Q: Any advice for someone interested in a career in data convergence?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h5"/>
                                <text_copy_copy_copy__1429172671
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-16T17:01:41.718-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-11T12:02:35.729-05:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;b>Van Camp&lt;/b>: I don’t think there is a single answer – there’s not one class you should take or a degree you need. But I always believe in being relentlessly curious. As an organization, industry, and a society, we have to keep asking those hard questions that we can't answer.&lt;/p>&#xd;&#xa;&lt;p>Watch AbbVie’s LinkedIn Live event: “&lt;a href=&quot;https://www.youtube.com/watch?v=5P2PnIcbGgA&amp;amp;t=2163s&quot; target=&quot;_blank&quot;>What’s the Formula? Tackling the digital health revolution&lt;/a>” for more from AbbVie’s data convergence leaders.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <separator_copy_1379026575
                                    cq:styleIds="[1662756423318]"
                                    jcr:created="{Date}2023-01-28T16:38:57.508-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-28T16:38:57.508-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                                <text_copy_759260103_
                                    cq:styleIds="[1659545825678]"
                                    jcr:created="{Date}2022-11-23T16:46:55.248-05:00"
                                    jcr:createdBy="chiucx"
                                    jcr:lastModified="{Date}2023-01-11T12:03:21.166-05:00"
                                    jcr:lastModifiedBy="fusznx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;span class=&quot;body-unica-20-reg&quot;>&lt;b>Media inquiries:&lt;/b>&lt;/span>&lt;br>&#xd;&#xa;Email:&amp;nbsp;&lt;a href=&quot;mailto:abbviemediarelations@abbvie.com&quot;>abbviemediarelations@abbvie.com&lt;/a>&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </container>
                        </par_12>
