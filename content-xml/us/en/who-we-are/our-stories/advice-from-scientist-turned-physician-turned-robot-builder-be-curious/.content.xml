                            <container4_copy_copy_1901631163
                                cq:styleIds="[1653545847150,1653242825678,1653545825687,1653545835982]"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/container/v2/container">
                                <title2
                                    cq:styleIds="[1659545825678,1651545824678,1651545825694]"
                                    jcr:lastModified="{Date}2024-05-08T10:10:08.339-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Whether it’s personalized medicine, genomic research, gene therapy, or artificial intelligence, there are a lot of hot topics in R&amp;D today. What area do you think holds the most potential for patients?"
                                    sling:resourceType="abbvie-com2/components/title/v2/title"
                                    type="h2"
                                    variant="h"/>
                                <text2
                                    cq:styleIds="[1659545825678,1659545835858]"
                                    jcr:lastModified="{Date}2023-05-04T17:52:02.141-04:00"
                                    jcr:lastModifiedBy="SCHAFSM"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>I learned that no single approach or technology will be transformative by itself. When new therapies are shown to have an impact, there usually has been a convergence of insights, technologies, disciplines and hard work that came together to bring meaningful results to patients. The most important ingredients common to successful outcomes in biomedical research are deep commitment of individuals and strong teamwork.&lt;/p>&#xa;"
                                    textIsRich="true"/>
                                <separator_copy
