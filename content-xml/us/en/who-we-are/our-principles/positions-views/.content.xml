                        <text_1864523356
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2022-11-28T14:12:33.220-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2022-11-28T17:18:50.116-05:00"
                            jcr:lastModifiedBy="chiucx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>We support public policies that promote our mission of:&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Developing leading-edge therapies and innovations&lt;/li>&#xd;&#xa;&lt;li>Providing life-changing products to patients who need them most&lt;/li>&#xd;&#xa;&lt;li>Enabling us to deliver treatments that have an impact on people’s lives&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                            textIsRich="true"/>
