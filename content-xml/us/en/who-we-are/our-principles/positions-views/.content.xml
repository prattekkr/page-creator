                        <accordion
                            cq:styleIds="[1]"
                            jcr:created="{Date}2022-11-28T17:20:34.179-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2023-01-06T19:00:49.572-05:00"
                            jcr:lastModifiedBy="millicx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/accordion/v2/accordion"
                            headingElement="h5"
                            singleExpansion="false">
                            <item_1670884282434
                                cq:panelTitle="Ethical culture"
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2022-12-22T16:54:52.041-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Read the guiding principles, policies and governance structures that shape our ethical culture.&lt;/p>&#xd;&#xa;&lt;p>&lt;a href=&quot;/content/dam/abbvie-com2/pdfs/cobc/cobc_English.pdf&quot;>Our Code of Business Conduct&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;a href=&quot;/content/dam/abbvie-com2/pdfs/about/our-commitment-to-human-rights.pdf&quot;>Our Commitment to Human Rights&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;a href=&quot;/content/dam/abbvie-com2/pdfs/about/pricing-and-access-of-our-innovative-medicines.pdf&quot;>Pricing and Access of Our Innovative Medicines&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;a href=&quot;/content/dam/abbvie-com2/pdfs/about/abbvie-governance-guidelines.pdf&quot;>Our Corporate Governance Guidelines&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;a href=&quot;/content/dam/abbvie-com2/pdfs/suppliers/abbvie-supplier-code-of-conduct-brochure.pdf&quot;>Our Supplier Guidelines&amp;nbsp;&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;a href=&quot;/content/dam/abbvie-com2/pdfs/about/our-commitment-to-product-donations.pdf&quot;>Our Commitment to Product Donations&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;a href=&quot;/content/dam/abbvie-com2/pdfs/about/statement-of-opposition-to-capital-punishment.pdf&quot;>Statement of Opposition to Use of AbbVie Products in Lethal Injections for Capital Punishment&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;a href=&quot;/content/dam/abbvie-com2/pdfs/about/our-position-on-tax.pdf&quot;>Our Position on Tax&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;a href=&quot;/content/dam/abbvie-com2/pdfs/about/abbvie-unity-statement.pdf&quot;>Our Statement of Unity and Anti-Hate&lt;/a>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <item_1670884286461
                                cq:panelTitle="Responsible research"
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2025-04-16T09:49:41.865-04:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Read our responsible research policies and commitments.&lt;/p>&#xd;&#xa;&lt;p>&lt;a href=&quot;https://www.abbvie.com/content/dam/abbvie-dotcom/uploads/PDFs/our-commitment-to-bioethics.pdf&quot;>Our Commitment to Bioethics&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;a href=&quot;/content/dam/abbvie-com2/pdfs/about/our-commitment-to-responsible-use-of-stem-cells.pdf&quot;>Our Commitment to Responsible Use of Stem Cells&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;a href=&quot;/content/abbvie-com2/us/en/who-we-are/our-principles/positions-views/our-commitment-to-ethical-and-responsible-use-of-animals-in-research.html&quot;>Our Commitment to Humane Care and Use of Animals&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;a href=&quot;https://www.abbvieclinicaltrials.com/hcp/data-sharing/&quot; target=&quot;_blank&quot;>Our Commitment to Clinical Trials Data and Information Sharing&amp;nbsp;&lt;/a>&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;&lt;p>&lt;a href=&quot;/content/dam/abbvie-com2/pdfs/about/commitment-to-continued-treatment-for-trial-participants.pdf&quot;>Our Commitment to Continued Treatment for Trial Participants&lt;/a>&lt;/p>&#xd;&#xa;&lt;p>&lt;a href=&quot;/content/abbvie-com2/us/en/who-we-are/access-to-investigational-drugs-policy.html&quot;>Pre-Approval Access to Investigational Drugs Policy&lt;/a>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <item_1670884289120
                                cq:panelTitle="Healthy environment"
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2023-05-19T11:23:04.518-04:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Read our management and governance guiding documents that help ensure a responsible environmental approach is fully integrated into our business.&lt;/p>&#xd;&#xa;&lt;p>&lt;a href=&quot;/content/dam/abbvie-com2/pdfs/about/our-commitment-to-the-environment-health-and-safety.pdf&quot;>Our Commitment to the Environment, Health and Safety&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;a href=&quot;/content/dam/abbvie-com2/pdfs/about/our-environment-health-and-safety-management-and-technical-standards.pdf&quot;>Our Environment, Health and Safety (EHS) Management and Technical Standards&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;a href=&quot;/content/dam/abbvie-com2/pdfs/about/our-environmental-procurement-guidelines.pdf&quot;>Our Environmental Procurement Guidelines&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;a href=&quot;/content/dam/abbvie-com2/pdfs/about/our-environmental-stewardship.pdf&quot;>Our Environmental Stewardship&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;a href=&quot;/content/dam/abbvie-com2/pdfs/about/our-position-on-global-climate-change.pdf&quot;>Our Position on Global Climate Change&lt;/a>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <item_1670884293427
                                cq:panelTitle="Innovation"
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2022-12-22T16:55:39.105-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Read our policy on biologic innovation, including our position on biosimilars.&lt;/p>&#xd;&#xa;&lt;p>&lt;a href=&quot;/content/dam/abbvie-com2/pdfs/about/committed-to-biologic-innovation.pdf&quot;>Our Commitment to Biologic Innovation&lt;/a>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <item_1670884296156
                                cq:panelTitle="Quality &amp; safety"
                                jcr:lastModified="{Date}2022-12-22T16:56:05.086-05:00"
                                jcr:lastModifiedBy="chiucx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Read our policies that aim to ensure workplace and product safety.&lt;/p>&#xd;&#xa;&lt;p>&lt;a href=&quot;/content/dam/abbvie-com2/pdfs/about/our-distracted-driving-standard.pdf&quot;>Our Distracted Driving Standard&lt;/a>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;a href=&quot;https://www.abbvie.com/content/dam/abbvie-dotcom/uploads/PDFs/our-commitment-to-safe-disposal-of-medicine.pdf&quot;>Our Commitment to Safe Disposal of Medicine&lt;/a>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </accordion>
                    </container_614517142>
