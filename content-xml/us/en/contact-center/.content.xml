                                <item_1670707214308
                                    cq:panelTitle="Partnership Opportunities"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2022-12-23T15:31:17.371-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>If you have a partnership or technology opportunity that may be of interest to AbbVie, we want to hear from you. Submit your non-confidential information here for review.&lt;/p>&#xd;&#xa;&lt;p>&lt;a href=&quot;https://abbvie.partneringplace.com/OppPortal/portal/Abbvie&quot; target=&quot;_blank&quot;>Contact us&lt;/a>&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1689363673461
                                    cq:panelTitle="Careers"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2026-06-02T09:22:01.388-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    langAttribute="none"
                                    text="&lt;p>Visit &lt;a href=&quot;https://careers.abbvie.com&quot; target=&quot;_blank&quot;>careers.abbvie.com&lt;/a> to search for current opportunities.&lt;/p>&#xd;&#xa;&lt;p>For career-related inquiries, email:&amp;nbsp;&lt;a href=&quot;mailto:talentacquisition@abbvie.com&quot;>talentacquisition@abbvie.com&lt;/a>.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1671827189744
                                    cq:panelTitle="Suppliers"
                                    jcr:lastModified="{Date}2026-06-01T16:55:15.205-04:00"
                                    jcr:lastModifiedBy="VALENSX5"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    langAttribute="none"
                                    text="&lt;p>&lt;b>Payment requirements&lt;/b>&lt;/p>&#xd;&#xa;&lt;p>For questions concerning invoice status or payment, please reach out to the CDO helpdesk at &lt;a href=&quot;mailto:%20AbbvieCDO@abbvie.com&quot;>AbbvieCDO@abbvie.com&lt;/a>.&lt;/p>&#xd;&#xa;&lt;p>&lt;b>US invoices submitted by using the following:&lt;/b>&lt;/p>&#xd;&#xa;&lt;p>EDI Invoicing, please contact the helpdesk at &lt;a href=&quot;mailto:%20AbbvieCDO@abbvie.com&quot;>AbbvieCDO@abbvie.com&lt;/a>&lt;/p>&#xd;&#xa;&lt;p>Mail,  AbbVie Inc,  P.O. Box 210075, Dallas, TX 75211&lt;/p>&#xd;&#xa;&lt;p>Fax,  214-329-0920&lt;/p>&#xd;&#xa;&lt;p>Email: &lt;a href=&quot;mailto:abbvie.us.usap@ironmountain.com&quot;>abbvie.us.usap@ironmountain.com&lt;/a>&lt;/p>&#xd;&#xa;&lt;p>Email: PCYC only &lt;a href=&quot;mailto:abbvie.us.6701@ironmountain.com&quot;>abbvie.us.6701@ironmountain.com&lt;/a>&lt;/p>&#xd;&#xa;&lt;p>For OUS invoices, please work with your site contact for information on where to send your invoices.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1779815510868
                                    cq:panelTitle="AbbVie Contract Manufacturing "
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2026-05-27T16:41:38.843-04:00"
                                    jcr:lastModifiedBy="stromkx1"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    langAttribute="none"
                                    text="&lt;p>As an embedded Contract Manufacturing Organization (CMO), we leverage decades of scientific expertise, operational excellence, and best-in-class facilities to provide you with one of the most reliable manufacturing options for high quality supply chain assurance. From development to commercialization, we can efficiently support your vision to market to help improve the lives of patients world-wide.&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;b>Email:&lt;/b>&amp;nbsp;&lt;a href=&quot;mailto:abbviecontractmfg@abbvie.com&quot;>abbviecontractmfg@abbvie.com&lt;/a>&lt;br>&#xd;&#xa;&lt;b>Route to website:&lt;/b> &lt;a href=&quot;https://www.abbviecontractmfg.com&quot; target=&quot;_blank&quot;>https://www.abbviecontractmfg.com&lt;/a>&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
