                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    langAttribute="none"
                                    text="&lt;p>&lt;b>Patient Support, Resources &amp;amp; Assistance:&lt;/b>&lt;br />&#xd;&#xa;Patient Support: &lt;a href=&quot;/content/abbvie-com2/us/en/patients/patient-support.html&quot;>Click Here&lt;/a>&lt;br />&#xd;&#xa;Savings Card Information: &lt;a href=&quot;/content/abbvie-com2/us/en/patients/patient-support/patient-assistance/savings-card.html&quot;>Click Here&lt;/a>&lt;br />&#xd;&#xa;myAbbVie Assist Patient Assistance Program: &lt;a href=&quot;/content/abbvie-com2/us/en/patients/patient-support/patient-assistance.html&quot;>Click Here&lt;/a> or call (for myAbbVie assist only):&lt;br />&#xd;&#xa;myAbbVie Assist: 1-800-222-6885&lt;br />&#xd;&#xa;myAbbVie Assist Oncology: 1-844-900-2228&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1779815698307
                                    cq:panelTitle="Medical Information"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2026-05-27T15:04:31.025-04:00"
                                    jcr:lastModifiedBy="stromkx1"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    langAttribute="none"
                                    text="&lt;p>If you have medical information, product information, storage or ingredient question please contact AbbVie Medical Information at 844-663-3742. Specialists are available Monday through Friday, 8:00 AM to 5:30 PM CT. You may also submit your question at &lt;a href=&quot;https://www.abbviemedinfo.com/&quot; target=&quot;_blank&quot;>AbbVie Medical Information.&lt;/a>&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
