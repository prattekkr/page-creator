                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    langAttribute="none"
                                    text="&lt;p>To report a side effect or a product quality concern, please contact AbbVie Medical Services at 1-800-633-9110.&amp;nbsp;Specialists are available Monday through Friday, 8:00 AM to 5:30 PM CT.&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1779815482151
