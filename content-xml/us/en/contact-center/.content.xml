                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    langAttribute="none"
                                    text="&lt;div>&lt;span class=&quot;body-unica-16-reg&quot;>&lt;span class=&quot;body-unica-18-reg&quot;>For Customer Service support across products, therapies, and account-related needs:&lt;br>&#xd;&#xa; &amp;nbsp;&lt;/span>&lt;/span>&lt;/div>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Allergan Aesthetics: 1-800-377-7790&lt;/li>&#xd;&#xa;&lt;li>Alle: 1-888-912-1572&lt;/li>&#xd;&#xa;&lt;li>New Aesthetic Accounts: 1-844-NEW-2AGN (1-844-639-2246); aestheticsonboarding@abbvie.com&lt;/li>&#xd;&#xa;&lt;li>Anti-Infectives: 855-387-2821&lt;/li>&#xd;&#xa;&lt;li>Botox Therapeutic: 1-800-44-BOTOX (1-800-442-6869)&lt;/li>&#xd;&#xa;&lt;li>HCP support for Direct or Advantage: 1-844-246-2461&lt;/li>&#xd;&#xa;&lt;li>Durysta: 1-833-DURYSTA (1-833-387-9782)&lt;/li>&#xd;&#xa;&lt;li>Liletta: 1-855-LILETTA (1-855-545-3882)&lt;/li>&#xd;&#xa;&lt;li>Lupron: 1-800-621-1020&lt;/li>&#xd;&#xa;&lt;li>Ozurdex and Xen: 1-866-698-7339&lt;/li>&#xd;&#xa;&lt;li>Refresh Concierge: 1-833-733-7675&lt;/li>&#xd;&#xa;&lt;li>SkinMedica Consumer Care: 1-888-912-1596&lt;/li>&#xd;&#xa;&lt;li>AbbVie Pharmaceuticals (General): 1-800-255-5162&lt;/li>&#xd;&#xa;&lt;li>Accounts Receivable: 1-800-811-4148&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1779812658085
                                    cq:panelTitle="Adverse Events and Product Quality Concerns"
