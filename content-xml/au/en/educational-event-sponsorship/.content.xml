                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>Medical science evolves rapidly and we are pleased to offer support to healthcare professionals&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
