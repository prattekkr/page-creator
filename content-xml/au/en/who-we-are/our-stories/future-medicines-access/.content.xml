                                text="&lt;p>&lt;span class=&quot;body-unica-20-reg&quot;>Key findings from respondents&lt;sup>4&lt;/sup>&lt;/span>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <separator
                                jcr:created="{Date}2025-12-10T08:56:25.512-05:00"
