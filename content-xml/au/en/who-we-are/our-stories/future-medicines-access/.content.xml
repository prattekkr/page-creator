                                    jcr:lastModifiedBy="singarx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&amp;quot;A healthy economy depends on healthy people. AbbVie remains a steadfast supporter of the PBS, advocating for reforms to help secure access to medicines for all Australians in need. Investment in the PBS is an investment in Australia’s future.&amp;quot;&lt;/p>&#xd;&#xa;&lt;p>&lt;i>Nathalie McNeil, VP and GM AbbVie Australia and New Zealand&lt;/i>&lt;/p>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </par_12>
