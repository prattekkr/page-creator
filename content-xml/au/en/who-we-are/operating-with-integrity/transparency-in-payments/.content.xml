                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>We engage ethically with all providers, and do so transparently and in compliance with country laws, regulations and trade association obligations.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
