                        dmPresetType="imagePreset">
                        <title
                            cq:styleIds="[1659545825678,1651241825678,1651545825693,1661545829678]"
                            jcr:created="{Date}2025-05-02T03:10:17.406-04:00"
                            jcr:createdBy="singarx"
                            jcr:lastModified="{Date}2025-08-08T03:24:09.195-04:00"
                            jcr:lastModifiedBy="nandivx5"
                            jcr:primaryType="nt:unstructured"
                            jcr:title="We believe interactions with healthcare professionals and healthcare organisations bring value to patient care "
                            sling:resourceType="abbvie-com2/components/title/v2/title"
                            type="h2"
                            variant="h"/>
                        <text
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2025-05-02T03:11:33.647-04:00"
                            jcr:createdBy="singarx"
                            jcr:lastModified="{Date}2025-08-08T03:25:12.263-04:00"
                            jcr:lastModifiedBy="nandivx5"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>AbbVie supports disclosure and transparency on interactions between the healthcare industry and healthcare professionals to ensure public trust and confidence.&lt;/p>&#xd;&#xa;&lt;p>In alignment with the member companies of Medicines Australia, AbbVie has undertaken to be open and transparent when we provide a reportable payment to a healthcare professional or a third party as directed by a healthcare professional. Reportable payments or transfers of value are:&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Payments for the provision of services such as giving a lecture, chairing an educational meeting, providing advice as a member of an Advisory Board or as a Consultant&lt;/li>&#xd;&#xa;&lt;li>Airfares, accommodation and/or conference registration fees to attend medical education or as part of the provision of services.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>AbbVie has prepared the report for publication in accordance with the Medicines Australia Code of Conduct, Edition 20 and Australia’s Privacy legislation. The report identifies healthcare professionals by name where their consent has been provided. Where consent has not been provided, the information is reported in aggregate.&amp;nbsp;&lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
                        <separator
                            cq:styleIds="[1662756409908]"
                            jcr:created="{Date}2025-05-02T03:13:58.002-04:00"
                            jcr:createdBy="singarx"
                            jcr:lastModified="{Date}2025-05-02T03:37:47.158-04:00"
                            jcr:lastModifiedBy="singarx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                        <title_1350529886
                            cq:styleIds="[1659545825678,1661545829678]"
                            jcr:created="{Date}2025-05-02T03:14:30.684-04:00"
                            jcr:createdBy="singarx"
                            jcr:lastModified="{Date}2025-08-08T03:25:52.885-04:00"
                            jcr:lastModifiedBy="nandivx5"
                            jcr:primaryType="nt:unstructured"
                            jcr:title="HCP disclosures "
                            sling:resourceType="abbvie-com2/components/title/v2/title"
                            type="h2"
                            variant="h"/>
                        <text_1328406989
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2025-05-02T03:16:01.416-04:00"
                            jcr:createdBy="singarx"
                            jcr:lastModified="{Date}2026-05-06T10:05:02.148-04:00"
                            jcr:lastModifiedBy="VALENSX5"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            langAttribute="none"
                            text="&lt;p>From 1 October 2016, reporting of these payments is mandatory.&lt;/p>&#xd;&#xa;&lt;p>The report is designed to be read on this website. It is also provided as a downloadable CSV file.&lt;/p>&#xd;&#xa;&lt;p>To comply with our privacy obligations, the report may be amended from time to time. The report here contains the most up to date information. Any use or disclosure of the data by a third party is the responsibility of that third party, who must comply with the Australian Privacy Act 1988.&lt;/p>&#xd;&#xa;&lt;p>For further information about the details in the report, please go to &lt;a href=&quot;https://www.medicinesaustralia.com.au/code/transparency-reporting/payments-to-healthcare-professionals/&quot;>https://www.medicinesaustralia.com.au/code/transparency-reporting/payments-to-healthcare-professionals/&lt;/a>&lt;/p>&#xd;&#xa;&lt;p>This report will be available for at least three years from the date of publication.&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Reporting Period from 1 November 2018 onward&lt;/li>&#xd;&#xa;&lt;li>From 30 August 2019, this information will be held in a central database, administered by Medicines Australia. This database is designed to be searchable and includes an option to download the data as a CSV file. &lt;/li>&#xd;&#xa;&lt;li>For further information about the details in the report, or to search the database, please visit &lt;a href=&quot;http://www.disclosureaustralia.com.au/&quot;>www.DisclosureAustralia.com.au&lt;/a>&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://japactransparency.abbvie.com/Aug_2023_Report_AbbVie_Australia_Disclosure_Final.csv&quot;>Click here to download a CSV file of the report from 1 November 2022 to 30 April 2023&lt;/a>&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://japactransparency.abbvie.com/Feb_2024_Report_AbbVie_Australia_Disclosure_Final.csv&quot;>Click here to download a CSV file of the report from 1 May 2023 to 31 October 2023&lt;/a>&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://japactransparency.abbvie.com/Aug_2024_Report_AbbVie_Australia_Disclosure_Final.csv&quot;>Click here to download a CSV file of the report from 1 November 2023 to 30 April 2024&lt;/a>&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://japactransparency.abbvie.com/Dec_2025_AbbVie_Australia_Report_Final_v2.1.csv&quot;>Click here to download a CSV file of the report from 1 May 2024 to 31 October 2024&lt;/a>&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://japactransparency.abbvie.com/Aug_2025_Report_AbbVie_Australia_Disclosure_Final.csv&quot;>Click here to download a CSV file of the report from 1 November 2024 to 30 April 2025&lt;/a>&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://japactransparency.abbvie.com/Dec_2025_AbbVie_Australia_Report_Final_v2-1.csv&quot;>Click here to download a CSV file of the report from&amp;nbsp;1 May 2025 to 31 December 2025&lt;/a>&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                            textIsRich="true"/>
                        <separator_1971640334
                            jcr:created="{Date}2025-05-02T03:17:28.933-04:00"
                            jcr:createdBy="singarx"
