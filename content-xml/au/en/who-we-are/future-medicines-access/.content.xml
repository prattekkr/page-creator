                                sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                            <title_1393380546_cop
                                cq:styleIds="[1659545825678,1661545829678]"
                                jcr:created="{Date}2025-10-02T19:51:54.594-04:00"
                                jcr:createdBy="nandivx5"
                                jcr:lastModified="{Date}2025-10-02T19:52:26.377-04:00"
                                jcr:lastModifiedBy="nandivx5"
                                jcr:primaryType="nt:unstructured"
                                jcr:title="AbbVie’s commitment"
                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                type="h4"
                                variant="h"/>
                            <text_1989020332
                                cq:styleIds="[1659545825678]"
                                jcr:created="{Date}2025-10-02T19:53:29.685-04:00"
                                jcr:createdBy="nandivx5"
                                jcr:lastModified="{Date}2025-10-02T19:53:46.025-04:00"
                                jcr:lastModifiedBy="nandivx5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Through AbbVie’s Future Medicines Access initiative, we aim to foster constructive conversations about improving Australia’s access to new medicines. This includes highlighting the critical issues that need to be solved and helping to pave the way for a stronger PBS, ensuring that every Australian can receive the medicine they need, when they need it.&lt;/p>&#xd;&#xa;&lt;p>AbbVie supports Medicines Australia’s call for a&amp;nbsp;&lt;a href=&quot;http://www.strongerpbs.com.au/&quot;>Stronger PBS&lt;/a>. We also urge the Government to implement the 50 recommendations from the&amp;nbsp;&lt;a href=&quot;https://www.health.gov.au/our-work/hta-review&quot;>Health Technology Assessment (HTA) Review&lt;/a>&amp;nbsp;to improve access to medicines for Australians.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <separator_71377048_c
                                cq:styleIds="[1662756456518]"
                                jcr:created="{Date}2025-10-02T19:52:49.636-04:00"
                                jcr:createdBy="nandivx5"
                                jcr:lastModified="{Date}2025-10-02T19:52:49.636-04:00"
                                jcr:lastModifiedBy="nandivx5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                            <title_1393380546_cop_1369413527
                                cq:styleIds="[1659545825678,1661545829678]"
                                jcr:created="{Date}2025-10-02T19:51:54.594-04:00"
                                jcr:createdBy="nandivx5"
                                jcr:lastModified="{Date}2025-10-02T19:54:31.361-04:00"
                                jcr:lastModifiedBy="nandivx5"
                                jcr:primaryType="nt:unstructured"
                                jcr:title="How you can get involved:"
                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                type="h4"
                                variant="h"/>
                            <text_1989020332_copy
                                cq:styleIds="[1659545825678]"
                                jcr:created="{Date}2025-10-02T19:53:29.685-04:00"
                                jcr:createdBy="nandivx5"
                                jcr:lastModified="{Date}2026-03-10T14:35:43.605-04:00"
                                jcr:lastModifiedBy="VALENSX5"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                langAttribute="none"
                                text="&lt;p>Through AbbVie’s Future Medicines Access initiative, we aim to foster constructive conversations about improving Australia’s access to new medicines. This includes highlighting the critical issues that need to be solved and helping to pave the way for a stronger PBS, ensuring that every Australian can receive the medicine they need, when they need it.&lt;/p>&#xd;&#xa;&lt;p>AbbVie supports Medicines Australia’s call for a&amp;nbsp;&lt;a href=&quot;http://www.strongerpbs.com.au/&quot;>Stronger PBS&lt;/a>. We also urge the Government to implement the 50 recommendations from the&amp;nbsp;&lt;a href=&quot;https://www.health.gov.au/our-work/hta-review&quot;>Health Technology Assessment (HTA) Review&lt;/a>&amp;nbsp;to improve access to medicines for Australians.&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Follow, like and share Future Medicines Access social content from AbbVie Australia on&amp;nbsp;&lt;a href=&quot;https://www.facebook.com/AbbVieAustralia/&quot;>Facebook&lt;/a>,&amp;nbsp;&lt;a href=&quot;https://www.instagram.com/abbvieaustralia&quot;>Instagram&lt;/a>,&amp;nbsp;&lt;a href=&quot;https://www.linkedin.com/company/abbvie/&quot;>LinkedIn&lt;/a>.&lt;/li>&#xd;&#xa;&lt;li>Contact your local&amp;nbsp;&lt;a href=&quot;https://www.aph.gov.au/Senators_and_Members&quot;>Member of Parliament&lt;/a>&amp;nbsp;to discuss your concerns about access to medicines and urge them to take action.&lt;/li>&#xd;&#xa;&lt;li>Pledge your support and&amp;nbsp;&lt;a href=&quot;https://www.strongerpbs.com.au/&quot;>sign up&amp;nbsp;to Medicines Australia’s Stronger PBS Campaign&lt;/a>.&lt;/li>&#xd;&#xa;&lt;li>&amp;nbsp;For more information, or if you/your organisation would like to partner with AbbVie on Future Medicines Access please reach out to us at&amp;nbsp;&lt;a href=&quot;mailto:auabbviecorporatecomms@abbvie.com&quot;>auabbviecorporatecomms@abbvie.com&lt;/a>.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;&lt;p>&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>&lt;span class=&quot;body-unica-20-reg&quot;>&lt;b>PRESS RELEASE AUGUST 2025:&lt;/b>&lt;/span>&amp;nbsp;&lt;a href=&quot;https://www.abbvie.com.au/content/dam/abbvie-dotcom/au/documents/australians-want-greater-investment-pbs-press-release-final-4Aug.pdf&quot;>Australians want more investment in the PBS&lt;/a>&lt;/p>&#xd;&#xa;&lt;p>&lt;span class=&quot;body-unica-20-reg&quot;>&lt;b>References&lt;/b>&lt;/span>&lt;/p>&#xd;&#xa;&lt;ol>&#xd;&#xa;&lt;li>Medicines Australia: Stronger PBS Campaign&amp;nbsp;&lt;a href=&quot;http://www.strongerpbs.com.au/&quot;>www.strongerpbs.com.au&lt;/a>. Accessed June 2025&lt;/li>&#xd;&#xa;&lt;li>Medicines Australia – Medicines Matter Report 2022.&amp;nbsp;&amp;nbsp;&lt;a href=&quot;https://www.medicinesaustralia.com.au/wp-content/uploads/sites/65/2023/04/Medicines-Matter-2022-FINAL.pdf&quot;>https://www.medicinesaustralia.com.au/wp-content/uploads/sites/65/2023/04/Medicines-Matter-2022-FINAL.pdf&lt;/a> Accessed June 2025&lt;/li>&#xd;&#xa;&lt;li>&lt;a href=&quot;https://data-explorer.oecd.org/vis?lc=en&amp;amp;pg=0&amp;amp;snb=1&amp;amp;vw=br&amp;amp;df%5bds%5d=dsDisseminateFinalDMZ&amp;amp;df%5bid%5d=DSD_SHA%40DF_SHA&amp;amp;df%5bag%5d=OECD.ELS.HD&amp;amp;df%5bvs%5d=&amp;amp;pd=2021%2C2021&amp;amp;dq=USA%2BGBR%2BTUR%2BCHE%2BSWE%2BESP%2BSVN%2BSVK%2BPRT%2BPOL%2BNOR%2BNZL%2BNLD%2BMEX%2BLUX%2BLTU%2BLVA%2BKOR%2BJPN%2BITA%2BISR%2BIRL%2BISL%2BHUN%2BGRC%2BDEU%2BFRA%2BFIN%2BEST%2BDNK%2BCZE%2BCRI%2BCOL%2BCHL%2BCAN%2BBEL%2BAUT%2BAUS.A.EXP_HEALTH.PT_EXP_HLTH.HF1..HC51.._T...&amp;amp;ly%5brw%5d=REF_AREA&amp;amp;to%5bTIME_PERIOD%5d=false&amp;amp;lb=id&quot;>OECD Data Explorer&lt;/a>&amp;nbsp;Accessed June 2025&lt;/li>&#xd;&#xa;&lt;li>IFPMA. Always Innovating Pharmaceutical Industry Facts &amp;amp; Figures December 2024. &lt;a href=&quot;https://www.ifpma.org/wp-content/uploads/2025/02/IFPMA_Always_Innovating_Facts__Figures_Report.pdf&quot;>https://www.ifpma.org/wp-content/uploads/2025/02/IFPMA_Always_Innovating_Facts__Figures_Report.pdf&lt;/a> Accessed February 2026&lt;/li>&#xd;&#xa;&lt;li>PhRMA. Research and Development Policy Framework. &lt;a href=&quot;https://www.phrma.org/policy-issues/research-development&quot;>https://www.phrma.org/policy-issues/research-development&lt;/a> Accessed February 2026&lt;/li>&#xd;&#xa;&lt;li>AbbVie Data on File – Future Medicines Access Survey Data. May 2025. CLA-AU-250014&lt;/li>&#xd;&#xa;&lt;/ol>&#xd;&#xa;&lt;p>&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>AU-ABBV-250176. September 2025.&lt;/p>&#xd;&#xa;"
