                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-18-reg&quot;>&amp;quot;A healthy economy depends on healthy people. AbbVie remains a steadfast supporter of the PBS, advocating for reforms to help secure access to medicines for all Australians in need. Investment in the PBS is an investment in Australia’s future.&amp;quot;&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;&lt;p>&lt;i style=&quot;font-size: 0.8125rem;&quot;>Nathalie McNeil, VP and GM AbbVie Australia and New Zealand&lt;/i>&lt;/p>&#xd;&#xa;"
