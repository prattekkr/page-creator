                            <accordion
                                cq:styleIds="[1]"
                                jcr:created="{Date}2025-09-12T08:46:44.102-04:00"
                                jcr:createdBy="singarx"
                                jcr:lastModified="{Date}2025-09-12T08:49:51.699-04:00"
                                jcr:lastModifiedBy="singarx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/accordion/v2/accordion"
                                singleExpansion="false">
                                <item_1757681221580
                                    cq:panelTitle="Patients &amp; Carers"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2025-12-05T08:53:57.801-05:00"
                                    jcr:lastModifiedBy="singarx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Putting patients first.&lt;br>&#xd;&#xa;We’re providing broader support to help ensure patients have the information and support they need.&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>&lt;b>Consumer Medicine Information (CMI)&lt;/b>&amp;nbsp;provides important information about your medicine.&amp;nbsp;&lt;a href=&quot;/content/abbvie-com2/au/en/patients/products.html&quot;>Consumer Medicine Information (CMI) for AbbVie products&lt;/a>&lt;/li>&#xd;&#xa;&lt;li>For&lt;b>&amp;nbsp;enquiries&lt;/b>&amp;nbsp;regarding an AbbVie product, please contact our Medical Information team at&amp;nbsp;&lt;a href=&quot;mailto:medinfoanz@abbvie.com&quot;>&lt;b>medinfoanz@abbvie.com&lt;/b>&lt;/a>&amp;nbsp;or call&amp;nbsp;1800 252 224.&lt;/li>&#xd;&#xa;&lt;li>Some AbbVie products have patient support programs, please ask your healthcare professional for more information.&lt;/li>&#xd;&#xa;&lt;li>For medical advice, please consult your healthcare professional.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1757681225684
                                    cq:panelTitle="Healthcare Professionals"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2025-12-05T08:43:57.551-05:00"
                                    jcr:lastModifiedBy="singarx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Unwavering in our commitment to bring the best science to patients worldwide.&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>For&lt;b>&amp;nbsp;all HCP&lt;/b> &lt;b>enquiries&lt;/b>&amp;nbsp;including finding your AbbVie representative, please call&lt;br>&#xd;&#xa;1800 252 224 or email&amp;nbsp;&lt;a href=&quot;mailto:supportanz@abbvie.com&quot;>supportanz@abbvie.com&lt;/a>&lt;/li>&#xd;&#xa;&lt;li>Access the&amp;nbsp;&lt;a href=&quot;/content/abbvie-com2/au/en/patients/products.html&quot;>Product Information (PI) for AbbVie products&lt;/a>&lt;/li>&#xd;&#xa;&lt;li>Access a dedicated&amp;nbsp;&lt;b>Healthcare Professional &lt;/b>portal,&amp;nbsp;&lt;a href=&quot;https://www.abbviepro.com/au/en.html&quot;>AbbVie Pro&lt;/a>, providing streamlined access to AbbVie product &amp;amp; patient resources, medical education based on expert insights, congress coverage and research publications.&lt;/li>&#xd;&#xa;&lt;li>Clinical trials -&amp;nbsp;&lt;a href=&quot;/content/abbvie-com2/au/en/science/clinical-trials.html&quot;>explore how we turn our research into reality&lt;/a>&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1757681229867
                                    cq:panelTitle="Wholesalers &amp; Direct Accounts"
                                    jcr:lastModified="{Date}2025-09-12T09:52:34.224-04:00"
                                    jcr:lastModifiedBy="singarx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Creating partnerships that make a difference.&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>For enquiries regarding&amp;nbsp;&lt;b>ordering, stock replacements, pricing, claims and new or existing accounts&lt;/b>&amp;nbsp;please contact the&lt;b>&amp;nbsp;Distribution &amp;amp; Order Management&lt;/b>&amp;nbsp;team on 1800 252 224.&lt;/li>&#xd;&#xa;&lt;li>For questions concerning&amp;nbsp;&lt;b>invoice status or payment&lt;/b>, please email&amp;nbsp;&lt;b>Accounts Receivable&lt;/b>&amp;nbsp;at&amp;nbsp;&lt;a href=&quot;mailto:receivable.go-accounts@abbvie.com&quot;>Receivable.GO-Accounts@abbvie.com&lt;/a>&lt;/li>&#xd;&#xa;&lt;li>For&amp;nbsp;&lt;b>Allergan Aesthetics&lt;/b>&amp;nbsp;please call 1800 252 224, email&amp;nbsp;&lt;a href=&quot;mailto:australiaenquiries@allergan.com&quot;>australiaenquiries@allergan.com&lt;/a>&amp;nbsp;or go to&amp;nbsp;&lt;a href=&quot;http://www.allerganaesthetics.com.au/&quot;>www.allerganaesthetics.com.au&lt;/a>&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1757681233121
                                    cq:panelTitle="Report an adverse event or product complaint"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2025-12-05T08:40:36.326-05:00"
                                    jcr:lastModifiedBy="singarx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;ul>&#xd;&#xa;&lt;li>If you are experiencing a&amp;nbsp;&lt;b>medical emergency&lt;/b>,&amp;nbsp;please call 000. If you require&amp;nbsp;&lt;b>medical advice&lt;/b>, please contact your doctor or other healthcare professional.&lt;/li>&#xd;&#xa;&lt;li>To report an&amp;nbsp;&lt;b>Adverse Event&lt;/b>&amp;nbsp;in relation to the use of an AbbVie product please email&amp;nbsp;&lt;a href=&quot;mailto:anzpv@abbvie.com&quot;>anzpv@abbvie.com&lt;/a>&amp;nbsp;or call 1800 252 224.&lt;/li>&#xd;&#xa;&lt;li>To report a&amp;nbsp;&lt;b>Product Complaint&lt;/b>&amp;nbsp;in relation to the use of an AbbVie product please email&amp;nbsp;&lt;a href=&quot;mailto:productcomplaints-anz@abbvie.com&quot;>productcomplaints-anz@abbvie.com&lt;/a>&amp;nbsp;or call&amp;nbsp;1800 252 224.&lt;/li>&#xd;&#xa;&lt;li>For&lt;b>&amp;nbsp;safety information&lt;/b>&amp;nbsp;please refer to the relevant product’s &amp;nbsp;&lt;a href=&quot;/content/abbvie-com2/au/en/patients/products.html&quot;>Consumer Medicine Information&amp;nbsp;&lt;/a>for patients and&amp;nbsp;&lt;a href=&quot;/content/abbvie-com2/au/en/patients/products.html&quot;>Product Information&lt;/a>&amp;nbsp;for healthcare professionals.&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1757681256167
                                    cq:panelTitle="Careers"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2025-10-02T06:48:30.427-04:00"
                                    jcr:lastModifiedBy="singarx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>AbbVie employees work every day to help discover solutions to address many of the world's most pressing health challenges.&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Visit&amp;nbsp;&lt;a href=&quot;/content/abbvie-com2/au/en/join-us.html&quot;>Join Us&lt;/a>&amp;nbsp;to search for current opportunities.&lt;/li>&#xd;&#xa;&lt;li>For career related enquiries email&amp;nbsp;&lt;a href=&quot;mailto:careersanz@abbvie.com&quot;>careersanz@abbvie.com&lt;/a>&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1757681262841
                                    cq:panelTitle="Media"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2025-12-05T08:25:47.791-05:00"
                                    jcr:lastModifiedBy="singarx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;ul>&#xd;&#xa;&lt;li>For media-related enquiries, please contact Corporate Communications Australia and&lt;br>&#xd;&#xa;New Zealand at&amp;nbsp;&lt;a href=&quot;mailto:media_ANZ@abbvie.com&quot;>media_ANZ@abbvie.com&lt;/a>&amp;nbsp;or go to the&amp;nbsp;&lt;a href=&quot;/content/abbvie-com2/au/en/media.html&quot;>AbbVie Media page&lt;/a>&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </accordion>
