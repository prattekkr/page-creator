                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;br _rte_temp_br=&quot;brEOB&quot;>&#xd;&#xa;&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-20-reg&quot;>AbbVie Pty Ltd,&lt;br>&#xd;&#xa; Gateway 241, Level 7&lt;br>&#xd;&#xa; 241 O’Riordan Street,&lt;br>&#xd;&#xa; Mascot, NSW 2020&lt;br>&#xd;&#xa; Telephone: 1800 252 224&lt;br>&#xd;&#xa; Fax: 1800 564 716&lt;/span>&lt;/span>&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-20-reg&quot;>If you are experiencing a&amp;nbsp;&lt;b>medical emergency&lt;/b>, please call 000. If you require&amp;nbsp;&lt;b>medical advice&lt;/b>, please contact your doctor or other healthcare professional.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <separator_1670052733
