                            jcr:lastModified="{Date}2025-08-05T05:41:45.981-04:00"
                            jcr:lastModifiedBy="singarx"
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Researching Areas of Unmet Medical Need"
                            sling:resourceType="abbvie-com2/components/title/v2/title"
                            type="h3"
                            variant="h"/>
                        <text_1789249334_copy_1701568248
                            cq:styleIds="[1659545825678,1659545825676]"
                            jcr:created="{Date}2022-12-07T14:53:09.069-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2025-08-05T05:42:26.350-04:00"
                            jcr:lastModifiedBy="singarx"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>At AbbVie, our R&amp;amp;D teams are chasing bold goals. The therapies and solutions that no one else has achieved or even attempted. And we want to be there first. That's what we go after every day for our patients.&lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
                        <separator_1534983138
                            cq:styleIds="[1662756456518]"
                            jcr:created="{Date}2025-12-08T12:16:40.837-05:00"
