                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>We’re constantly finding new ways to address patients’ most serious health issues. We concentrate our efforts on a core set of therapeutic areas—ones where we’ve proven our expertise, and where we feel we can have an even greater impact on disease and how it is managed.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                        </container3>
