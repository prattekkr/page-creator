                            jcr:createdBy="singarx"
                            jcr:description="&lt;p>We aim to develop innovative therapies for health conditions where there is a significant need. Our medicines are approved by the Therapeutic Goods Administration (TGA) for use in Australia.&lt;/p>&#xd;&#xa;"
                            jcr:lastModified="{Date}2025-08-05T09:49:57.088-04:00"
                            jcr:lastModifiedBy="singarx"
                            jcr:primaryType="nt:unstructured"
                            jcr:title="&lt;p> A Portfolio of Medicines&lt;/p>&#xd;&#xa;"
                            sling:resourceType="abbvie-com2/components/teaser/v2/teaser"
                            ctaLink="/content/abbvie-com2/au/en/patients/products"
