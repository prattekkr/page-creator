                                <item_1670707220579
                                    cq:panelTitle="Allergan Aesthetics"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2023-02-02T14:40:02.779-05:00"
                                    jcr:lastModifiedBy="kokajx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Allergan Aesthetics, an AbbVie company, develops, manufactures and markets a portfolio of leading aesthetics brands and products. Be part of the team that believes in the power of confidence.&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>Our Allergan Aesthetics functions:&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Allergan Data Labs&lt;/li>&#xd;&#xa;&lt;li>Communications &amp;amp; Customer Engagement&lt;/li>&#xd;&#xa;&lt;li>Global Strategy &amp;amp; Pipeline Marketing&lt;/li>&#xd;&#xa;&lt;li>Sales&lt;/li>&#xd;&#xa;&lt;li>Sales Training&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1670707211154
                                    cq:panelTitle="Commercial"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2022-12-22T12:01:52.792-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Join sales, marketing and business support teams connecting patients to new therapies and solutions that can make a positive impact on their lives. &lt;/p>&#xd;&#xa;&lt;p>Our Commercial functions:&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Market Access &amp;amp; Managed Health Care&lt;/li>&#xd;&#xa;&lt;li>Market Analytics &amp;amp; Business Intelligence &lt;/li>&#xd;&#xa;&lt;li>Marketing&lt;/li>&#xd;&#xa;&lt;li>Sales&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1670707214308
                                    cq:panelTitle="Corporate"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2023-02-02T14:41:00.681-05:00"
                                    jcr:lastModifiedBy="kokajx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Find new ways to increase our competitive advantage, support our people and lead with integrity in everything we do.&lt;/p>&#xd;&#xa;&lt;p>Our Corporate functions:&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Business Technology Solutions (BTS)&lt;/li>&#xd;&#xa;&lt;li>Corporate Responsibility, Brand &amp;amp; Communications&lt;/li>&#xd;&#xa;&lt;li>Corporate Strategy Office (CSO)&lt;/li>&#xd;&#xa;&lt;li>Finance &amp;amp; Accounting&lt;/li>&#xd;&#xa;&lt;li>Government Affairs&lt;/li>&#xd;&#xa;&lt;li>Health Economics Outcomes Research&lt;/li>&#xd;&#xa;&lt;li>Human Resources&lt;/li>&#xd;&#xa;&lt;li>Legal&lt;/li>&#xd;&#xa;&lt;li>Office of Ethics and Compliance (OEC)&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1670707217700
                                    cq:panelTitle="Operations"
                                    jcr:lastModified="{Date}2023-01-31T14:00:01.262-05:00"
                                    jcr:lastModifiedBy="kokajx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p>Work with a global team of professionals responsible for supply and distribution of all AbbVie products, as well as several enterprise services, including facilities, purchasing and security.&lt;/p>&#xd;&#xa;&lt;p>Our Operations functions:&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Engineering&lt;/li>&#xd;&#xa;&lt;li>Facilities&lt;/li>&#xd;&#xa;&lt;li>Internal Manufacturing&lt;/li>&#xd;&#xa;&lt;li>External &amp;amp; Contract Manufacturing&lt;/li>&#xd;&#xa;&lt;li>Global Security&lt;/li>&#xd;&#xa;&lt;li>Pharmacy Solutions&lt;/li>&#xd;&#xa;&lt;li>Purchasing&lt;/li>&#xd;&#xa;&lt;li>Quality Assurance&lt;/li>&#xd;&#xa;&lt;li>Science &amp;amp; Technology&lt;/li>&#xd;&#xa;&lt;li>Supply Chain Management&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                                <item_1670707208042
                                    cq:panelTitle="Research &amp; Development"
                                    cq:styleIds="[1659545825678]"
                                    jcr:lastModified="{Date}2022-12-22T12:00:33.336-05:00"
                                    jcr:lastModifiedBy="chiucx"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/text/v2/text"
                                    text="&lt;p> Break new ground in the discovery and development of medicines and solutions and ensure our products and practices adhere to the highest regulatory standards.&amp;nbsp;&lt;/p>&#xd;&#xa;&lt;p>Our R&amp;amp;D functions:&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>Analytical Research &amp;amp; Development&lt;/li>&#xd;&#xa;&lt;li>Chemistry, Manufacturing &amp;amp; Controls (CMC)&lt;/li>&#xd;&#xa;&lt;li>Data &amp;amp; Statistical Sciences (DSS)&lt;/li>&#xd;&#xa;&lt;li>Discovery&lt;/li>&#xd;&#xa;&lt;li>Global Labeling, Advertising &amp;amp; Promotion&lt;/li>&#xd;&#xa;&lt;li>Global Medical Affairs&lt;/li>&#xd;&#xa;&lt;li>Global Product Strategy&lt;/li>&#xd;&#xa;&lt;li>Pharmaceutical Development&lt;/li>&#xd;&#xa;&lt;li>Pharmacovigilance&lt;/li>&#xd;&#xa;&lt;li>Pharmacology&lt;/li>&#xd;&#xa;&lt;li>Quality Assurance&lt;/li>&#xd;&#xa;&lt;li>Regulatory Operations, Policy &amp;amp; Intelligence&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                    textIsRich="true"/>
                            </accordion>
