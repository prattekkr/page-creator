                            <title_copy
                                cq:styleIds="[1659545825678,1661545829678]"
                                jcr:lastModified="{Date}2025-08-14T08:51:38.833-04:00"
                                jcr:lastModifiedBy="singarx"
                                jcr:primaryType="nt:unstructured"
                                jcr:title="Develop as a leader "
                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                type="h3"
                                variant="h"/>
                            <text
                                cq:styleIds="[1659545825678]"
                                jcr:lastModified="{Date}2025-08-14T08:56:33.349-04:00"
                                jcr:lastModifiedBy="singarx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Great leaders bring out the best in their teams. We’re committed to providing leaders with the tools to succeed in an ever-evolving landscape. Whether you’re a new, aspiring or experienced leader, AbbVie offers programs to help you grow and inspire others.&lt;br>&#xd;&#xa;&lt;br>&#xd;&#xa;Programs include:&lt;/p>&#xd;&#xa;&lt;ul>&#xd;&#xa;&lt;li>&lt;b>Development Workshops&lt;/b>, solutions and resources that enable leaders to advance their skills, expand their knowledge, amplify our culture, and progress in their careers&lt;/li>&#xd;&#xa;&lt;li>&lt;b>Leading at AbbVie&lt;/b>, a cohort-based program that supports first-time people leaders with critical skills needed to successfully lead individuals and teams&lt;/li>&#xd;&#xa;&lt;li>&lt;b>Key Talent Leadership Programs,&lt;/b> a suite of customised learning solutions designed for key talent leaders selected by their business for accelerated development&lt;/li>&#xd;&#xa;&lt;li>&lt;b>Executive Mentoring Program (EMP)&lt;/b>, pairs high performing talent with AbbVie senior executive leaders for a one-on-one mentoring partnership&lt;/li>&#xd;&#xa;&lt;li>&lt;b>Educational Assistance Program&lt;/b> which is available to eligible employees for courses with approved educational institutions at Diploma, Degree, Master, PhD or equivalent level.&amp;nbsp;&amp;nbsp;&lt;/li>&#xd;&#xa;&lt;/ul>&#xd;&#xa;"
                                textIsRich="true"/>
                        </container_1199983605>
                    </copy_of_container_co>
