                                jcr:created="{Date}2022-12-10T17:10:30.657-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2025-08-14T03:01:33.601-04:00"
                                jcr:lastModifiedBy="singarx"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Working at AbbVie is more than a job. It’s a career that grows with you. We invest in our people – through robust learning and development, meaningful benefits, and a commitment to creating an environment where everyone thrives.&lt;/p>&#xd;&#xa;"
