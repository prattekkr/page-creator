                            jcr:title="Η προσέγγισή μας στην Έρευνα &amp; Ανάπτυξη (R&amp;D)"
                            sling:resourceType="abbvie-com2/components/title/v2/title"
                            type="h3"
                            variant="h"/>
                        <text_1789249334_copy
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2022-12-07T14:53:09.069-05:00"
                            jcr:createdBy="chiucx"
                            jcr:lastModified="{Date}2024-06-29T14:08:33.603-04:00"
                            jcr:lastModifiedBy="GEORGIX2"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>Η επιστήμη και η καινοτομία αποτελούν την ψυχή της εταιρείας μας. Από την ανακάλυψη φαρμάκων έως τις κλινικές δοκιμές και την κανονιστική έγκριση, επιδιώκουμε να ανακαλύπτουμε νέους τρόπους για να βοηθήσουμε τους ασθενείς να αντιμετωπίσουν σοβαρά προβλήματα υγείας.&lt;/p>&#xd;&#xa;&lt;p>Από την ίδρυσή μας το 2013, έχουμε επενδύσει πάνω από 50 εκατομμύρια δολάρια σε R&amp;amp;D. Αυτό μας επιτρέπει να ανακαλύπτουμε και να προσφέρουμε καινοτόμα φάρμακα και προϊόντα που δίνουν λύση σε σοβαρά προβλήματα υγείας, βελτιώνουν τις ζωές των ανθρώπων και αντιμετωπίζουν τις ιατρικές προκλήσεις του μέλλοντος.&lt;/p>&#xd;&#xa;&lt;p>Εστιάζουμε σε βασικούς τομείς όπου η αποδεδειγμένη εμπειρία μας και η τολμηρή μας σκέψη μας δίνουν τη δυνατότητα να εργαστούμε για την κάλυψη των ακάλυπτων αναγκών των ασθενών. Οι τομείς αυτοί είναι η Αιματολογία - Ογκολογία, η Ανοσολογία, η Νευρολογία, η Οφθαλμολογία, η Αισθητική Ιατρική και άλλοι εξειδικευμένοι τομείς.&lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
                        <separator_copy_copy
                            cq:styleIds="[1662756555361]"
                            jcr:created="{Date}2023-06-09T05:06:22.499-04:00"
                            jcr:createdBy="JADHASX13"
                            jcr:lastModified="{Date}2023-06-09T05:09:26.813-04:00"
                            jcr:lastModifiedBy="JADHASX13"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/separator/v2/separator"/>
                        <title_1427339057_cop
                            cq:styleIds="[1659545825678,1661545829678]"
                            jcr:created="{Date}2022-12-07T14:53:17.160-05:00"
