                                text="&lt;p>&lt;span class=&quot;light-font&quot;>&lt;span class=&quot;body-unica-32-reg&quot;>AbbVie Pharmaceuticals S.A.&lt;/span>&lt;/span>&lt;/p>&#xd;&#xa;"
