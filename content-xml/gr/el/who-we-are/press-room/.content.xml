                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>&lt;span class=&quot;body-unica-26-reg&quot;>&lt;b>Οι άνθρωποι της AbbVie προσφέρουν στην κοινωνία και στο περιβάλλον μέσω του εθελοντικού προγράμματος Week of Possibilities&lt;/b>&lt;/span>&lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
                        <text_925029848
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2024-09-07T12:25:03.302-04:00"
                            jcr:createdBy="GEORGIX2"
                            jcr:lastModified="{Date}2024-09-07T12:25:52.669-04:00"
