                        <text_188599550
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2025-05-07T05:51:19.195-04:00"
                            jcr:createdBy="GEORGIX2"
                            jcr:lastModified="{Date}2025-05-07T05:52:51.543-04:00"
                            jcr:lastModifiedBy="GEORGIX2"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>&lt;span class=&quot;body-unica-26-reg&quot;>&lt;b>Δύο σημαντικές διακρίσεις για την AbbVie στην έρευνα&lt;/b> &lt;b>Best Workplaces™ 2025: 2&lt;sup>η&lt;/sup> θέση για το καλύτερο εργασιακό περιβάλλον &amp;amp; 5&lt;sup>η&lt;/sup> θέση για το καλύτερο εργασιακό περιβάλλον για τις γυναίκες&lt;/b>&lt;/span>&lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
                        <text_1546017718
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2025-05-07T05:53:22.313-04:00"
                            jcr:createdBy="GEORGIX2"
                            jcr:lastModified="{Date}2025-05-07T05:58:05.335-04:00"
                            jcr:lastModifiedBy="GEORGIX2"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>&lt;b>Δευτέρα 5 Μαΐου 2025. &lt;br />&#xd;&#xa;&lt;/b>&lt;br />&#xd;&#xa;Η &lt;b>AbbVie&lt;/b>, η παγκόσμια βιοφαρμακευτική εταιρεία, αναγνωρίστηκε από τον Οργανισμό Great Place to Work® Hellas ως μία από τις &lt;b>εταιρείες&lt;/b> με το &lt;b>καλύτερο εργασιακό περιβάλλον&lt;/b> στην Ελλάδα, κατακτώντας τη &lt;b>2η θέση στη συνολική λίστα Best Workplaces™ 2025&lt;/b> και την &lt;b>5η θέση στη λίστα Best Workplaces™ for Women Hellas, ως καλύτερο εργασιακό περιβάλλον&lt;/b> &lt;b>για τις γυναίκες&lt;/b>, στην κατηγορία 100-250 εργαζομένων. Οι &lt;b>δύο διακρίσεις&lt;/b> υπογραμμίζουν τη &lt;b>στρατηγική επένδυση της AbbVie&lt;/b> στους &lt;b>εργαζομένους&lt;/b> της και στην αφοσίωσή της στην καλλιέργεια μιας κουλτούρας που απορρίπτει κάθε διάκριση, που προωθεί την έμφυλη ισότητα, την πρόσβαση σε ίσες ευκαιρίες στις προσλήψεις, στις προαγωγές, στις απολαβές και στην ανάπτυξη, και ενθαρρύνει τον αλληλοσεβασμό και τη συνεργασία μεταξύ των εργαζομένων. &lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
                        <button_1016099419
                            cq:styleIds="[1659997777274]"
                            jcr:created="{Date}2025-05-07T05:58:26.277-04:00"
                            jcr:createdBy="GEORGIX2"
                            jcr:lastModified="{Date}2025-05-07T06:28:32.296-04:00"
                            jcr:lastModifiedBy="GEORGIX2"
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Διαβάστε το πλήρες Δελτίο Τύπου"
                            sling:resourceType="abbvie-com2/components/button/v2/button"
                            accessibilityLabel="Διαβάστε το πλήρες Δελτίο Τύπου"
                            linkTarget="_blank"
                            linkURL="/content/dam/abbvie-com2/gr/news/Δελτίο Τύπου_AbbVie_Δύο σημαντικές διακρίσεις για την AbbVie στην έρευνα Best Workplaces™ 2025_05052025.pdf"/>
                        <text_copy
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2024-09-07T12:00:26.460-04:00"
                            jcr:createdBy="GEORGIX2"
                            jcr:lastModified="{Date}2025-02-18T07:54:51.502-05:00"
                            jcr:lastModifiedBy="GEORGIX2"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>&lt;span class=&quot;body-unica-26-reg&quot;>&lt;b>H AbbVie αποκτά&amp;nbsp;την&amp;nbsp;Πιστοποίηση&amp;nbsp;Great Place to&amp;nbsp;Work&lt;sup>®&amp;nbsp;&lt;/sup>2025&lt;/b>&lt;/span>&lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
                        <text_1931862036
                            cq:styleIds="[1659545825678]"
                            jcr:created="{Date}2025-02-18T07:55:03.484-05:00"
                            jcr:createdBy="GEORGIX2"
                            jcr:lastModified="{Date}2025-02-18T07:56:09.107-05:00"
                            jcr:lastModifiedBy="GEORGIX2"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="abbvie-com2/components/text/v2/text"
                            text="&lt;p>&lt;b>Πέμπτη 23 Ιανουαρίου 2025. &lt;/b>&lt;/p>&#xd;&#xa;&lt;p>Η &lt;b>AbbVie Ελλάδας&lt;/b> λαμβάνει την &lt;b>Πιστοποίηση Great Place to Work® Hellas&lt;/b>,&lt;b> &lt;/b>για μία ακόμα χρονιά. Μια σημαντική αναγνώριση η οποία υπογραμμίζει τη συμπεριληπτική, καινοτόμο και οραματική εργασιακή κουλτούρα της εταιρείας που την καθιστά ως έναν εκ των κορυφαίων εργοδοτών επιλογής. Η πιστοποίηση απορρέει από μία αδιάβλητη διαδικασία αξιολόγησης και μία σειρά αυστηρών κριτηρίων πιστοποίησης από τον Οργανισμό Great Place to Work® Hellas, λαμβάνοντας υπόψη την εργασιακή εμπειρία των εργαζομένων, μέσα από ανώνυμες και εμπιστευτικές απαντήσεις. &lt;/p>&#xd;&#xa;"
                            textIsRich="true"/>
                        <button_copy_copy_618318824
                            cq:styleIds="[1659997777274]"
                            jcr:created="{Date}2024-11-24T16:38:26.095-05:00"
