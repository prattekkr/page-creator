                                jcr:title="Η δέσμευσή μας"
                                sling:resourceType="abbvie-com2/components/title/v2/title"
                                type="h3"
                                variant="h"/>
                            <text_copy_copy
                                cq:styleIds="[1659545825678]"
                                jcr:created="{Date}2022-12-09T17:34:50.014-05:00"
                                jcr:createdBy="chiucx"
                                jcr:lastModified="{Date}2024-06-29T13:38:10.672-04:00"
                                jcr:lastModifiedBy="GEORGIX2"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="abbvie-com2/components/text/v2/text"
                                text="&lt;p>Δεσμευόμαστε να υποστηρίζουμε την ισοτιμία, την ισότητα, τη διαφορετικότητα και τη συμπερίληψη. Είναι θεμελιώδες χαρακτηριστικό της ταυτότητάς μας. Εξάλλου, μόνο έτσι γνωρίζουμε να εργαζόμαστε. Αυτό συνεπάγεται την εκτίμηση των διαφορετικών απόψεων, την καλλιέργεια μιας κουλτούρας συμπερίληψης και την αντιμετώπιση όλων των εργαζομένων με αξιοπρέπεια και σεβασμό.&lt;/p>&#xd;&#xa;&lt;p>&lt;b>Χώρος για μέγιστη απόδοση...&lt;/b>&lt;/p>&#xd;&#xa;&lt;p>Στην AbbVie, θεωρούμε ότι ο σεβασμός στη διαφορετικότητα και η κουλτούρα συμπερίληψης είναι υποχρέωση και καθήκον της εταιρείας.&amp;nbsp;Δεσμευόμαστε να λειτουργούμε με ακεραιότητα, να προωθούμε την καινοτομία, να μεταμορφώνουμε ζωές, να υπηρετούμε την κοινότητά μας, να αγκαλιάζουμε τη διαφορετικότητα και να καλλιεργούμε τη συμπερίληψη.&amp;nbsp;Δεν είναι μόνο το ηθικά ορθό. Ενισχύει, παράλληλα, την ικανότητά μας να καινοτομούμε και είναι ζωτικής σημασίας για την απόδοσή μας, τώρα και στο μέλλον.&lt;/p>&#xd;&#xa;&lt;p>&lt;b>...με στόχο να έχουμε σημαντικό αντίκτυπο στους ασθενείς&lt;/b>&lt;/p>&#xd;&#xa;&lt;p>Η ανάπτυξη και η διάθεση καινοτόμων φαρμάκων που αλλάζουν τη ζωή των ασθενών απαιτεί πολυφωνία - και η πολυφωνία προέρχεται από ένα πολυσυλλεκτικό ανθρώπινο δυναμικό.&amp;nbsp;Εξίσου σημαντικό είναι ότι εξυπηρετούμε ποικίλους πληθυσμούς ασθενών σε όλον τον κόσμο και είναι ζωτικής σημασίας αυτοί να εκπροσωπούνται και να ακούγονται μέσα στην εταιρεία.&lt;/p>&#xd;&#xa;"
                                textIsRich="true"/>
                            <button
