                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="abbvie-com2/components/quote"
                                    attributionName="Rae Livingston"
                                    attributionTitle="Chief Equity Officer, AbbVie"
                                    quote="Είμαι περήφανος για ό,τι κάναμε και υπάρχουν ακόμη περισσότερα να κάνουμε για να επιτύχουμε πλήρως την πρόθεση και τα επιθυμητά αποτελέσματα του οράματός μας για Ισότητα, Ισότητα, Διαφορετικότητα και Ένταξη. Η διατήρηση μιας κουλτούρας χωρίς αποκλεισμούς έχει να κάνει με αυτό που κάνουμε καθημερινά – δεν είναι μια εκδήλωση. Αυτή η δουλειά δεν είναι πάντα εύκολη. Επιμένουμε γιατί ό,τι πετυχαίνουμε εμπνέει ελπίδα και αλλάζει ζωές – κάθε μέρα."
                                    quoteType="regular"
                                    textSize="h0"/>
