        "children": [
          {
            "type": "accordion-item",
            "props": {
              "summary": "Fellowships Experience",
              "classes_defaultOpen": false,
              "cq:lastRolledout": "Tue Jun 16 2026 09:04:49 GMT+0000",
              "text": "\n<ul>\n <li>Professional development</li>\n <li>Mentorship and guidance from seasoned professionals</li>\n <li>Graduate-level coursework and seminars at partner institutions</li>\n <li>Potential to be placed in rewarding positions</li>\n <li>Develop skills required to excel in your field</li>\n</ul>\n<p><strong>Location</strong></p>\n<p>Irvine, CA; Lake County, IL; Branchburg, NJ; or Madison, NJ (Fellow placements vary by focus area).</p>\n<p><strong>Can I apply?</strong></p>\n<p>If you are in the final year of your PharmD or PhD program (or hold your degree) and are ready to take the next step into the pharmaceutical industry, our fellowships offer a launchpad for leadership and innovation. Recruitment begins each fall.</p>",
              "cq:lastRolledoutBy": "sheetal.joshi@abbvie.com"
            },
