      },
      {
        "type": "custom-title",
        "props": {
          "filter": "custom-title",
          "titleType": "h5",
          "classes_customDynamicClass": "h5-size,format-raised,width-large",
          "title": "1. Smarter patient matching"
        },
        "children": []
      },
      {
        "type": "text-container",
        "props": {
          "filter": "text-container",
          "classes_customDynamicClass": "spacing-bottom,width-large"
        },
        "children": [
          {
            "type": "text-container-text",
            "props": {
              "text": "<p>By using AI-driven trial matching, AbbVie can identify the right patients for clinical trials in a fraction of the time it once took.</p>"
            },
            "children": []
          }
        ]
      },
      {
        "type": "custom-title",
        "props": {
          "filter": "custom-title",
          "titleType": "h5",
          "classes_customDynamicClass": "h5-size,format-outdented,width-large",
          "title": "2. Decentralized trial infrastructure"
        },
        "children": []
      },
      {
        "type": "text-container",
        "props": {
          "filter": "text-container",
          "classes_customDynamicClass": "spacing-bottom,width-large"
        },
        "children": [
          {
            "type": "text-container-text",
            "props": {
              "text": "<p>Remote monitoring and digital endpoints let patients participate from home, broadening diversity and accelerating enrollment.</p>"
            },
            "children": []
          }
        ]
      }
    ]
