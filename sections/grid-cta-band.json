{
  "id": "grid-cta-band",
  "title": "Grid: CTA Band (7+2+3)",
  "description": "Coloured promo band: wide heading left, CTA button pushed right",
  "icon": "⊞",
  "section": {
    "type": "grid-container",
    "props": {
      "style_container": "grid-container",
      "style_contentWidth": "content-wide",
      "style_padding": "regular-padding",
      "style_borderRadius": "radius-medium",
      "style_bg-color": "bg-8a2ecc",
      "style_customDynamicClass": "content-wide,bg-8a2ecc,height-short,medium-radius,no-bottom-margin,regular-padding,padding-bottom"
    },
    "blocks": [
      {
        "type": "grid-section",
        "props": {
          "style_gridCols": "grid-cols-7",
          "style_customDynamicClass": "grid-cols-7"
