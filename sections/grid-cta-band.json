        "children": [
          {
            "type": "custom-title",
            "props": {
              "title": "Join the team working to transform patient care",
              "titleType": "h4",
              "classes_customDynamicClass": "h4-size,theme-dark",
              "classes_theme": "theme-dark"
            }
          }
        ]
      },
      {
        "type": "grid-section",
        "props": {
          "style_gridCols": "grid-cols-2",
          "style_customDynamicClass": "grid-cols-2"
        },
        "children": []
      },
      {
        "type": "grid-section",
        "props": {
          "style_gridCols": "grid-cols-3",
          "style_customDynamicClass": "grid-cols-3"
        },
        "children": [
          {
            "type": "cta",
            "props": {
              "linkText": "Explore R&D opportunities",
              "link": "https://www.abbvie.com/join-us/opportunities/research-and-development.html",
              "ctaTarget": "_self",
              "classes": "default-cta",
              "classes_theme": "dark-theme",
              "classes_customDynamicClass": "dark-theme",
              "iconPosition": "after"
            }
          }
        ]
      }
    ]
  }
}
