{
  "id": "cta-band-brand",
  "title": "CTA Band (Brand Color)",
  "description": "Full-width branded color (purple/blue) CTA band with 7+2+3 grid: title on left, spacer, and CTA button on right",
  "icon": "⊞",
  "section": {
    "type": "grid-container",
    "props": {
      "style_customDynamicClass": "medium-radius,bg-8a2ecc,no-bottom-margin,regular-padding,padding-bottom,height-short,no-side-margin",
      "style_bg-color": "bg-8a2ecc",
      "style_contentWidth": "content-wide",
      "style_borderRadius": "radius-medium",
      "style_padding": "regular-padding",
      "filter": "grid-container"
    },
    "blocks": [
      {
        "type": "grid-section",
        "props": {
          "style_gridCols": "grid-cols-7",
          "style_customDynamicClass": "grid-cols-7",
          "filter": "grid-section"
        },
        "children": [
          { "type": "custom-title", "props": { "filter": "custom-title" } }
        ]
      },
      {
        "type": "grid-section",
        "props": {
          "style_gridCols": "grid-cols-2",
          "style_customDynamicClass": "grid-cols-2",
          "filter": "grid-section"
        },
        "children": []
      },
      {
        "type": "grid-section",
        "props": {
          "style_gridCols": "grid-cols-3",
          "style_customDynamicClass": "grid-cols-3",
          "filter": "grid-section"
        },
        "children": [
          { "type": "cta", "props": {} }
        ]
      }
    ]
  }
}
