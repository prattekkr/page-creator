                        name="Text Container Text"
                        text="&lt;p>&lt;em>Watch how Rhonda (left) and Kim’s (right) paths converge — and how perseverance, science and innovation are working to uncover what’s next for Parkinson’s.&lt;/em>&lt;/p>"/>
                </block_3>
                <block_4
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    blockId="\0"
