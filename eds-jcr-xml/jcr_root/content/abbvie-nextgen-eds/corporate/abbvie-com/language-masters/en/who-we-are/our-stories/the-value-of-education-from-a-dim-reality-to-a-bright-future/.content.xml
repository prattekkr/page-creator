                    name="Custom Title"
                    title="‘Don’t let it defeat you’"
                    titleType="h2"/>
                <block_11
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="-"
                    blockId="-"
                    classes_customDynamicClass="spacing-bottom,width-large"
                    filter="text-container"
                    language="none"
                    model="text-container"
                    modelFields="[classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Text Container">
                    <item_0
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="text-container-text"
                        modelFields="[text]"
                        name="Text Container Text"
                        text="&lt;p>Bailey continued to face hardships after leaving the home of his stepmom and dad, like the unexpected death of his older sister. But he persevered, eventually becoming the first person in his family to graduate high school before continuing his education.&lt;/p>"/>
                </block_11>
                <block_12
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    attributionName="Fredrick Bailey"
                    attributionRole="Communities In Schools alum"
                    backgroundImageAlt="\0"
                    blockId="\0"
                    classes_contentAlignment="quote-align-none"
                    classes_contentWidth="quote-content-col-none"
                    classes_theme="quote-none"
                    customClass="\0"
                    id="\0"
                    language="quote-standard,quote-h4"
                    model="quote"
                    modelFields="[quoteVariant,quotation,attributionName,attributionRole,attributionImage,attributionImageMimeType,quoteFragment,backgroundImage,backgroundImageAlt,backgroundImageMimeType,classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Quote"
                    quotation="&lt;p>If it was not for Communities In Schools in my life, I don’t know what type of man I would be today.&lt;/p>"
                    quoteVariant="quote-standard"/>
                <block_13
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="-"
                    blockId="-"
                    classes_customDynamicClass="spacing-bottom,width-large"
                    filter="text-container"
                    language="none"
                    model="text-container"
                    modelFields="[classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Text Container">
                    <item_0
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="text-container-text"
                        modelFields="[text]"
                        name="Text Container Text"
                        text="&lt;p>Bailey continues to pay it forward by mentoring young men and tutoring students in reading, an area where he particularly struggled as a child.&lt;br> &lt;br> “If it was not for Communities In Schools in my life, I don’t know what type of man I would be today,” Bailey says.&lt;br> &lt;br> Being named as an inaugural Bill and Jean Milliken Fellow is a continuation of Bailey’s 15-year relationship with CIS, allowing him to help create new opportunities for young people who may be losing hope or who face seemingly insurmountable challenges.&lt;br> &lt;br> He often revisits the memory of the bucket he used to collect rainwater, framing it as an opportunity to ask young people, “What’s in your bucket?”&lt;br> &lt;br> “Don’t let it defeat you,” Bailey says. “Refill it with joy, peace, love, faith, hope and other good things.”&lt;/p>"/>
                </block_13>
