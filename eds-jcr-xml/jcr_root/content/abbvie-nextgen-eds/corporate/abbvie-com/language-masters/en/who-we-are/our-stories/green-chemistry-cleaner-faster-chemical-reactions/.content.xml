                        modelFields="[text]"
                        name="Text Container Text"
                        text="&lt;p>Wilfried Braje, Ph.D., research scientist, AbbVie, uses technology that creates chemical reactions with less energy and produces less waste.&lt;/p>"/>
                </block>
                <block_1
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    blockId="\0"
