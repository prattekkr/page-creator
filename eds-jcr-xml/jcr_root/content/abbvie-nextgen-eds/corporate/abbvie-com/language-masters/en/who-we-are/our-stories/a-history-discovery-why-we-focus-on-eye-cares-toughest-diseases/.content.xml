                    name="Custom Title"
                    title="Continuing a long journey of discovery"
                    titleType="h2"/>
                <block_2
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="-"
                    blockId="-"
                    classes_customDynamicClass="spacing-bottom,width-large"
                    filter="text-container"
                    language="none"
                    model="text-container"
                    modelFields="[classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Text Container">
                    <item_0
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="text-container-text"
                        modelFields="[text]"
                        name="Text Container Text"
                        text="&lt;p>Patrice Keegan has lived with a progressive, hereditary eye disease for 20 years, one that affects millions of people around the globe and is the second-leading cause of blindness.&lt;/p>&lt;p>Yet, the New York resident finds that many people don’t understand glaucoma and how it affects her daily life.&lt;/p>&lt;p>A narrow field of vision, balance issues and frequent falls have limited Keegan’s independence and ability to do what she loves, like travel and cook.&lt;/p>&lt;p>“I don't want my family members, my grandchildren to have to experience the symptoms and the loss of vision that I have,” she says. “That's why raising the standard is important.”&lt;/p>"/>
                </block_2>
                <block_3
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="-"
                    blockId="-"
                    classes_overlayColor="video-overlay-navy"
                    enableAutoplay="false"
                    enableCaptions="false"
                    enableFullscreen="true"
                    enablePlayerControls="true"
                    filter="video"
                    language="none"
                    model="video"
                    modelFields="[uri,placeholderImage,placeholderImageMimeType,posterAccessibilityLabel,overlayHeading,overlayDescription,overlayButtonLabel,videoContentLayout,classes_overlayColor,classes_overlayBtnStyle,overlayButtonIconKind,overlayButtonFontIcon,projectNumber,enableAutoplay,enableCaptions,enablePlayerControls,enableFullscreen,classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Video"
                    overlayButtonFontIcon="play"
                    overlayButtonIconKind="icon-font"
                    overlayButtonLabel="watch 0:22"
                    overlayDescription="-"
                    overlayHeading="Envisioning a better future for glaucoma patients"
                    placeholderImage="https://delivery-p157365-e1665873.adobeaemcloud.com/adobe/assets/urn:aaid:aem:d7e735e4-e5d1-4d8c-ae01-36aac63bd007/as/history-of-discovery-yt-screenshot.jpg"
                    placeholderImageMimeType="image/unknown"
                    posterAccessibilityLabel="history of discovery youtube"
                    projectNumber="-"
                    uri="https://www.youtube.com/embed/o5_LJ5fqHSA?enablejsapi=1&amp;origin=https%3A%2F%2Fwww.abbvie.com&amp;widgetid=1&amp;forigin=https%3A%2F%2Fwww.abbvie.com%2Fwho-we-are%2Four-stories%2Fa-history-discovery-why-we-focus-on-eye-cares-toughest-diseases.html&amp;aoriginsup=1&amp;vf=1"
                    videoContentLayout="none"/>
                <block_4
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    blockId="\0"
                    classes_customDynamicClass="h5-size,width-large"
