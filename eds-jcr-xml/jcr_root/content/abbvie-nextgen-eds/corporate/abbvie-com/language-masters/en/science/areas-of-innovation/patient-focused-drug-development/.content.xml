                    modelFields="[title,titleType,classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Custom Title"
                    title="Diversifying our clinical trials"
                    titleType="h3"/>
                <block_9
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="-"
                    blockId="-"
                    classes_customDynamicClass="width-large"
                    filter="text-container"
                    language="none"
                    model="text-container"
                    modelFields="[classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Text Container">
                    <item_0
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="text-container-text"
                        modelFields="[text]"
                        name="Text Container Text"
                        text="&lt;p>We believe clinical trials should reflect the populations we serve. Led by our dedicated Patient Inclusion team, we work to design inclusive study protocols, enable underrepresented populations to volunteer and continuously evaluate our clinical trial eligibility criteria against real-world datasets — so that all patients can have their voices heard.&lt;/p>"/>
                </block_9>
                <block_10
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="none"
                    classes_customDynamicClass="separator-height-48"
                    filter="separator"
                    model="separator"
                    modelFields="[showLine,classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Separator"
                    showLine="false"/>
                <block_11
