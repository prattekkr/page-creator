                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="text-container-text"
                        modelFields="[text]"
                        name="Text Container Text"
                        text="&lt;p>We work to better understand the experience of people living with a disease or condition, integrating their perspectives throughout our clinical development process to meet their specialized health needs. We develop robust patient journey maps to understand the transactional and emotional journey people experience from diagnosis through treatment and beyond.&lt;/p>"/>
                </block_12>
                <block_13
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="none"
                    classes_customDynamicClass="separator-height-48"
