                    model="text-container"
                    modelFields="[classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Text Container">
                    <item_0
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="text-container-text"
                        modelFields="[text]"
                        name="Text Container Text"
                        text="&lt;p>A subtle reminder that each person, each patient matters.&lt;/p>"/>
                </block_14>
                <block_15
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    blockId="\0"
                    classes_customDynamicClass="h5-size,format-outdented,width-large"
                    filter="custom-title"
                    language="none"
                    model="custom-title"
                    modelFields="[title,titleType,classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Custom Title"
                    title="Q: You have a lot of items on your desk. Is each one special to you?"
                    titleType="h5"/>
                <block_16
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="-"
                    blockId="-"
                    classes_customDynamicClass="spacing-bottom,width-large"
                    filter="text-container"
                    language="none"
                    model="text-container"
                    modelFields="[classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Text Container">
                    <item_0
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="text-container-text"
                        modelFields="[text]"
                        name="Text Container Text"
                        text="&lt;p>There is a small rock on my desk that has the number 22 written on it. A military veteran who worked on my team at AbbVie gave it to me to let me know he was not going to be one of the 22 veterans estimated to take their own life each day. He said that his career at AbbVie gave him a sense of purpose and belonging. I look at that rock every time I sit at my desk and reflect on my own sense of purpose and belonging. Not only here at AbbVie, but in the world.&lt;/p>"/>
                </block_16>
                <block_17
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    blockId="\0"
                    classes_customDynamicClass="h5-size,format-outdented,width-large"
                    filter="custom-title"
                    language="none"
                    model="custom-title"
                    modelFields="[title,titleType,classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Custom Title"
                    title="Q: How do you describe your leadership style today?"
                    titleType="h5"/>
                <block_18
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="-"
                    blockId="-"
                    classes_customDynamicClass="spacing-bottom,width-large"
                    filter="text-container"
                    language="none"
                    model="text-container"
                    modelFields="[classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Text Container">
                    <item_0
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="text-container-text"
                        modelFields="[text]"
                        name="Text Container Text"
                        text="&lt;p>I get asked that question a lot, and I usually give 2 answers: 1) I am an inclusive leader who acknowledges the power of diverse thought and curiosity. 2) Ask my amazing team, they are the ones who know my style best.&lt;/p>&lt;p>&lt;a href=&quot;https://www.abbvie.com/our-science/our-rd-leaders/linda-scarazzini.html&quot;>Learn More about Linda&lt;/a>&lt;/p>"/>
                </block_18>
                <block_19
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="-"
                    blockId="-"
                    classes_customDynamicClass="spacing-bottom,width-large,body-unica-20-reg"
                    filter="text-container"
                    language="none"
                    model="text-container"
                    modelFields="[classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Text Container">
                    <item_0
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="text-container-text"
                        modelFields="[text]"
                        name="Text Container Text"
