                    modelFields="[title,titleType,classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Custom Title"
                    title="Support through every phase of the cancer journey"
                    titleType="h2"/>
                <block_12
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="-"
                    blockId="-"
                    classes_customDynamicClass="spacing-bottom,width-large"
                    filter="text-container"
                    language="none"
                    model="text-container"
                    modelFields="[classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Text Container">
                    <item_0
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="text-container-text"
                        modelFields="[text]"
                        name="Text Container Text"
                        text="&lt;p>No one should face cancer alone, which is why AbbVie has enlisted a full suite of oncology care resources to help guide its U.S.-based employees and their family members through every phase of the cancer journey.&lt;/p>&lt;p>AbbVie has partnered with a specialized vendor to offer enhanced oncology benefits through a personalized healthcare app. Examples of no-cost services provided by the app include cancer screening reminders that aid in prevention and early detection. It also incorporates treatment navigation to coordinate expert opinions from National Cancer Institute-designated centers.&lt;/p>&lt;p>Whether it's understanding available benefits, navigating health care complexities or identifying oncology providers, AbbVie is providing personalized help to employees navigating this challenging time, allowing its people to focus on what truly matters to them and their loved ones.&lt;/p>"/>
                </block_12>
                <block_13
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    attributionImage="https://delivery-p157365-e1665873.adobeaemcloud.com/adobe/assets/urn:aaid:aem:cf6992b3-d667-4725-a1b0-2811d81fbb55/as/Lesli-Marasco-headshot.jpg"
                    attributionImageMimeType="image/unknown"
                    attributionName="Lesli Marasco,"
                    attributionRole="VP, Global Benefits and Well-being, AbbVie"
                    backgroundImageAlt="\0"
                    blockId="\0"
                    classes_contentAlignment="quote-align-none"
                    classes_contentWidth="quote-content-col-none"
                    classes_theme="quote-none"
                    customClass="\0"
                    id="\0"
                    language="quote-standard,quote-h4"
                    model="quote"
                    modelFields="[quoteVariant,quotation,attributionName,attributionRole,attributionImage,attributionImageMimeType,quoteFragment,backgroundImage,backgroundImageAlt,backgroundImageMimeType,classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Quote"
                    quotation="&lt;p>It's about more than just benefits; it's about standing together, empowering our people and making a real difference in their lives.&lt;/p>"
                    quoteVariant="quote-standard"/>
                <block_14
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="-"
                    blockId="-"
                    classes_customDynamicClass="spacing-bottom,width-large"
                    filter="text-container"
                    language="none"
