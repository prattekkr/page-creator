                    titleType="h3"/>
                <block_6
                    jcr:lastModified="{Date}2026-06-17T13:42:33.043Z"
                    jcr:lastModifiedBy="inf44580@adobe.com"
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="-"
                    classes_commonCustomClass="margin-bottom-30,col-1"
