                    language="none"
                    model="text-container"
                    modelFields="[classes_customDynamicClass@ngaem:dynamic-picklist,blockId@text,classes_commonCustomClass@text,language@select,analytics_id@text]"
                    name="Text Container">
                    <item_0
                        jcr:lastModified="{Date}2026-06-15T10:33:23.945Z"
                        jcr:lastModifiedBy="inf44580@adobe.com"
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="text-container-text"
                        modelFields="[text@richtext]"
                        name="Text Container Text"
                        text="&lt;p>&lt;strong>Is the online application right for you?&lt;/strong>&lt;/p>&#xa;&lt;p>Our online application is for use by people over the age of eighteen and seeking assistance (the patient) for either CREON&lt;sup>®&lt;/sup> (pancrelipase), HUMIRA&lt;sup>®&lt;/sup> (adalimumab), LINZESS&lt;sup>®&lt;/sup> (linaclotide), MAVYRET&lt;sup>®&lt;/sup> (glecaprevir/pibrentasvir), QULIPTA&lt;sup>®&lt;/sup> (atogepant), RINVOQ&lt;sup>®&lt;/sup> (upadacitinib), SKYRIZI&lt;sup>®&lt;/sup> (risankizumab-rzaa), UBRELVY&lt;sup>®&lt;/sup> (ubrogepant), VIBERZI&lt;sup>®&lt;/sup> (eluxadoline), or VRAYLAR&lt;sup>®&lt;/sup> (cariprazine).&amp;nbsp; We will ask you to register and complete an application. Before you start, please make sure that you have electronic copies of the necessary documents, listed further below.&lt;/p>&#xa;&lt;p>While you can apply online, we will also need the health care provider who has prescribed your medication to submit application documents separately. Once you have submitted your application and supporting documents, we will contact your health care provider to obtain your prescription and other needed information.&lt;/p>&#xa;&lt;p>This website will guide you through the steps needed to complete your application and will allow you to sign up for text or e-mail updates from the program:&lt;/p>"/>
                </block_6>
                <text_container
                    jcr:created="{Date}2026-06-15T10:42:52.155Z"
                    jcr:createdBy="inf44580@adobe.com"
                    jcr:lastModified="{Date}2026-06-17T13:42:52.787Z"
                    jcr:lastModifiedBy="inf44580@adobe.com"
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    aueComponentId="text-container"
                    classes_commonCustomClass="margin-left-40,margin-bottom-30,col-1"
                    filter="text-container"
                    language="none"
                    model="text-container"
                    modelFields="[classes_customDynamicClass@ngaem:dynamic-picklist,blockId@text,classes_commonCustomClass@text,language@select,analytics_id@text]"
                    name="Text Container">
                    <text_container_text
                        jcr:created="{Date}2026-06-15T10:42:59.386Z"
                        jcr:createdBy="inf44580@adobe.com"
                        jcr:lastModified="{Date}2026-06-15T10:44:16.426Z"
                        jcr:lastModifiedBy="inf44580@adobe.com"
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        aueComponentId="text-container-text"
                        model="text-container-text"
                        modelFields="[text@richtext]"
                        name="Text Container Text"
                        text="&lt;p>&lt;strong>Step One:&lt;/strong>&amp;nbsp;Enter your information into our website and create an account.&amp;nbsp;&lt;/p>&#xa;&lt;p>&lt;strong>Step Two:&lt;/strong>&amp;nbsp;Follow the screens to provide income and insurance information for the application process. &amp;nbsp;Please note: We will assess income electronically when you provide written instructions to the Program under the Fair Credit Reporting Act, solely to determine patient assistance program eligibility. If the program is unable to determine income, you may be asked to provide additional financial documentation such as your most recent tax return or similar document.&lt;/p>&#xa;&lt;p>The system will prompt you to upload copies of your insurance cards if you have them.&amp;nbsp;&amp;nbsp;&lt;/p>&#xa;&lt;p>&lt;strong>Step Three:&lt;/strong>&amp;nbsp;Upload any additional documents that may help us understand your difficulty accessing your medicine.&lt;/p>&#xa;&lt;p>&lt;strong>Step Four:&lt;/strong>&amp;nbsp;Review our privacy notice and program terms to understand how we use your personal data, acknowledge your understanding and submit.&lt;/p>"/>
                </text_container>
                <text_container_1947008991
                    jcr:created="{Date}2026-06-15T11:03:32.717Z"
                    jcr:createdBy="inf44580@adobe.com"
                    jcr:lastModified="{Date}2026-06-17T13:43:11.139Z"
                    jcr:lastModifiedBy="inf44580@adobe.com"
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    aueComponentId="text-container"
                    classes_commonCustomClass="margin-bottom-30,col-1"
                    filter="text-container"
                    language="none"
                    model="text-container"
                    modelFields="[classes_customDynamicClass@ngaem:dynamic-picklist,blockId@text,classes_commonCustomClass@text,language@select,analytics_id@text]"
                    name="Text Container">
                    <text_container_text
                        jcr:created="{Date}2026-06-15T11:03:59.220Z"
                        jcr:createdBy="inf44580@adobe.com"
                        jcr:lastModified="{Date}2026-06-15T11:51:48.350Z"
                        jcr:lastModifiedBy="inf44580@adobe.com"
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        aueComponentId="text-container-text"
                        model="text-container-text"
                        modelFields="[text@richtext]"
                        name="Text Container Text"
                        text="&lt;p>We will contact your prescribing doctor for the remaining information. We also will notify you and your health care provider after we have reviewed your application. If you are approved for assistance through the myAbbVie Assist Patient Assistance Program, you may use this site to schedule refill deliveries based on the prescription from your health care provider.&amp;nbsp;&amp;nbsp;&lt;br>&amp;lt;br&amp;gt;&lt;/p>&#xa;&lt;p>&lt;strong>What documents must be electronically available?&lt;/strong>&lt;/p>&#xa;&lt;ul>&#xa; &lt;li>&lt;strong>Insurance Information:&lt;/strong> If you have insurance, you will need to provide the following documents:&#xa;  &lt;ul>&#xa;   &lt;li>Prescription or medical insurance card – a front and back copy of the card is needed.&lt;br>&amp;lt;br&amp;gt;&lt;/li>&#xa;  &lt;/ul>&lt;/li>&#xa; &lt;li>&lt;strong>Income documents:&lt;/strong> If we are unable to determine your income electronically, we may request your Federal Tax Return for the most current filing year. If you do not have a tax return, we will accept copies of your pay stub (for at least two pay periods), social security statement, social security disability statement, W-2 form, or 1099-R form.&lt;/li>&#xa;&lt;/ul>&#xa;&lt;p>Click&amp;nbsp;&lt;a href=&quot;https://www.abbvie.com/content/dam/abbvie-com2/pdfs/pap/patient-assistance-application-expense-form.pdf&quot;>here&lt;/a>&amp;nbsp;for an optional expense form that can be used to document your prescription and medical expenses.&lt;/p>&#xa;&lt;p>&lt;strong>&lt;br>&lt;br>What if I am not the patient OR the patient is under 18 yrs old OR I do not have all my documents available electronically?&lt;/strong>&lt;/p>"/>
                </text_container_1947008991>
                <text_container_19470
                    jcr:created="{Date}2026-06-15T11:03:32.717Z"
                    jcr:createdBy="inf44580@adobe.com"
                    jcr:lastModified="{Date}2026-06-17T13:43:27.863Z"
                    jcr:lastModifiedBy="inf44580@adobe.com"
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    aueComponentId="text-container"
                    classes_commonCustomClass="margin-left-40,margin-bottom-30,col-1"
