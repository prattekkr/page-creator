                    modelFields="[blockHeading,classes_allowMultipleOpen,classes_showExpandCollapseAll,expandAllLabel,collapseAllLabel,expandAllIcon,collapseAllIcon,expandIcon,collapseIcon,expandAllIconImage,collapseAllIconImage,expandIconImage,collapseIconImage,ariaExpandAllLabel,ariaCollapseAllLabel,classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Accordion">
                    <item_0
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="accordion-item"
                        modelFields="[summary,text,classes_defaultOpen,ariaExpandLabel,ariaCollapseLabel]"
                        name="Accordion Item"
                        summary="What is inflammatory bowel disease, or IBD?"
                        text="&lt;p>Inflammatory bowel disease (IBD) is a chronic condition that involves inflammation of the digestive tract. There are two main types:&lt;/p>&lt;p>&lt;ol> &lt;li>Crohn's disease, which can affect any part of the gastrointestinal tract&lt;/li> &lt;li>Ulcerative colitis, which specifically impacts the colon and rectum&lt;/li> &lt;/ol>&lt;/p>"/>
                    <item_1
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="accordion-item"
                        modelFields="[summary,text,classes_defaultOpen,ariaExpandLabel,ariaCollapseLabel]"
                        name="Accordion Item"
                        summary="What are  the main symptoms of  IBD?"
                        text="&lt;p>Symptoms can vary from person to person, but they often include:&lt;/p>&lt;p>&lt;ul> &lt;li>Abdominal pain&lt;/li> &lt;li>Diarrhea&lt;/li> &lt;li>Changes in bowel movements&lt;/li> &lt;li>Rectal bleeding&lt;/li> &lt;/ul>&lt;/p>"/>
                    <item_2
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="accordion-item"
                        modelFields="[summary,text,classes_defaultOpen,ariaExpandLabel,ariaCollapseLabel]"
                        name="Accordion Item"
                        summary="What are some other possible complications of IBD?"
                        text="&lt;p>IBD patients sometimes can have symptoms such as arthritis (the inflammation of joints), skin complications or eye problems. These are called “extraintestinal manifestations” because they happen outside of the intestines.&lt;/p>"/>
                    <item_3
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="accordion-item"
                        modelFields="[summary,text,classes_defaultOpen,ariaExpandLabel,ariaCollapseLabel]"
                        name="Accordion Item"
                        summary="What is IBD remission?"
                        text="&lt;p>A main goal of IBD treatment is remission, which is a state when the disease is quiet. This can be measured by how a patient feels, what doctors see during a scope or what’s happening at the tissue level.&lt;/p>"/>
                    <item_4
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="accordion-item"
                        modelFields="[summary,text,classes_defaultOpen,ariaExpandLabel,ariaCollapseLabel]"
                        name="Accordion Item"
                        summary="Is IBD different from IBS?"
                        text="&lt;p>Yes. Although irritable bowel syndrome (IBS) has a similar name and some overlapping symptoms, it is not the same condition. IBD causes chronic inflammation that damages the intestinal lining, while IBS does not. Blood tests and stool tests can help doctors make the right diagnosis.&lt;/p>"/>
                </block_19>
