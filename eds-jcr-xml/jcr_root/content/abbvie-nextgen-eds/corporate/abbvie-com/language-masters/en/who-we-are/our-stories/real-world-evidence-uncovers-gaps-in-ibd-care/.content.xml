                    image="https://abbvie.scene7.com/is/image/abbviecorp/ibd-In-story-graphic?ts=1776963371093&amp;dpr=off"
                    imageAlt="An infographic on a light blue background with dark blue and purple text. Headline reads: “IBD patients report suboptimal results despite treatment with advanced therapies.” There are 2 icons representing statistics: 52% of people with Crohn’s disease and"
                    imageIsDecorative="false"
                    imageMimeType="image/unknown"
                    language="none"
                    linkAriaLabel="\0"
