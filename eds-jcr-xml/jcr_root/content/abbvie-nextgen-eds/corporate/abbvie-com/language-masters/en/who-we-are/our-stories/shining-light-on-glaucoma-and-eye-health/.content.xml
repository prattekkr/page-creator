                    <item_0
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="text-container-text"
                        modelFields="[text]"
                        name="Text Container Text"
                        text="&lt;p>The program is called Keep Sight where AbbVie helps to provide training for eyecare professionals in Nigeria and India to screen high risk populations, ensure early and accurate diagnosis and provide appropriate care to make a positive impact on people at risk or living with glaucoma.&lt;/p>&lt;p>In just one year, ophthalmologists conducted more than more than 12,000 eye screenings and referred more than 1,000 glaucoma-related cases.&lt;/p>"/>
                </block_9>
                <block_10
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    blockId="\0"
                    classes_customDynamicClass="h5-size,width-large"
