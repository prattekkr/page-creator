                    imageAlt="cell diagram"
                    imageIsDecorative="false"
                    imageMimeType="image/unknown"
                    language="none"
                    linkAriaLabel="\0"
                    modalPanelId="\0"
                    model="custom-image"
                    modelFields="[image,imageAlt,imageMimeType,getAltFromDAM,imageIsDecorative,caption,getCaptionFromDAM,displayCaptionBelowImage,enableLink,target,clickBehavior,modalPanelId,enableWarnOnLeave,warnOnLeavePath,linkAriaLabel,classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Custom Image"
                    target="\0"
                    warnOnLeavePath="\0"/>
                <block_13
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    blockId="\0"
                    classes_customDynamicClass="h5-size,format-outdented,width-large"
                    filter="custom-title"
                    language="none"
                    model="custom-title"
                    modelFields="[title,titleType,classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Custom Title"
                    title="Q: What’s next for Alfons?"
                    titleType="h5"/>
                <block_14
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="-"
                    blockId="-"
                    classes_customDynamicClass="spacing-bottom,width-large"
                    filter="text-container"
                    language="none"
                    model="text-container"
                    modelFields="[classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Text Container">
                    <item_0
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="text-container-text"
                        modelFields="[text]"
                        name="Text Container Text"
                        text="&lt;p>&lt;strong>Siedler:&lt;/strong> Our next goal is to achieve the full automation of our tests. The better the data position for a particular molecular format, the better we can then supplement experiments with mathematical models and, ideally, replace them. To do this, we must pool our knowledge and process it in such a way that it is always available to our researchers. This way, we can develop more innovative therapies for the most serious diseases and make them accessible to patients as quickly and efficiently as possible.&lt;/p>"/>
                </block_14>
                <block_15
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="-"
                    blockId="-"
                    classes_customDynamicClass="spacing-bottom,width-large,body-unica-20-reg"
                    filter="text-container"
                    language="none"
                    model="text-container"
                    modelFields="[classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Text Container">
