                    modelFields="[classes_customDynamicClass@ngaem:dynamic-picklist,blockId@text,classes_commonCustomClass@text,language@select,analytics_id@text]"
                    name="Text Container">
                    <text_container_text
                        jcr:created="{Date}2026-06-02T13:02:31.119Z"
                        jcr:createdBy="swatijain@adobe.com"
                        jcr:lastModified="{Date}2026-06-11T07:16:17.753Z"
                        jcr:lastModifiedBy="swatijain@adobe.com"
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        aueComponentId="text-container-text"
                        model="text-container-text"
                        modelFields="[text@richtext]"
                        name="Text Container Text"
                        text="&lt;p>1. An email was sent to you with your login credentials.&lt;/p>&#xa;&lt;p>Example credentials:&lt;/p>&#xa;&lt;p>&lt;br>Wi-Fi Name: &lt;em>AbbVie-Guest&lt;/em>&lt;br>Wi-Fi Username: &lt;strong>pbak5&lt;/strong>&lt;br>Wi-Fi Password: &lt;strong>2462&lt;/strong>&lt;/p>&#xa;&lt;p>2. On your device, go to &lt;strong>Wi-Fi settings&lt;/strong>.&lt;/p>&#xa;&lt;p>3. Select &lt;strong>&lt;em>AbbVie-Guest&lt;/em>&lt;/strong>&lt;em>.&lt;/em>&lt;/p>&#xa;&lt;p>4. On the &lt;strong>Guest Wi-Fi Login screen&lt;/strong>, enter the &lt;strong>login credentials&lt;/strong> provided in the email.&lt;/p>&#xa;&lt;p>5. Read AbbVie’s Acceptable Use Policy and click &lt;strong>Accept&lt;/strong>.&lt;/p>&#xa;&lt;p>6. Click Done to confirm you have access to &lt;strong>AbbVie’s Guest Wi-Fi.&lt;/strong>&lt;/p>"/>
                </text_container>
