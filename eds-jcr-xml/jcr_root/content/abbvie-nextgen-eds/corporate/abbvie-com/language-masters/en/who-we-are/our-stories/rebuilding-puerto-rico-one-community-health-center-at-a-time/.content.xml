                    name="Text Container">
                    <item_0
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="text-container-text"
                        modelFields="[text]"
                        name="Text Container Text"
                        text="&lt;p>&lt;div>The emergency room of the Centro de Salud Familiar clinic in Arroyo, Puerto Rico, sustained water and wind damage during Hurricane Maria.&lt;/div>&lt;/p>"/>
                </block_16>
                <block_17
