                    name="Custom Title"
                    title="Every little bit makes a difference"
                    titleType="h2"/>
                <block_12
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="-"
                    blockId="-"
                    classes_customDynamicClass="spacing-bottom,width-large"
                    filter="text-container"
                    language="none"
                    model="text-container"
                    modelFields="[classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Text Container">
                    <item_0
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="text-container-text"
                        modelFields="[text]"
                        name="Text Container Text"
                        text="&lt;p>Another essential volunteer task is traffic control, which includes organizing vehicles into 8 different lanes and cycling them in and out quickly and safely.&lt;/p>&lt;p>In his native Brazil, AbbVie global marketing manager Felipe Marques Goncalves is a medical doctor. But at the Fairgrounds, he donned a reflective vest and took on traffic control.&lt;/p>"/>
                </block_12>
                <block_13
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
