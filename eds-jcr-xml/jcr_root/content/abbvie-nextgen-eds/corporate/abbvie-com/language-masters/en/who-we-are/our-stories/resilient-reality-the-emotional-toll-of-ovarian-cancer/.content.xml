                    image="https://delivery-p157365-e1665873.adobeaemcloud.com/adobe/assets/urn:aaid:aem:7c3d99b5-c23d-4bb1-8f5f-939602add453/as/global-ovarian-cancer-infographic-v2.jpg?dpr=1"
                    imageAlt="global ovarian cancer infographic"
                    imageIsDecorative="false"
                    imageMimeType="image/unknown"
                    language="none"
                    linkAriaLabel="\0"
                    modalPanelId="\0"
                    model="custom-image"
                    modelFields="[image,imageAlt,imageMimeType,getAltFromDAM,imageIsDecorative,caption,getCaptionFromDAM,displayCaptionBelowImage,enableLink,target,clickBehavior,modalPanelId,enableWarnOnLeave,warnOnLeavePath,linkAriaLabel,classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
