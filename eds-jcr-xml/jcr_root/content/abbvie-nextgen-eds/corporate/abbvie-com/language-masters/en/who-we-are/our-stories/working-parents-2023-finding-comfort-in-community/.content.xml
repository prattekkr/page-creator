                    getAltFromDAM="false"
                    getCaptionFromDAM="false"
                    image="https://delivery-p157365-e1665873.adobeaemcloud.com/adobe/assets/urn:aaid:aem:143aa1b9-8776-4fcf-9970-129b7817043b/as/lisa-mathews-family.jpg?dpr=1"
                    imageAlt="lisa mathews family"
                    imageIsDecorative="false"
                    imageMimeType="image/unknown"
                    language="none"
                    linkAriaLabel="\0"
                    modalPanelId="\0"
