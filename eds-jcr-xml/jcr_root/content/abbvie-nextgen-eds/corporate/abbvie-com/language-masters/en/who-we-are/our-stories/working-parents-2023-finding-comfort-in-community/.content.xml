                    name="Custom Image"
                    target="\0"
                    warnOnLeavePath="\0"/>
                <block_13
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    blockId="\0"
                    classes_customDynamicClass="h5-size,format-outdented,width-large"
                    filter="custom-title"
                    language="none"
                    model="custom-title"
                    modelFields="[title,titleType,classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Custom Title"
                    title="Q: Describe the work you do to support other families of those with special needs."
                    titleType="h5"/>
                <block_14
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="-"
                    blockId="-"
                    classes_customDynamicClass="spacing-bottom,width-large"
                    filter="text-container"
                    language="none"
                    model="text-container"
                    modelFields="[classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Text Container">
                    <item_0
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="text-container-text"
                        modelFields="[text]"
                        name="Text Container Text"
                        text="&lt;p>At first, I was talking one-on-one to parents who also had children on the autism spectrum, offering advice and support, but in more recent years giving back has become a family affair, which I’m so proud of. Together we’ve raised money to support organizations helping people with disabilities and have volunteered in various capacities. When Maddy was 8, she even set up a lemonade stand to raise money in support of her brother’s future care, raising over $2,000 for new smart boards at his school.&lt;/p>&lt;p>I’ve also gotten involved at AbbVie by becoming a member and contributor to &lt;a href=&quot;/join-us/life-at-abbvie/employee-resource-groups/ability-at-abbvie.html&quot;>Ability at AbbVie&lt;/a>, an employee resource group that's all about community, advocacy and driving awareness for people with disabilities. This past year, I signed up to be the community chair for Ability, leading volunteer and philanthropy efforts. If I can help in any way to make that path less stressful for somebody else, it makes it worth it.&lt;/p>"/>
                </block_14>
                <block_15
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    attributionImage="https://delivery-p157365-e1665873.adobeaemcloud.com/adobe/assets/urn:aaid:aem:f062452e-e29a-4d41-b764-930d63f53bde/as/lisa-mathews-quote.jpg"
                    attributionImageMimeType="image/unknown"
                    attributionName="Lisa Mathews"
                    attributionRole="Director, Integrated Communications, Strategic Planning and Operations"
                    backgroundImageAlt="\0"
                    blockId="\0"
                    classes_contentAlignment="quote-align-none"
                    classes_contentWidth="quote-content-col-none"
                    classes_theme="quote-none"
                    customClass="\0"
                    id="\0"
                    language="quote-standard,quote-h4"
                    model="quote"
                    modelFields="[quoteVariant,quotation,attributionName,attributionRole,attributionImage,attributionImageMimeType,quoteFragment,backgroundImage,backgroundImageAlt,backgroundImageMimeType,classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Quote"
                    quotation="&lt;p>I strive to work with everyone in a way that allows them to shine their brightest.”&lt;/p>"
                    quoteVariant="quote-standard"/>
                <block_16
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    blockId="\0"
                    classes_customDynamicClass="h5-size,format-outdented,width-large"
                    filter="custom-title"
                    language="none"
                    model="custom-title"
                    modelFields="[title,titleType,classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Custom Title"
                    title="Q: Sofie, what are some ways in which you support your children’s hobbies and how do you prioritize this from the perspective of a single parent?"
                    titleType="h5"/>
                <block_17
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="-"
                    blockId="-"
                    classes_customDynamicClass="spacing-bottom,width-large"
                    filter="text-container"
                    language="none"
                    model="text-container"
                    modelFields="[classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Text Container">
                    <item_0
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="text-container-text"
                        modelFields="[text]"
                        name="Text Container Text"
                        text="&lt;p>&lt;strong>Sofie&lt;/strong>: I do everything I can to be a part of my sons’ extracurricular activities. My husband Mattias had previously driven the boys to and from most of their soccer practices and games. I now utilize Excel to manage my weekly schedule–ensuring the boys have transportation and that I can help to carpool while also attending important events. I often try to work in calls with my colleagues in Asia and Australia while sitting in my car at the pitch during practices, which is beneficial for my global role.&lt;/p>&lt;p>By sharing the carpooling with the other parents, I can best prioritize my evening obligations between the two boys, business travel and business events. I am very fortunate in that the carpooling families have given me the opportunity to be flexible, allowing me to choose days that work best within my schedule.&lt;/p>&lt;p>While the schedules and traffic can be challenging, I treasure hearing my sons and their friends joke around, sing to the radio and even talk about the girls they like. I know these moments are fleeting and am grateful for this time with my boys and their friends.&lt;/p>"/>
                </block_17>
                <block_18
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analyticsInteractionId="\0"
                    blockId="\0"
                    caption="Working Parent Sofie Berg and her two sons Hugo and Victor connect through a love of soccer, cooking and travel."
                    classes_commonCustomClass="\0"
                    clickBehavior="_self"
                    displayCaptionBelowImage="true"
                    enableLink="false"
                    enableWarnOnLeave="false"
                    getAltFromDAM="false"
                    getCaptionFromDAM="false"
                    image="https://delivery-p157365-e1665873.adobeaemcloud.com/adobe/assets/urn:aaid:aem:416c53ab-918b-4391-8638-6ac250a49dab/as/sofie-berg-family.jpg?dpr=1"
                    imageAlt="sofie berg family"
                    imageIsDecorative="false"
                    imageMimeType="image/unknown"
                    language="none"
                    linkAriaLabel="\0"
                    modalPanelId="\0"
                    model="custom-image"
                    modelFields="[image,imageAlt,imageMimeType,getAltFromDAM,imageIsDecorative,caption,getCaptionFromDAM,displayCaptionBelowImage,enableLink,target,clickBehavior,modalPanelId,enableWarnOnLeave,warnOnLeavePath,linkAriaLabel,classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Custom Image"
                    target="\0"
                    warnOnLeavePath="\0"/>
                <block_19
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    blockId="\0"
                    classes_customDynamicClass="h5-size,format-outdented,width-large"
