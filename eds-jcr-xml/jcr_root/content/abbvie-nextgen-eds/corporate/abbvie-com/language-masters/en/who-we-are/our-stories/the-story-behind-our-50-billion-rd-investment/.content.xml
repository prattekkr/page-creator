                    imageAlt="new products or indications"
                    imageIsDecorative="false"
                    imageMimeType="image/unknown"
                    language="none"
                    linkAriaLabel="\0"
                    modalPanelId="\0"
                    model="custom-image"
                    modelFields="[image,imageAlt,imageMimeType,getAltFromDAM,imageIsDecorative,caption,getCaptionFromDAM,displayCaptionBelowImage,enableLink,target,clickBehavior,modalPanelId,enableWarnOnLeave,warnOnLeavePath,linkAriaLabel,classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Custom Image"
                    target="\0"
                    warnOnLeavePath="\0"/>
                <block_11
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    blockId="\0"
                    classes_customDynamicClass="h5-size,width-large"
                    filter="custom-title"
                    language="none"
                    model="custom-title"
                    modelFields="[title,titleType,classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Custom Title"
                    title="R&amp;D is how we help the patients of tomorrow"
                    titleType="h5"/>
                <block_12
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="-"
                    blockId="-"
                    classes_customDynamicClass="spacing-bottom,width-large"
                    filter="text-container"
                    language="none"
                    model="text-container"
                    modelFields="[classes_customDynamicClass,blockId,classes_commonCustomClass,language,analytics_id]"
                    name="Text Container">
                    <item_0
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="text-container-text"
                        modelFields="[text]"
                        name="Text Container Text"
                        text="&lt;p>When people think of large pharmaceutical companies, they don’t often think of biochemists staying late to get lab results or data scientists poring over real time data on patient outcomes. But they should.&lt;/p>&lt;p>Because it’s science – and the billions we have invested in our science – that drives this company. There are scientists in our labs today who come to work every day with one goal: to help patients. Many work years to advance a molecule to the next stage of clinical development. They are working to get patients back to their lives, back to their families. I’m tremendously proud that AbbVie has helped millions of patients, but I’m even prouder of our potential and of what we can do for the millions who still need new and better treatments. The innovation in our labs has always connected us to patients.&lt;/p>&lt;p>And it always will.&lt;/p>"/>
                </block_12>
