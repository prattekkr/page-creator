                        sling:resourceType="core/franklin/components/block/v1/block/item"
                        model="text-container-text"
                        modelFields="[text]"
                        name="Text Container Text"
                        text="&lt;p>Organizations with deep community roots, like CommunityHealth, help build sustainable healthcare initiatives that create meaningful change. The clinics demonstrate the importance of increasing equitable access to quality health care one community, one clinic and one patient at a time.&lt;/p>"/>
                </block_9>
