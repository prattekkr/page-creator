                    name="Quote"
                    quotation="&lt;p>With support from the AbbVie Foundation, we’re able to meet patients where they’re at and ensure greater health equity throughout the city.&lt;/p>"
                    quoteVariant="quote-standard"/>
                <block_3
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="-"
