                        modelFields="[text]"
                        name="Text Container Text"
                        text="&lt;p>&lt;ol> &lt;li>&lt;a href=&quot;https://nationaleczema.org/research/eczema-facts/&quot;>https://nationaleczema.org/research/eczema-facts/&lt;/a>&lt;/li> &lt;li>&lt;a href=&quot;https://www.psoriasis.org/about-psoriasis/&quot;>https://www.psoriasis.org/about-psoriasis/&lt;/a>&lt;/li> &lt;li>&lt;a href=&quot;https://nationaleczema.org/eczema-emotional-wellness/&quot;>https://nationaleczema.org/eczema-emotional-wellness/&lt;/a>&lt;/li> &lt;li>&lt;a href=&quot;https://www.sciencedirect.com/science/article/abs/pii/S000173101830320X?via%3Dihub&quot;>https://www.sciencedirect.com/science/article/abs/pii/S000173101830320X?via%3Dihub&lt;/a>&lt;/li> &lt;li>&lt;a href=&quot;https://www.jidonline.org/article/S0022-202X(17)31856-0/fulltext&quot;>https://www.jidonline.org/article/S0022-202X(17)31856-0/fulltext&lt;/a>&lt;/li> &lt;/ol>&lt;/p>"/>
