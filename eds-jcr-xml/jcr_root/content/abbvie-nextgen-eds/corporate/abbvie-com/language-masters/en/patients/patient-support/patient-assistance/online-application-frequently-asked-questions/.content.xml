                        modelFields="[summary,text,classes_defaultOpen,ariaExpandLabel,ariaCollapseLabel]"
                        name="Accordion Item"
                        summary="What types of files can I upload to my documents?"
                        text="&lt;p>We support the following file types:  JPEG, JPG and PDF. If applying from a mobile phone, you may take a picture of your document and upload.&lt;/p>"/>
