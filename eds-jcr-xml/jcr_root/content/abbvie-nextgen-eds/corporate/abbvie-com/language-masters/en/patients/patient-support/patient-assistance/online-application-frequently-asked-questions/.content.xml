                        modelFields="[summary,text,classes_defaultOpen,ariaExpandLabel,ariaCollapseLabel]"
                        name="Accordion Item"
                        summary="How long do I have to wait before I can reset my password?"
                        text="&lt;p>Please give us 15 minutes before resetting your password.&lt;/p>"/>
                    <item_12
                        jcr:primaryType="nt:unstructured"
