                        name="Accordion Item"
                        summary="Benefits"
                        text="&lt;ul>&#xa; &lt;li>Comprehensive medical, dental, vision, mental health and prescription drug coverage &lt;/li>&#xa; &lt;li>Sick pay and medical leave&lt;/li>&#xa; &lt;li>Life and disability insurance&lt;/li>&#xa; &lt;li>Flexible spending accounts to help pay for health expenses using pre-tax dollars*&lt;/li>&#xa; &lt;li>Retirement Savings Plan&lt;/li>&#xa; &lt;li>Employee Stock Purchase Plan, available in most countries outside the U.S.&lt;/li>&#xa; &lt;li>Housing and transport allowances, available outside the U.S.&lt;/li>&#xa;&lt;/ul>&#xa;&lt;p>* Available in the U.S.&lt;/p>"/>
                    <accordion_item_2
                        jcr:lastModified="{Date}2026-06-18T15:39:19.864Z"
                        jcr:lastModifiedBy="sheetal.joshi@abbvie.com"
