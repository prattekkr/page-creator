                        model="accordion-item"
                        modelFields="[summary@text,text@richtext,classes_defaultOpen@boolean,ariaExpandLabel@text,ariaCollapseLabel@text]"
                        name="Accordion Item"
                        summary="Flexible work and time off"
                        text="&lt;ul>&#xa; &lt;li>Workplace flexibility that varies based on role, such as flex time, part-time work, job sharing, shift changes, compressed work weeks, and remote work&lt;/li>&#xa; &lt;li>Hybrid work model for office-based employees that consists of three minimum set days in the office and two days of remote work per week&lt;/li>&#xa; &lt;li>A phased retirement program*&lt;/li>&#xa; &lt;li>Paid vacation and company holidays&lt;/li>&#xa; &lt;li>Two paid days off to volunteer, in addition to company-wide volunteer week&lt;/li>&#xa;&lt;/ul>&#xa;&lt;p>*Available in the U.S.&lt;/p>"/>
                    <accordion_item_3
                        jcr:lastModified="{Date}2026-06-18T15:39:52.784Z"
                        jcr:lastModifiedBy="sheetal.joshi@abbvie.com"
