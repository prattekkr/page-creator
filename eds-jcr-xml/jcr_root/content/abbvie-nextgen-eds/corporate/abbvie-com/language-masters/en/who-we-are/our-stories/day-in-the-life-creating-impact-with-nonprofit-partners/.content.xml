                    projectNumber="-"
                    uri="https://www.youtube.com/embed/IGZ15zM1NXc?enablejsapi=1&amp;origin=https%3A%2F%2Fwww.abbvie.com&amp;widgetid=1&amp;forigin=https%3A%2F%2Fwww.abbvie.com%2Fwho-we-are%2Four-stories%2Fday-in-the-life-creating-impact-with-nonprofit-partners.html&amp;aoriginsup=1&amp;vf=1"
                    videoContentLayout="none"/>
                <block_10
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="-"
                    blockId="-"
                    classes_customDynamicClass="spacing-bottom,width-large"
