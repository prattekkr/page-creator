                    name="Quote"
                    quotation="&lt;p>Tenacity is the anchor of solving any real challenge.&lt;/p>"
                    quoteVariant="quote-standard"/>
                <block_8
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="core/franklin/components/block/v1/block"
                    analytics_id="-"
                    blockId="-"
                    classes_customDynamicClass="standard,custom-class"
