                        name="Text Container Text"
                        text="&lt;p>&lt;strong>Media inquiries:&lt;/strong>&lt;br> Email: &lt;a href=&quot;mailto:abbviemediarelations@abbvie.com&quot;>abbviemediarelations@abbvie.com&lt;/a>&lt;/p>"/>
                </block_22>
