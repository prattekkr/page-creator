                    image="https://delivery-p157365-e1665873.adobeaemcloud.com/adobe/assets/urn:aaid:aem:a2853694-bbea-4dcc-ac3b-d7957d8f7355/as/Degradomers_InBody_Team_Photo_1750x1400.jpg?dpr=1"
                    imageAlt="Unlocking the next level of protein degradation"
                    imageIsDecorative="false"
                    imageMimeType="image/unknown"
                    language="none"
