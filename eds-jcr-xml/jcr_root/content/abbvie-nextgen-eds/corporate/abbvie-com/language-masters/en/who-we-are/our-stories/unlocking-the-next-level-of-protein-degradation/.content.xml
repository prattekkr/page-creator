                    overlayHeading="Unlocking the next level of protein degradation"
                    placeholderImage="https://delivery-p157365-e1665873.adobeaemcloud.com/adobe/assets/urn:aaid:aem:25b6d006-f0ed-417a-877d-ffb8934571a3/as/degradomers-video-thumbnail.jpg"
