                    image="https://delivery-p157365-e1665873.adobeaemcloud.com/adobe/assets/urn:aaid:aem:bf800543-cc6a-40d5-a3d7-a8f9d6605793/as/advancing-public-health_inbody-2.png?dpr=1"
                    imageAlt="The DNA of Patient Safety"
                    imageIsDecorative="false"
                    imageMimeType="image/unknown"
